// Prisma schema for Minerva RBAC system
generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// RBAC Models
// ============================================

/// Admin user account for management panels
model AdminUser {
  id          String   @id @default(cuid())
  sub         String   @unique @db.VarChar(100)
  displayName String?  @map("display_name") @db.VarChar(100)
  avatarUrl   String?  @map("avatar_url") @db.VarChar(500)
  tenantKey   String?  @map("tenant_key") @db.VarChar(100)
  unionId     String?  @unique @map("union_id") @db.VarChar(100)
  mobile      String?  @db.VarChar(50)
  password    String   @db.VarChar(255)
  userType    UserType @default(FEISHU) @map("user_type")

  // Relations
  userRoles UserRole[]
  auditLogs AuditLog[]

  @@map("admin_users")
}

/// Role defines a set of permissions
model Role {
  id          String   @id @default(cuid())
  name        String   @unique @db.VarChar(50)
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("admin_roles")
}

/// Permission represents a single capability/action
model Permission {
  id          String   @id @default(cuid())
  key         String   @unique @db.VarChar(100) // e.g., "rbac.user.read", "pwa.dashboard.export"
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  rolePermissions RolePermission[]

  @@map("admin_permissions")
}

/// Many-to-many relation between AdminUser and Role
model UserRole {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("admin_user_roles")
}

/// Many-to-many relation between Role and Permission
model RolePermission {
  id           String   @id @default(cuid())
  roleId       String   @map("role_id")
  permissionId String   @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("admin_role_permissions")
}

/// Audit log for tracking RBAC changes
model AuditLog {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id")
  action     String   @db.VarChar(50) // e.g., "user.create", "role.update", "permission.delete"
  targetType String?  @map("target_type") @db.VarChar(50) // e.g., "AdminUser", "Role", "Permission"
  targetId   String?  @map("target_id")
  details    Json? // Additional details about the change
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent") @db.VarChar(500)
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  user AdminUser? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("admin_audit_logs")
}

// ============================================
// Enums
// ============================================

enum UserType {
  SYSTEM  // System account (can login with password)
  FEISHU  // Feishu OAuth user (password login disabled)
}