@@ -0,0 +1,186 @@
+import { PageContainer, ProTable } from '@ant-design/pro-components';
+import type { ProColumns, ActionType } from '@ant-design/pro-components';
+import { useAccess } from '@umijs/max';
+import { Button, Tag, message } from 'antd';
+import {
+  ReloadOutlined,
+  ClockCircleOutlined,
+  SendOutlined,
+  CheckCircleOutlined,
+  CloseCircleOutlined,
+  StopOutlined,
+} from '@ant-design/icons';
+import React, { useRef } from 'react';
+import { useRequest } from 'ahooks';
+import { listQueueMessages, getQueueStats, retryQueueMessage } from '@/api/union';
+import { GradientStatRow } from '@/components/GradientStatCard';
+import type { StatCardItem } from '@/components/GradientStatCard';
+import dayjs from 'dayjs';
+
+type QueueItem = {
+  id: string;
+  userId: string;
+  deviceId: string;
+  content: string;
+  priority: number;
+  sendStatus: string;
+  retryCount: number;
+  scheduledAt: string;
+  createdAt: string;
+  failReason: string | null;
+  user?: { id: string; phone: string };
+  device?: { id: string; deviceId: string };
+};
+
+const statusEnum: Record<string, { text: string; color: string }> = {
+  pending: { text: '待发送', color: 'default' },
+  sent: { text: '已发送', color: 'processing' },
+  delivered: { text: '已送达', color: 'success' },
+  failed: { text: '失败', color: 'error' },
+  dead: { text: '已失效', color: 'default' },
+};
+
+const QUEUE_CARD_STYLES: Record<string, { icon: React.ReactNode; color: string; bg: string }> = {
+  pending: {
+    icon: <ClockCircleOutlined />,
+    color: '#8c8c8c',
+    bg: 'linear-gradient(135deg, #fafafa 0%, #f0f0f0 100%)',
+  },
+  sent: {
+    icon: <SendOutlined />,
+    color: '#1890ff',
+    bg: 'linear-gradient(135deg, #e6f4ff 0%, #bae0ff 100%)',
+  },
+  delivered: {
+    icon: <CheckCircleOutlined />,
+    color: '#52c41a',
+    bg: 'linear-gradient(135deg, #f6ffed 0%, #d9f7be 100%)',
+  },
+  failed: {
+    icon: <CloseCircleOutlined />,
+    color: '#ff4d4f',
+    bg: 'linear-gradient(135deg, #fff2f0 0%, #ffccc7 100%)',
+  },
+  dead: {
+    icon: <StopOutlined />,
+    color: '#595959',
+    bg: 'linear-gradient(135deg, #f5f5f5 0%, #e8e8e8 100%)',
+  },
+};
+
+const UnionDeviceQueue: React.FC = () => {
+  const access = useAccess();
+  const actionRef = useRef<ActionType>(null);
+  const { data: stats, refresh: refreshStats } = useRequest(getQueueStats);
+
+  const handleRetry = async (id: string) => {
+    try {
+      await retryQueueMessage(id);
+      message.success('已重新加入队列');
+      actionRef.current?.reload();
+      refreshStats();
+    } catch {
+      message.error('重试失败');
+    }
+  };
+
+  const columns: ProColumns<QueueItem>[] = [
+    {
+      title: '用户',
+      dataIndex: 'userId',
+      width: 140,
+      render: (_, r) => r.user?.phone || r.userId,
+      copyable: true,
+    },
+    {
+      title: '设备',
+      dataIndex: 'deviceId',
+      width: 120,
+      render: (_, r) => r.device?.deviceId || r.deviceId || '—',
+    },
+    { title: '内容预览', dataIndex: 'content', ellipsis: true, width: 200, hideInSearch: true },
+    { title: '优先级', dataIndex: 'priority', sorter: true, hideInSearch: true, width: 80 },
+    {
+      title: '发送状态',
+      dataIndex: 'sendStatus',
+      valueType: 'select',
+      width: 100,
+      valueEnum: Object.fromEntries(Object.entries(statusEnum).map(([k, v]) => [k, { text: v.text }])),
+      render: (_, r) => <Tag color={statusEnum[r.sendStatus]?.color}>{statusEnum[r.sendStatus]?.text || r.sendStatus}</Tag>,
+    },
+    { title: '重试次数', dataIndex: 'retryCount', hideInSearch: true, width: 80 },
+    {
+      title: '失败原因',
+      dataIndex: 'failReason',
+      hideInSearch: true,
+      width: 150,
+      ellipsis: true,
+      render: (v: any) => v || '—',
+    },
+    {
+      title: '创建时间',
+      dataIndex: 'createdAt',
+      hideInSearch: true,
+      sorter: true,
+      width: 170,
+      render: (_, r) => r.createdAt ? dayjs(r.createdAt).format('YYYY-MM-DD HH:mm:ss') : '—',
+    },
+    {
+      title: '操作',
+      valueType: 'option',
+      width: 80,
+      render: (_, record) =>
+        record.sendStatus === 'failed'
+          ? [<a key="retry" onClick={() => handleRetry(record.id)}>重试</a>]
+          : [],
+    },
+  ];
+
+  const queueStatCards: StatCardItem[] = Object.entries(statusEnum).map(([key, { text }]) => {
+    const style = QUEUE_CARD_STYLES[key] ?? QUEUE_CARD_STYLES.pending;
+    return {
+      title: text,
+      value: stats?.[key] ?? 0,
+      icon: style.icon,
+      color: style.color,
+      bg: style.bg,
+    };
+  });
+
+  return (
+    <PageContainer>
+      {stats && (
+        <GradientStatRow cards={queueStatCards} style={{ marginBottom: 16 }} />
+      )}
+
+      <ProTable<QueueItem>
+        headerTitle="消息队列"
+        actionRef={actionRef}
+        rowKey="id"
+        columns={columns}
+        request={async (params) => {
+          const res = await listQueueMessages({
+            page: params.current,
+            pageSize: params.pageSize,
+            status: params.sendStatus,
+            deviceId: params.deviceId,
+          });
+          return { data: res.items, total: res.total, success: true };
+        }}
+        toolBarRender={() => [
+          <Button
+            key="refresh"
+            icon={<ReloadOutlined />}
+            onClick={() => { actionRef.current?.reload(); refreshStats(); }}
+          >
+            刷新
+          </Button>,
+        ]}
+        search={{ labelWidth: 'auto' }}
+        pagination={{ defaultPageSize: 20, showSizeChanger: true }}
+      />
+    </PageContainer>
+  );
+};
+
+export default UnionDeviceQueue;
