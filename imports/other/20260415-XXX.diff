+++ b/scripts/device-sim.js
@@ -0,0 +1,157 @@
+#!/usr/bin/env node
+/**
+ * Device WS Simulator
+ *
+ * Simulates a physical phone device connecting to the Minerva gateway.
+ *
+ * Usage:
+ *   node scripts/device-sim.js "<wsUrl>?token=<token>" [deviceId] [phoneNumber]
+ *
+ * Example:
+ *   node scripts/device-sim.js "ws://localhost:29001/ws/device?token=eyJ..." dev-001 13800138000
+ *
+ * Interactive commands (type in terminal after connected):
+ *   send <phone> <content>   — send inbound_message frame
+ *   push <type> <json>       — send raw frame
+ *   quit                     — disconnect
+ */
+
+const WebSocket = require('ws');
+const readline = require('readline');
+
+// ── Args ────────────────────────────────────────────────────
+const [,, rawUrl, deviceId = `sim-${Date.now()}`, phoneNumber = '13800138000'] = process.argv;
+
+if (!rawUrl) {
+  console.error('Usage: node device-sim.js "<wsUrl>?token=<token>" [deviceId] [phoneNumber]');
+  process.exit(1);
+}
+
+// ── Connect ─────────────────────────────────────────────────
+console.log(`\n🔌 Connecting to: ${rawUrl}`);
+console.log(`   deviceId   : ${deviceId}`);
+console.log(`   phoneNumber: ${phoneNumber}\n`);
+
+const ws = new WebSocket(rawUrl);
+let heartbeatTimer = null;
+let registered = false;
+
+function send(type, data = {}) {
+  const frame = JSON.stringify({ type, data, ts: Date.now() });
+  ws.send(frame);
+  console.log(`  ↑ SEND  [${type}]`, JSON.stringify(data));
+}
+
+ws.on('open', () => {
+  console.log('✅ Connected\n');
+
+  // Register
+  send('register', { deviceId, phoneNumber, dailyLimit: 200 });
+
+  // Start heartbeat every 20s
+  heartbeatTimer = setInterval(() => {
+    if (ws.readyState === WebSocket.OPEN) {
+      send('heartbeat');
+    }
+  }, 20_000);
+});
+
+ws.on('message', (raw) => {
+  let frame;
+  try {
+    frame = JSON.parse(raw.toString());
+  } catch {
+    console.log('  ↓ RECV  [raw]', raw.toString());
+    return;
+  }
+
+  const { type, data } = frame;
+  console.log(`  ↓ RECV  [${type}]`, JSON.stringify(data ?? {}));
+
+  if (type === 'registered') {
+    registered = true;
+    console.log('\n🎉 Device registered successfully!');
+    console.log('   Type "help" for interactive commands.\n');
+  }
+
+  if (type === 'push_message') {
+    console.log(`\n📨 Incoming push — messageId: ${data?.messageId}`);
+    console.log(`   To   : ${data?.phone}`);
+    console.log(`   Msg  : ${data?.content}`);
+    // Auto-acknowledge
+    setTimeout(() => {
+      send('send_result', { messageId: data?.messageId, status: 'sent' });
+    }, 500);
+  }
+});
+
+ws.on('close', (code, reason) => {
+  console.log(`\n❌ Disconnected (${code}: ${reason})`);
+  if (heartbeatTimer) clearInterval(heartbeatTimer);
+  process.exit(0);
+});
+
+ws.on('error', (err) => {
+  console.error('WS Error:', err.message);
+});
+
+// ── Interactive CLI ──────────────────────────────────────────
+const rl = readline.createInterface({ input: process.stdin, output: process.stdout, terminal: true });
+
+function printHelp() {
+  console.log('\nCommands:');
+  console.log('  help                         — show this help');
+  console.log('  send <phone> <content>       — send inbound_message');
+  console.log('  raw <type> <json>            — send raw frame (json as single arg)');
+  console.log('  quit                         — disconnect and exit\n');
+}
+
+rl.on('line', (line) => {
+  const trimmed = line.trim();
+  if (!trimmed) return;
+
+  const parts = trimmed.split(' ');
+  const cmd = parts[0].toLowerCase();
+
+  if (cmd === 'help') {
+    printHelp();
+    return;
+  }
+
+  if (cmd === 'quit' || cmd === 'exit') {
+    console.log('Closing connection...');
+    ws.close();
+    return;
+  }
+
+  if (cmd === 'send') {
+    const phone = parts[1];
+    const content = parts.slice(2).join(' ');
+    if (!phone || !content) {
+      console.log('Usage: send <phone> <content>');
+      return;
+    }
+    send('inbound_message', { phone, content });
+    return;
+  }
+
+  if (cmd === 'raw') {
+    const type = parts[1];
+    const jsonStr = parts.slice(2).join(' ') || '{}';
+    let data;
+    try {
+      data = JSON.parse(jsonStr);
+    } catch {
+      console.log('Invalid JSON');
+      return;
+    }
+    send(type, data);
+    return;
+  }
+
+  console.log(`Unknown command: ${cmd}. Type "help" for usage.`);
+});
+
+rl.on('close', () => {
+  ws.close();
+});
