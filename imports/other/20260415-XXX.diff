+import Router from '@koa/router';
+import { unionInferenceRequestSchema } from '@sitin/minerva-schemas';
+import { prisma } from '../../utils/prisma.js';
+import { success } from '../../utils/response.js';
+import { AppError } from '../../utils/AppError.js';
+import { authMiddleware, requirePermission } from '../../middlewares/auth.js';
+import { aiStats } from '../../services/union/ai-stats.js';
+
+export const aiServiceRouter = new Router();
+
+aiServiceRouter.use(authMiddleware);
+
+/**
+ * GET /api/union/ai-service/stats
+ * AI 调用统计（数据库持久化）
+ */
+aiServiceRouter.get('/stats', requirePermission('union.brain.config'), async (ctx) => {
+  success(ctx, await aiStats.getStats());
+});
+
+/**
+ * POST /api/union/ai-service/inference
+ * Direct model inference
+ */
+aiServiceRouter.post('/inference', requirePermission('union.brain.config'), async (ctx) => {
+  const body = unionInferenceRequestSchema.parse(ctx.request.body);
+
+  // Resolve model config
+  let modelConfig;
+  if (body.modelConfigId) {
+    modelConfig = await prisma.unionModelConfig.findFirst({
+      where: { id: body.modelConfigId, enabled: true },
+    });
+    if (!modelConfig) {
+      throw AppError.notFound(`Model config "${body.modelConfigId}" not found or disabled`);
+    }
+  } else {
+    modelConfig = await prisma.unionModelConfig.findFirst({
+      where: { enabled: true },
+      orderBy: { priority: 'desc' },
+    });
+    if (!modelConfig) {
+      throw AppError.badRequest('No enabled AI model config found');
+    }
+  }
+
+  const startTime = Date.now();
+
+  try {
+    const response = await fetch(`${modelConfig.endpoint}/v1/chat/completions`, {
+      method: 'POST',
+      headers: {
+        'Content-Type': 'application/json',
+        Authorization: `Bearer ${modelConfig.apiKey}`,
+      },
+      body: JSON.stringify({
+        model: modelConfig.modelName,
+        messages: [{ role: 'user', content: body.prompt }],
+        max_tokens: body.maxTokens ?? (modelConfig.params as any)?.maxTokens ?? 4096,
+        temperature: body.temperature ?? (modelConfig.params as any)?.temperature ?? 0.7,
+      }),
+    });
+
+    const result = await response.json() as any;
+    const latencyMs = Date.now() - startTime;
+
+    const text = result.choices?.[0]?.message?.content ?? '';
+    const tokenUsage = {
+      input: result.usage?.prompt_tokens ?? 0,
+      output: result.usage?.completion_tokens ?? 0,
+    };
+
+    aiStats.track('inference', modelConfig.modelName, true, latencyMs);
+
+    success(ctx, {
+      text,
+      modelUsed: modelConfig.modelName,
+      tokenUsage,
+      latencyMs,
+    });
+  } catch (err: any) {
+    aiStats.track('inference', modelConfig.modelName, false, Date.now() - startTime);
+    throw new AppError(`AI inference failed: ${err.message}`, 500, 'AI_ERROR');
+  }
+});
