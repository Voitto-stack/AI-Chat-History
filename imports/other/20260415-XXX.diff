+import { PageContainer, ProCard } from '@ant-design/pro-components';
+import { useAccess, history, useSearchParams } from '@umijs/max';
+import { useRequest } from 'ahooks';
+import { Form, Input, Select, Button, Space, message, Typography } from 'antd';
+import React, { useEffect } from 'react';
+import {
+  getUnionTemplate,
+  createUnionTemplate,
+  updateUnionTemplate,
+} from '@/api/union';
+import { unionPhaseOptions } from '@sitin/minerva-schemas';
+
+const VARIABLES = ['{{user_name}}', '{{app_name}}', '{{link}}', '{{date}}'];
+
+const UnionTemplateEditor: React.FC = () => {
+  const access = useAccess();
+  const [searchParams] = useSearchParams();
+  const templateId = searchParams.get('id');
+  const [form] = Form.useForm();
+  const content = Form.useWatch('content', form);
+
+  const { loading: fetching } = useRequest(
+    () => getUnionTemplate(templateId!),
+    {
+      ready: !!templateId,
+      onSuccess: (data) => {
+        form.setFieldsValue(data);
+      },
+    },
+  );
+
+  const { run: save, loading: saving } = useRequest(
+    async (values: any) => {
+      if (templateId) {
+        return updateUnionTemplate(templateId, values);
+      }
+      return createUnionTemplate(values);
+    },
+    {
+      manual: true,
+      onSuccess: () => {
+        message.success('保存成功');
+        history.push('/union/templates');
+      },
+    },
+  );
+
+  const insertVariable = (v: string) => {
+    const cur = form.getFieldValue('content') || '';
+    form.setFieldValue('content', cur + v);
+  };
+
+  return (
+    <PageContainer title="模板编辑器" onBack={() => history.push('/union/templates')}>
+      <div style={{ display: 'flex', gap: 16 }}>
+        <ProCard title="编辑" style={{ flex: 1 }} loading={fetching}>
+          <Form form={form} layout="vertical" onFinish={save}>
+            <Form.Item name="phase" label="阶段" rules={[{ required: true }]}>
+              <Select placeholder="选择阶段" options={unionPhaseOptions} />
+            </Form.Item>
+            <Form.Item name="scene" label="场景" rules={[{ required: true }]}>
+              <Input placeholder="场景标识" />
+            </Form.Item>
+            <Form.Item name="versionCode" label="版本号" rules={[{ required: true }]}>
+              <Input placeholder="如 v1.0.0" />
+            </Form.Item>
+            <Form.Item label="插入变量">
+              <Space>
+                {VARIABLES.map((v) => (
+                  <Button key={v} size="small" onClick={() => insertVariable(v)}>{v}</Button>
+                ))}
+              </Space>
+            </Form.Item>
+            <Form.Item name="content" label="模板内容" rules={[{ required: true }]}>
+              <Input.TextArea rows={10} placeholder="输入模板内容，可使用变量" />
+            </Form.Item>
+            <Button type="primary" htmlType="submit" loading={saving}>保存</Button>
+          </Form>
+        </ProCard>
+
+        <ProCard title="预览" style={{ flex: 1 }}>
+          <Typography.Paragraph>
+            <pre style={{ whiteSpace: 'pre-wrap', background: '#f5f5f5', padding: 16, borderRadius: 8 }}>
+              {content || '（输入内容后此处显示预览）'}
+            </pre>
+          </Typography.Paragraph>
+        </ProCard>
+      </div>
+    </PageContainer>
+  );
+};
+
+export default UnionTemplateEditor;
