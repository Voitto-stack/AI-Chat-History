@@ -0,0 +1,79 @@
+import Router from '@koa/router';
+import { unionBatchJobListQuerySchema } from '@sitin/minerva-schemas';
+import { prisma } from '../../utils/prisma.js';
+import { success } from '../../utils/response.js';
+import { AppError } from '../../utils/AppError.js';
+import { authMiddleware, requirePermission } from '../../middlewares/auth.js';
+
+export const batchJobsRouter = new Router();
+
+batchJobsRouter.use(authMiddleware);
+
+/**
+ * GET /api/union/batch-jobs
+ * List batch jobs (paginated, filterable)
+ */
+batchJobsRouter.get('/', requirePermission('union.user.read'), async (ctx) => {
+  const query = unionBatchJobListQuerySchema.parse(ctx.query);
+  const { page, pageSize, status, action } = query;
+
+  const where: Record<string, any> = {};
+  if (status) where.status = status;
+  if (action) where.action = action;
+
+  const [items, total] = await Promise.all([
+    prisma.unionBatchJob.findMany({
+      where,
+      orderBy: { createdAt: 'desc' },
+      skip: (page - 1) * pageSize,
+      take: pageSize,
+    }),
+    prisma.unionBatchJob.count({ where }),
+  ]);
+
+  success(ctx, { items, total, page, pageSize });
+});
+
+/**
+ * GET /api/union/batch-jobs/:id
+ * Get batch job detail (for polling progress)
+ */
+batchJobsRouter.get('/:id', requirePermission('union.user.read'), async (ctx) => {
+  const job = await prisma.unionBatchJob.findUnique({ where: { id: ctx.params.id } });
+  if (!job) throw AppError.notFound('Batch job not found');
+
+  // Enrich results with phone numbers from UnionUser
+  const userIds = (job.userIds as string[]) || [];
+  if (userIds.length > 0) {
+    const users = await prisma.unionUser.findMany({
+      where: { id: { in: userIds } },
+      select: { id: true, phone: true },
+    });
+    const phoneMap = new Map(users.map((u) => [u.id, u.phone]));
+    if (Array.isArray(job.results)) {
+      (job as any).results = (job.results as any[]).map((r: any) => ({
+        ...r,
+        phone: phoneMap.get(r.userId) || '-',
+      }));
+    }
+  }
+
+  success(ctx, job);
+});
+
+/**
+ * POST /api/union/batch-jobs/:id/cancel
+ * Cancel a running batch job
+ */
+batchJobsRouter.post('/:id/cancel', requirePermission('union.user.write'), async (ctx) => {
+  const job = await prisma.unionBatchJob.findUnique({ where: { id: ctx.params.id } });
+  if (!job) throw AppError.notFound('Batch job not found');
+  if (job.status !== 'pending' && job.status !== 'processing') {
+    throw AppError.badRequest(`Cannot cancel job in ${job.status} status`);
+  }
+  const updated = await prisma.unionBatchJob.update({
+    where: { id: ctx.params.id },
+    data: { status: 'cancelled', completedAt: new Date() },
+  });
+  success(ctx, updated);
+});
