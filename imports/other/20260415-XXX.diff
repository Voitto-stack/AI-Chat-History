+import { PageContainer, ProTable } from '@ant-design/pro-components';
+import type { ProColumns, ActionType } from '@ant-design/pro-components';
+import { useAccess, history } from '@umijs/max';
+import { Button, Modal, Form, Input, Select, Switch, message, Tag, QRCode, Typography, Space } from 'antd';
+import { PlusOutlined, QrcodeOutlined } from '@ant-design/icons';
+import { useRequest } from 'ahooks';
+import React, { useRef, useState, useEffect, useCallback } from 'react';
+import { listUnionDevices, registerUnionDevice, controlUnionDevice, generateDeviceQrToken, deleteUnionDevice } from '@/api/union';
+
+type DeviceItem = {
+  id: string;
+  deviceId: string;
+  phoneNumber: string;
+  status: string;
+  dailyLimit: number;
+  todaySentCount: number;
+  assignedUsersCount: number;
+  lastHeartbeatAt: string;
+};
+
+const statusEnum: Record<string, { text: string; status: string }> = {
+  online: { text: '在线', status: 'Success' },
+  offline: { text: '离线', status: 'Error' },
+};
+
+const UnionDeviceList: React.FC = () => {
+  const access = useAccess();
+  const actionRef = useRef<ActionType>(null);
+  const [modalOpen, setModalOpen] = useState(false);
+  const [qrModalOpen, setQrModalOpen] = useState(false);
+  const [qrData, setQrData] = useState<{ token: string; wsUrl: string; expiresAt: string } | null>(null);
+  const [countdown, setCountdown] = useState(0);
+  const [form] = Form.useForm();
+
+  const { run: doRegister, loading: registering } = useRequest(
+    (values: any) => registerUnionDevice(values),
+    {
+      manual: true,
+      onSuccess: () => {
+        message.success('设备注册成功');
+        setModalOpen(false);
+        form.resetFields();
+        actionRef.current?.reload();
+      },
+    },
+  );
+
+  const { run: fetchQrToken, loading: qrLoading } = useRequest(generateDeviceQrToken, {
+    manual: true,
+    onSuccess: (data) => {
+      setQrData(data);
+      setCountdown(300);
+    },
+    onError: () => {
+      message.error('生成二维码失败');
+    },
+  });
+
+  // Countdown timer
+  useEffect(() => {
+    if (!qrModalOpen || countdown <= 0) return;
+    const timer = setInterval(() => {
+      setCountdown((prev) => {
+        if (prev <= 1) {
+          // Auto refresh token
+          fetchQrToken();
+          return 0;
+        }
+        return prev - 1;
+      });
+    }, 1000);
+    return () => clearInterval(timer);
+  }, [qrModalOpen, countdown]);
+
+  const handleOpenQrModal = useCallback(() => {
+    setQrModalOpen(true);
+    fetchQrToken();
+  }, []);
+
+  const handleCloseQrModal = useCallback(() => {
+    setQrModalOpen(false);
+    setQrData(null);
+    setCountdown(0);
+    actionRef.current?.reload();
+  }, []);
+
+  const columns: ProColumns<DeviceItem>[] = [
+    {
+      title: '设备ID',
+      dataIndex: 'deviceId',
+      copyable: true,
+      render: (_, record) => (
+        <a onClick={() => history.push(`/union/devices/${record.id}`)}>{record.deviceId}</a>
+      ),
+    },
+    { title: '手机号', dataIndex: 'phoneNumber' },
+    { title: '状态', dataIndex: 'status', valueType: 'select', valueEnum: statusEnum },
+    { title: '日限额', dataIndex: 'dailyLimit', hideInSearch: true },
+    { title: '今日已发', dataIndex: 'todaySentCount', hideInSearch: true },
+    { title: '分配用户数', dataIndex: 'assignedUsersCount', hideInSearch: true },
+    { title: '最后心跳', dataIndex: 'lastHeartbeatAt', valueType: 'dateTime', hideInSearch: true },
+    {
+      title: '操作',
+      valueType: 'option',
+      render: (_, record) => [
+        record.status === 'online' && (
+          <a key="offline" onClick={() => controlUnionDevice(record.id, { action: 'disable' }).then(() => actionRef.current?.reload())}>
+            下线
+          </a>
+        ),
+        record.status === 'offline' && (
+          <a key="online" onClick={() => controlUnionDevice(record.id, { action: 'enable' }).then(() => actionRef.current?.reload())}>
+            上线
+          </a>
+        ),
+        <a
+          key="delete"
+          style={{ color: '#ff4d4f' }}
+          onClick={() => {
+            const hasUsers = record.assignedUsersCount > 0;
+            Modal.confirm({
+              title: '确认删除设备',
+              content: hasUsers
+                ? `该设备仍有 ${record.assignedUsersCount} 个分配用户，删除后将自动解绑这些用户。确定继续？`
+                : `确定要删除设备 ${record.deviceId} 吗？此操作不可撤销。`,
+              okText: '删除',
+              okButtonProps: { danger: true },
+              onOk: () => deleteUnionDevice(record.id, hasUsers).then(() => {
+                message.success('设备已删除');
+                actionRef.current?.reload();
+              }),
+            });
+          }}
+        >
+          删除
+        </a>,
+      ],
+    },
+  ];
+
+  return (
+    <PageContainer content="管理设备注册与在线状态，监控心跳、发送配额和用户分配情况。">
+      <ProTable<DeviceItem>
+        headerTitle="设备列表"
+        actionRef={actionRef}
+        rowKey="id"
+        columns={columns}
+        request={(async (params: any) => {
+          const res = await listUnionDevices({
+            page: params.current,
+            pageSize: params.pageSize,
+            status: params.status,
+          });
+          return { data: res.items, total: res.total, success: true };
+        }) as any}
+        toolBarRender={() => [
+          <Button key="qr" icon={<QrcodeOutlined />} onClick={handleOpenQrModal}>
+            扫码注册
+          </Button>,
+          <Button key="register" type="primary" icon={<PlusOutlined />} onClick={() => setModalOpen(true)}>
+            注册设备
+          </Button>,
+        ]}
+        search={{ labelWidth: 'auto' }}
+      />
+      <Modal
+        title="注册设备"
+        open={modalOpen}
+        onCancel={() => setModalOpen(false)}
+        onOk={() => form.validateFields().then(doRegister)}
+        confirmLoading={registering}
+      >
+        <Form form={form} layout="vertical">
+          <Form.Item name="deviceId" label="设备ID" rules={[{ required: true }]}>
+            <Input />
+          </Form.Item>
+          <Form.Item name="phoneNumber" label="手机号" rules={[{ required: true }]}>
+            <Input />
+          </Form.Item>
+          <Form.Item name="dailyLimit" label="日限额" initialValue={100}>
+            <Input type="number" />
+          </Form.Item>
+        </Form>
+      </Modal>
+      <Modal
+        title="扫码注册设备"
+        open={qrModalOpen}
+        onCancel={handleCloseQrModal}
+        footer={null}
+        width={520}
+      >
+        <div style={{ textAlign: 'center', padding: '24px 0' }}>
+          {qrData ? (
+            <Space direction="vertical" size="large" align="center" style={{ width: '100%' }}>
+              <QRCode
+                value={JSON.stringify({ token: qrData.token, wsUrl: qrData.wsUrl })}
+                size={240}
+                status={countdown <= 0 ? 'expired' : 'active'}
+                onRefresh={fetchQrToken}
+              />
+              <Typography.Text type="secondary">
+                {countdown > 0
+                  ? `二维码有效期：${Math.floor(countdown / 60)}:${String(countdown % 60).padStart(2, '0')}`
+                  : '二维码已过期，正在刷新...'}
+              </Typography.Text>
+              <Typography.Text type="secondary" style={{ fontSize: 12 }}>
+                请使用设备扫描二维码完成注册
+              </Typography.Text>
+              <div style={{ width: '100%', textAlign: 'left' }}>
+                <Typography.Text type="secondary" style={{ fontSize: 12, display: 'block', marginBottom: 4 }}>
+                  模拟器命令（复制后在终端运行）：
+                </Typography.Text>
+                <Typography.Paragraph
+                  copyable
+                  code
+                  style={{ fontSize: 11, wordBreak: 'break-all', margin: 0 }}
+                >
+                  {`node scripts/device-sim.js "${qrData.wsUrl}?token=${qrData.token}"`}
+                </Typography.Paragraph>
+              </div>
+            </Space>
+          ) : (
+            <Typography.Text>正在生成二维码...</Typography.Text>
+          )}
+        </div>
+      </Modal>
+    </PageContainer>
+  );
+};
+
+export default UnionDeviceList;
