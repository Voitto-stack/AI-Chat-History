+import Router from '@koa/router';
+import { updateUnionGlobalConfigRequestSchema } from '@sitin/minerva-schemas';
+import { prisma } from '../../utils/prisma.js';
+import { success } from '../../utils/response.js';
+import { authMiddleware, requirePermission } from '../../middlewares/auth.js';
+
+export const globalConfigRouter = new Router();
+
+globalConfigRouter.use(authMiddleware);
+
+/** GET / — List all global configs */
+globalConfigRouter.get('/', requirePermission('union.system.config'), async (ctx) => {
+  const items = await prisma.unionGlobalConfig.findMany({
+    orderBy: { key: 'asc' },
+  });
+  success(ctx, items);
+});
+
+/** PUT /:key — Upsert a config value */
+globalConfigRouter.put('/:key', requirePermission('union.system.config'), async (ctx) => {
+  const { key } = ctx.params;
+  const { value } = updateUnionGlobalConfigRequestSchema.parse(ctx.request.body);
+
+  const item = await prisma.unionGlobalConfig.upsert({
+    where: { key },
+    update: { value },
+    create: { key, value },
+  });
+
+  success(ctx, item);
+});
