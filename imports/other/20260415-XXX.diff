+import { PageContainer, ProTable } from '@ant-design/pro-components';
+import type { ProColumns, ActionType } from '@ant-design/pro-components';
+import { useAccess } from '@umijs/max';
+import { useRequest } from 'ahooks';
+import { Button, Modal, Form, Input, Select, message, Tag } from 'antd';
+import { PlusOutlined } from '@ant-design/icons';
+import React, { useRef, useState } from 'react';
+import { listUnionExperiments, createUnionExperiment } from '@/api/union';
+import { unionPhaseOptions } from '@sitin/minerva-schemas';
+
+type ExperimentItem = {
+  id: string;
+  name: string;
+  phase: string;
+  scene: string;
+  status: string;
+  variants: any[];
+  createdAt: string;
+};
+
+const statusColor: Record<string, string> = {
+  draft: 'default',
+  running: 'processing',
+  completed: 'success',
+  stopped: 'warning',
+};
+
+const columns: ProColumns<ExperimentItem>[] = [
+  { title: '实验名称', dataIndex: 'name' },
+  { title: '阶段', dataIndex: 'phase' },
+  { title: '场景', dataIndex: 'scene' },
+  {
+    title: '状态',
+    dataIndex: 'status',
+    render: (_, r) => <Tag color={statusColor[r.status]}>{r.status}</Tag>,
+  },
+  {
+    title: '变体数',
+    dataIndex: 'variants',
+    render: (_, r) => r.variants?.length ?? 0,
+    hideInSearch: true,
+  },
+  { title: '创建时间', dataIndex: 'createdAt', valueType: 'dateTime', hideInSearch: true },
+  {
+    title: '操作',
+    valueType: 'option',
+    render: (_, record) => [
+      record.status === 'draft' && <a key="start">启动</a>,
+      record.status === 'running' && <a key="stop">停止</a>,
+    ],
+  },
+];
+
+const UnionExperiments: React.FC = () => {
+  const access = useAccess();
+  const actionRef = useRef<ActionType>(null);
+  const [modalOpen, setModalOpen] = useState(false);
+  const [form] = Form.useForm();
+
+  const { data: list, loading, refresh } = useRequest(() => listUnionExperiments() as any);
+
+  const { run: doCreate, loading: creating } = useRequest(
+    (values: any) => createUnionExperiment(values),
+    {
+      manual: true,
+      onSuccess: () => {
+        message.success('实验创建成功');
+        setModalOpen(false);
+        form.resetFields();
+        refresh();
+      },
+    },
+  );
+
+  return (
+    <PageContainer content="创建和管理话术 A/B 测试实验，对比不同变体的转化效果。">
+      <ProTable<ExperimentItem>
+        headerTitle="AB 实验管理"
+        actionRef={actionRef}
+        rowKey="id"
+        columns={columns}
+        dataSource={list as any ?? []}
+        loading={loading}
+        search={false}
+        toolBarRender={() => [
+          <Button key="create" type="primary" icon={<PlusOutlined />} onClick={() => setModalOpen(true)}>
+            创建实验
+          </Button>,
+        ]}
+      />
+      <Modal
+        title="创建实验"
+        open={modalOpen}
+        onCancel={() => setModalOpen(false)}
+        onOk={() => form.validateFields().then(doCreate)}
+        confirmLoading={creating}
+      >
+        <Form form={form} layout="vertical">
+          <Form.Item name="name" label="实验名称" rules={[{ required: true }]}>
+            <Input />
+          </Form.Item>
+          <Form.Item name="phase" label="阶段" rules={[{ required: true }]}>
+            <Select options={unionPhaseOptions} />
+          </Form.Item>
+          <Form.Item name="scene" label="场景" rules={[{ required: true }]}>
+            <Input />
+          </Form.Item>
+        </Form>
+      </Modal>
+    </PageContainer>
+  );
+};
+
+export default UnionExperiments;
