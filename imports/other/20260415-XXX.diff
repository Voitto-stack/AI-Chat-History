+
+const { Dragger } = Upload;
+
+type ParsedRow = { phone: string; source?: string; sourceDetail?: Record<string, any> };
+
+/** platform 字段映射到 UnionUserSource 枚举 */
+const PLATFORM_SOURCE_MAP: Record<string, string> = {
+  fb: 'facebook',
+  facebook: 'facebook',
+  ig: 'facebook',
+  instagram: 'facebook',
+  tiktok: 'tiktok',
+  tt: 'tiktok',
+};
+
+/**
+ * 智能解析 CSV / TSV 文件内容
+ * - 自动检测分隔符（tab / comma）
+ * - 按表头字段名映射，兼容 FB 留资表单和原有 phone,source 格式
+ * - phone_number 字段自动去除 p: 前缀
+ */
+function parseSmartCSV(text: string): ParsedRow[] {
+  const lines = text.trim().split(/\r?\n/).filter(Boolean);
+  if (lines.length < 2) return [];
+
+  const headerLine = lines[0];
+  // 自动检测分隔符
+  const sep = headerLine.includes('\t') ? '\t' : ',';
+  const headers = headerLine.split(sep).map((h) => h.trim().toLowerCase().replace(/^"|"$/g, ''));
+
+  const phoneIdx = headers.indexOf('phone_number') !== -1
+    ? headers.indexOf('phone_number')
+    : headers.indexOf('phone');
+  if (phoneIdx === -1) return [];
+
+  const platformIdx = headers.indexOf('platform');
+  const sourceIdx = headers.indexOf('source');
+  const nameIdx = headers.indexOf('full_name');
+  const timeIdx = headers.indexOf('created_time');
+
+  const rows: ParsedRow[] = [];
+  for (let i = 1; i < lines.length; i++) {
+    const cols = lines[i].split(sep).map((c) => c.trim().replace(/^"|"$/g, ''));
+    let phone = cols[phoneIdx] ?? '';
+    // 去除 FB 导出的 p: 前缀
+    if (phone.startsWith('p:')) phone = phone.slice(2);
+    phone = phone.trim();
+    if (!phone) continue;
+
+    // 来源：优先 platform 列，其次 source 列
+    const platformRaw = platformIdx !== -1 ? cols[platformIdx]?.toLowerCase() : undefined;
+    const source = platformRaw
+      ? PLATFORM_SOURCE_MAP[platformRaw] || 'other'
+      : sourceIdx !== -1
+        ? cols[sourceIdx] || undefined
+        : undefined;
+
+    // 额外信息存入 sourceDetail
+    const sourceDetail: Record<string, any> = {};
+    if (nameIdx !== -1 && cols[nameIdx]) sourceDetail.fullName = cols[nameIdx];
+    if (timeIdx !== -1 && cols[timeIdx]) sourceDetail.leadTime = cols[timeIdx];
+    if (platformRaw) sourceDetail.platform = platformRaw;
+
+    rows.push({
+      phone,
+      source,
