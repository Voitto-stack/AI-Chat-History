@@ -0,0 +1,68 @@
+import Router from '@koa/router';
+import { prisma } from '../../utils/prisma.js';
+import { success } from '../../utils/response.js';
+import { authMiddleware, requirePermission } from '../../middlewares/auth.js';
+
+export const gatewayTraceRouter = new Router();
+gatewayTraceRouter.use(authMiddleware);
+
+/** GET /user/:userId — 获取用户所有对话的链路追踪 */
+gatewayTraceRouter.get(
+  '/user/:userId',
+  requirePermission('union.device.read'),
+  async (ctx) => {
+    const { userId } = ctx.params;
+
+    const conversations = await prisma.unionConversation.findMany({
+      where: { userId },
+      orderBy: { createdAt: 'desc' },
+      take: 50,
+      include: {
+        traces: { orderBy: { createdAt: 'asc' } },
+      },
+    });
+
+    success(
+      ctx,
+      conversations.map((c) => ({
+        conversationId: c.id,
+        direction: c.direction,
+        content: c.content,
+        sendStatus: c.sendStatus,
+        createdAt: c.createdAt.toISOString(),
+        traces: c.traces.map((t) => ({
+          id: t.id,
+          stage: t.stage,
+          status: t.status,
+          latencyMs: t.latencyMs,
+          metadata: t.metadata,
+          createdAt: t.createdAt.toISOString(),
+        })),
+      })),
+    );
+  },
+);
+
+/** GET /conversation/:conversationId — 获取单条对话的链路追踪 */
+gatewayTraceRouter.get(
+  '/conversation/:conversationId',
+  requirePermission('union.device.read'),
+  async (ctx) => {
+    const traces = await prisma.unionMessageTrace.findMany({
+      where: { conversationId: ctx.params.conversationId },
+      orderBy: { createdAt: 'asc' },
+    });
+
+    success(
+      ctx,
+      traces.map((t) => ({
+        id: t.id,
+        stage: t.stage,
+        status: t.status,
+        latencyMs: t.latencyMs,
+        metadata: t.metadata,
+        createdAt: t.createdAt.toISOString(),
+      })),
+    );
+  },
+);
