@@ -0,0 +1,144 @@
+import { PageContainer, ProCard } from '@ant-design/pro-components';
+import { useAccess } from '@umijs/max';
+import { useRequest } from 'ahooks';
+import { DatePicker, Select, Space, Spin, Typography } from 'antd';
+import {
+  ImportOutlined,
+  SendOutlined,
+  MessageOutlined,
+  HeartOutlined,
+  CheckCircleOutlined,
+} from '@ant-design/icons';
+import dayjs from 'dayjs';
+import React, { useState } from 'react';
+import { getUnionFunnel } from '@/api/union';
+import { GradientStatCard } from '@/components/GradientStatCard';
+import type { StatCardItem } from '@/components/GradientStatCard';
+
+const defaultRange: [string, string] = [
+  dayjs().subtract(7, 'day').format('YYYY-MM-DD'),
+  dayjs().format('YYYY-MM-DD'),
+];
+
+const sourceOptions = [
+  { label: '全部', value: '' },
+  { label: 'TikTok', value: 'tiktok' },
+  { label: 'Facebook', value: 'facebook' },
+  { label: 'Manual', value: 'manual' },
+  { label: 'Other', value: 'other' },
+];
+
+const stageLabels: Record<string, string> = {
+  imported: '导入',
+  reached: '触达',
+  replied: '回复',
+  engaged: '互动',
+  converted: '转化',
+};
+
+const STAGE_STYLES: Record<string, { icon: React.ReactNode; color: string; bg: string }> = {
+  imported: {
+    icon: <ImportOutlined />,
+    color: '#1890ff',
+    bg: 'linear-gradient(135deg, #e6f4ff 0%, #bae0ff 100%)',
+  },
+  reached: {
+    icon: <SendOutlined />,
+    color: '#722ed1',
+    bg: 'linear-gradient(135deg, #f9f0ff 0%, #efdbff 100%)',
+  },
+  replied: {
+    icon: <MessageOutlined />,
+    color: '#13c2c2',
+    bg: 'linear-gradient(135deg, #e6fffb 0%, #b5f5ec 100%)',
+  },
+  engaged: {
+    icon: <HeartOutlined />,
+    color: '#fa8c16',
+    bg: 'linear-gradient(135deg, #fff7e6 0%, #ffe7ba 100%)',
+  },
+  converted: {
+    icon: <CheckCircleOutlined />,
+    color: '#52c41a',
+    bg: 'linear-gradient(135deg, #f6ffed 0%, #d9f7be 100%)',
+  },
+};
+
+const UnionFunnel: React.FC = () => {
+  const access = useAccess();
+  const [dateRange, setDateRange] = useState<[string, string]>(defaultRange);
+  const [source, setSource] = useState<string | undefined>('');
+
+  const { data, loading } = useRequest(
+    () =>
+      getUnionFunnel({
+        startDate: dateRange?.[0],
+        endDate: dateRange?.[1],
+        source: (source || undefined) as any,
+      }),
+    { refreshDeps: [dateRange, source] },
+  );
+
+  const steps = (data?.stages ?? []) as any[];
+
+  return (
+    <PageContainer title="转化漏斗" content="查看用户从导入到转化的各阶段转化率，识别流失环节，优化运营策略。">
+      <ProCard style={{ marginBottom: 16 }}>
+        <Space size="middle">
+          <DatePicker.RangePicker
+            defaultValue={[dayjs().subtract(7, 'day'), dayjs()]}
+            onChange={(_, dateStrings) =>
+              setDateRange(dateStrings as [string, string])
+            }
+          />
+          <Select
+            style={{ width: 140 }}
+            value={source}
+            onChange={setSource}
+            options={sourceOptions}
+            placeholder="来源筛选"
+          />
+        </Space>
+      </ProCard>
+
+      <Spin spinning={loading}>
+        <div style={{ display: 'flex', gap: 12 }}>
+          {steps.map((step, idx) => {
+            const style = STAGE_STYLES[step.stage] ?? STAGE_STYLES.imported;
+            const card: StatCardItem = {
+              title: stageLabels[step.stage] ?? step.stage,
+              value: step.count,
+              icon: style.icon,
+              color: style.color,
+              bg: style.bg,
+              sub: idx > 0
+                ? { label: '转化率', value: `${(step.rate * 100).toFixed(1)}%` }
+                : { label: '基准', value: '—' },
+            };
+            return (
+              <div key={step.stage} style={{ flex: 1, display: 'flex', alignItems: 'stretch' }}>
+                <div style={{ width: '100%' }}>
+                  <GradientStatCard card={card} />
+                </div>
+                {idx < steps.length - 1 && (
+                  <div style={{ display: 'flex', alignItems: 'center', padding: '0 2px', color: '#d9d9d9', fontSize: 20 }}>
+                    ›
+                  </div>
+                )}
+              </div>
+            );
+          })}
+          {steps.length === 0 && !loading && (
+            <ProCard style={{ textAlign: 'center', padding: 60, flex: 1 }}>
+              <Typography.Text type="secondary">
+                选择日期范围查看漏斗数据
+              </Typography.Text>
+            </ProCard>
+          )}
+        </div>
+      </Spin>
+    </PageContainer>
+  );
+};
+
+export default UnionFunnel;
diff --git a/apps/minerva/src/pages/Union/BatchJobs/index.tsx b/apps/minerva/src/pages/Union/BatchJobs/index.tsx
