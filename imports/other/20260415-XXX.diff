+      bg: 'linear-gradient(135deg, #f9f0ff 0%, #efdbff 100%)',
+    },
+  ];
+
+  return (
+    <PageContainer content="配置和管理 AI 模型，设置优先级与启停状态，监控调用量与性能指标。">
+      <GradientStatRow cards={aiStatCards} colSpan={6} style={{ marginBottom: 16 }} />
+
+      {stats?.modelStats && stats.modelStats.length > 0 && (
+        <ProTable
+          headerTitle="各模型调用统计"
+          rowKey="model"
+          columns={[
+            { title: '模型', dataIndex: 'model' },
+            { title: '总调用', dataIndex: 'total', sorter: (a: any, b: any) => a.total - b.total },
+            { title: '成功', dataIndex: 'success', render: (v: any) => <Tag color="green">{v}</Tag> },
+            { title: '失败', dataIndex: 'failed', render: (v: any) => <Tag color={v > 0 ? 'red' : 'default'}>{v}</Tag> },
+            { title: '成功率', dataIndex: 'successRate', render: (v: any) => `${v}%` },
+            { title: '平均延迟', dataIndex: 'avgLatencyMs', render: (v: any) => v ? `${v}ms` : '-' },
+          ]}
+          dataSource={stats.modelStats}
+          search={false}
+          pagination={false}
+          size="small"
+          style={{ marginBottom: 16 }}
+        />
+      )}
+
+      <ProTable<ModelItem>
+        headerTitle="模型配置"
+        actionRef={actionRef}
+        rowKey="id"
+        columns={columns}
+        dataSource={list ?? [] as any}
