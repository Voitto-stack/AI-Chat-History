+import { PageContainer, ProCard } from '@ant-design/pro-components';
+import { useAccess } from '@umijs/max';
+import { useRequest } from 'ahooks';
+import { Form, Select, Slider, Input, Button, Descriptions, Spin, InputNumber, Alert } from 'antd';
+import { PlayCircleOutlined } from '@ant-design/icons';
+import React from 'react';
+import { runPlayground, listUnionModelConfigs } from '@/api/union';
+import { unionPhaseOptions } from '@sitin/minerva-schemas';
+
+const preStyle: React.CSSProperties = {
+  margin: 0,
+  whiteSpace: 'pre-wrap',
+  fontSize: 12,
+  maxHeight: 400,
+  overflowY: 'auto',
+};
+
+const UnionPlayground: React.FC = () => {
+  const access = useAccess();
+  const [form] = Form.useForm();
+
+  const { data: models } = useRequest(() => listUnionModelConfigs());
+
+  const { data: result, run: doRun, loading } = useRequest(
+    (values: any) => runPlayground(values),
+    { manual: true },
+  );
+
+  return (
+    <PageContainer
+      title="AI Playground"
+      content="选择模型、阶段和场景，输入用户消息后点击 Run，系统将自动组装多层 Prompt 并调用 AI 模型，返回结构化决策和调试信息。用于测试和迭代 Union AI 话术策略。"
+    >
+      <div style={{ display: 'flex', gap: 16 }}>
+        <ProCard title="配置" style={{ width: 280 }}>
+          <Form form={form} layout="vertical" onFinish={doRun}>
+            <Form.Item name="modelConfigId" label="模型" rules={[{ required: true }]}>
+              <Select
+                placeholder="选择模型"
+                options={(models ?? []).map((m: any) => ({
+                  label: m.displayName,
+                  value: m.id,
+                }))}
+              />
+            </Form.Item>
+            <Form.Item name="temperature" label="Temperature" initialValue={0.7}>
+              <Slider min={0} max={2} step={0.1} />
+            </Form.Item>
+            <Form.Item name="maxTokens" label="Max Tokens" initialValue={1024}>
+              <InputNumber min={1} max={4096} style={{ width: '100%' }} />
+            </Form.Item>
+            <Form.Item name="phase" label="阶段">
+              <Select placeholder="选择阶段" allowClear options={unionPhaseOptions} />
+            </Form.Item>
+            <Form.Item name="scene" label="场景">
+              <Input placeholder="场景标识" />
+            </Form.Item>
+          </Form>
+        </ProCard>
+
+        <div style={{ flex: 1, display: 'flex', flexDirection: 'column', gap: 16 }}>
+          <ProCard title="Prompt">
+            <Form.Item name="userMessage" noStyle>
+              <Input.TextArea
+                rows={10}
+                placeholder="输入用户消息..."
+                style={{ fontFamily: 'monospace' }}
+                onChange={(e) => form.setFieldValue('userMessage', e.target.value)}
+              />
+            </Form.Item>
+            <Button
+              type="primary"
+              icon={<PlayCircleOutlined />}
+              loading={loading}
+              onClick={() => form.validateFields().then(doRun)}
+              style={{ marginTop: 12 }}
+              block
+            >
+              Run
+            </Button>
+          </ProCard>
+
+          <ProCard title="结果">
+            <Spin spinning={loading}>
+              {result ? (
+                <div style={{ display: 'flex', flexDirection: 'column', gap: 12 }}>
+                  {result.error && (
+                    <Alert type="error" message="AI 调用失败" description={result.error} showIcon />
+                  )}
+                  <Descriptions column={2} size="small" bordered>
+                    {result.decision && (
+                      <Descriptions.Item label="Decision" span={2}>
+                        <pre style={preStyle}>
+                          {JSON.stringify(result.decision, null, 2)}
+                        </pre>
+                      </Descriptions.Item>
+                    )}
+                    <Descriptions.Item label="Model">{result?.debug?.modelUsed ?? '-'}</Descriptions.Item>
+                    <Descriptions.Item label="Latency">{result?.debug?.latencyMs ?? '-'}ms</Descriptions.Item>
+                    <Descriptions.Item label="Token Usage" span={2}>{JSON.stringify(result?.debug?.tokenUsage)}</Descriptions.Item>
+                    <Descriptions.Item label="发送给大模型的 Messages" span={2}>
+                      <pre style={preStyle}>
+                        {JSON.stringify(result?.debug?.messages, null, 2) ?? '-'}
+                      </pre>
+                    </Descriptions.Item>
+                    <Descriptions.Item label="Assembled Prompt (system)" span={2}>
+                      <pre style={preStyle}>
+                        {result?.debug?.assembledPrompt ?? '-'}
+                      </pre>
+                    </Descriptions.Item>
+                    {result?.debug?.rawOutput && (
+                      <Descriptions.Item label="Raw Output" span={2}>
+                        <pre style={preStyle}>
+                          {result.debug.rawOutput}
+                        </pre>
+                      </Descriptions.Item>
+                    )}
+                  </Descriptions>
+                </div>
+              ) : (
+                <div style={{ color: '#999', textAlign: 'center', padding: 40 }}>
+                  点击 Run 查看结果
+                </div>
+              )}
+            </Spin>
+          </ProCard>
+        </div>
+      </div>
+    </PageContainer>
+  );
+};
+
+export default UnionPlayground;
