+            jobId && (
+              <Button key="job" onClick={() => history.push('/union/batch-jobs')}>
+                查看任务进度
+              </Button>
+            ),
+            <Button key="again" onClick={() => { setImportResult(null); setRows([]); setFilename(''); setAutoStart(false); setUseSchedule(false); setScheduledAt(null); }}>
+              继续导入
+            </Button>,
+          ].filter(Boolean)}
+        />
+        {jobMsg && <Alert message={jobMsg} type="success" showIcon style={{ marginBottom: 16 }} />}
+        {errors && errors.length > 0 && (
+          <Table
+            rowKey={(_, i) => String(i)}
+            dataSource={errors}
+            pagination={{ pageSize: 20 }}
+            size="small"
+            style={{ marginTop: 16 }}
+            columns={[
+              { title: '行号', dataIndex: 'row', width: 80, render: (v: number) => v || '-' },
+              { title: '手机号', dataIndex: 'phone', width: 180 },
+              { title: '失败原因', dataIndex: 'reason', render: (v: string) => reasonMap[v] || v },
+            ]}
+          />
+        )}
+      </PageContainer>
