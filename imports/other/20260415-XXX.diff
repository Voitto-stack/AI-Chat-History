diff --git a/apps/minerva-server/src/routes/union/ai-model-config.ts b/apps/minerva-server/src/routes/union/ai-model-config.ts
new file mode 100644
index 00000000..1e1b116d
--- /dev/null
+++ b/apps/minerva-server/src/routes/union/ai-model-config.ts
@@ -0,0 +1,121 @@
+import Router from '@koa/router';
+import {
+  createUnionModelConfigRequestSchema,
+  updateUnionModelConfigRequestSchema,
+} from '@sitin/minerva-schemas';
+import { prisma } from '../../utils/prisma.js';
+import { success } from '../../utils/response.js';
+import { AppError } from '../../utils/AppError.js';
+import { authMiddleware, requirePermission } from '../../middlewares/auth.js';
+
+export const aiModelConfigRouter = new Router();
+
+aiModelConfigRouter.use(authMiddleware);
+
+/**
+ * GET /api/union/ai-model-config
+ * List model configs
+ */
+aiModelConfigRouter.get('/', requirePermission('union.brain.config'), async (ctx) => {
+  const configs = await prisma.unionModelConfig.findMany({
+    orderBy: { priority: 'desc' },
+  });
+
+  // Mask API keys in response
+  const result = configs.map((c) => ({
+    ...c,
+    apiKey: c.apiKey.slice(0, 8) + '****',
+  }));
+
+  success(ctx, result);
+});
+
+/**
+ * POST /api/union/ai-model-config
+ * Create model config
+ */
+aiModelConfigRouter.post('/', requirePermission('union.brain.config'), async (ctx) => {
+  const body = createUnionModelConfigRequestSchema.parse(ctx.request.body);
+
+  const existing = await prisma.unionModelConfig.findUnique({
+    where: { displayName: body.displayName },
+  });
+
+  if (existing) {
+    throw AppError.conflict('Model config with this display name already exists');
+  }
+
+  const config = await prisma.unionModelConfig.create({
+    data: {
+      displayName: body.displayName,
+      modelName: body.modelName,
+      provider: body.provider,
+      priority: body.priority,
+      apiKey: body.apiKey,
+      endpoint: body.endpoint,
+      params: {
+        maxTokens: body.maxTokens,
+        temperature: body.temperature,
+        timeoutMs: body.timeoutMs,
+      },
+    },
+  });
+
+  success(ctx, { ...config, apiKey: config.apiKey.slice(0, 8) + '****' }, 201);
+});
+
+/**
+ * PATCH /api/union/ai-model-config/:id
+ * Update model config
+ */
+aiModelConfigRouter.patch('/:id', requirePermission('union.brain.config'), async (ctx) => {
+  const { id } = ctx.params;
+  const body = updateUnionModelConfigRequestSchema.parse(ctx.request.body);
+
+  const existing = await prisma.unionModelConfig.findUnique({ where: { id } });
+  if (!existing) {
+    throw AppError.notFound('Model config not found');
+  }
+
+  const updateData: any = {};
+  if (body.displayName !== undefined) updateData.displayName = body.displayName;
+  if (body.priority !== undefined) updateData.priority = body.priority;
+  if (body.apiKey !== undefined && !body.apiKey.includes('****')) updateData.apiKey = body.apiKey;
+  if (body.endpoint !== undefined) updateData.endpoint = body.endpoint;
+  if (body.enabled !== undefined) updateData.enabled = body.enabled;
+
+  // Merge params fields
+  if (body.maxTokens !== undefined || body.temperature !== undefined || body.timeoutMs !== undefined) {
+    const existingParams = (existing.params as any) ?? {};
+    updateData.params = {
+      ...existingParams,
+      ...(body.maxTokens !== undefined ? { maxTokens: body.maxTokens } : {}),
+      ...(body.temperature !== undefined ? { temperature: body.temperature } : {}),
+      ...(body.timeoutMs !== undefined ? { timeoutMs: body.timeoutMs } : {}),
+    };
+  }
+
+  const config = await prisma.unionModelConfig.update({
+    where: { id },
+    data: updateData,
+  });
+
+  success(ctx, { ...config, apiKey: config.apiKey.slice(0, 8) + '****' });
+});
+
+/**
+ * DELETE /api/union/ai-model-config/:id
+ * Delete model config
+ */
+aiModelConfigRouter.delete('/:id', requirePermission('union.brain.config'), async (ctx) => {
+  const { id } = ctx.params;
+
+  const existing = await prisma.unionModelConfig.findUnique({ where: { id } });
+  if (!existing) {
+    throw AppError.notFound('Model config not found');
+  }
+
+  await prisma.unionModelConfig.delete({ where: { id } });
+
+  success(ctx, { message: 'Model config deleted successfully' });
+});
diff --git a/apps/minerva-server/src/routes/union/ai-playground.ts b/apps/minerva-server/src/routes/union/ai-playground.ts
new file mode 100644
index 00000000..7b8171ed
--- /dev/null
+++ b/apps/minerva-server/src/routes/union/ai-playground.ts
@@ -0,0 +1,164 @@
+import Router from '@koa/router';
+import { unionPlaygroundRequestSchema } from '@sitin/minerva-schemas';
+import { prisma } from '../../utils/prisma.js';
+import { success } from '../../utils/response.js';
+import { AppError } from '../../utils/AppError.js';
+import { authMiddleware, requirePermission } from '../../middlewares/auth.js';
+import { aiStats } from '../../services/union/ai-stats.js';
+
+export const aiPlaygroundRouter = new Router();
+
+aiPlaygroundRouter.use(authMiddleware);
+
+/**
+ * POST /api/union/ai-playground/run
+ * Playground test with overrides and debug info
+ */
+aiPlaygroundRouter.post('/run', requirePermission('union.brain.playground'), async (ctx) => {
+  const body = unionPlaygroundRequestSchema.parse(ctx.request.body);
+
+  // 1. Resolve model config
+  let modelConfig;
+  if (body.modelConfigId) {
+    modelConfig = await prisma.unionModelConfig.findFirst({
+      where: { id: body.modelConfigId, enabled: true },
+    });
+    if (!modelConfig) {
+      throw AppError.notFound(`Model config "${body.modelConfigId}" not found or disabled`);
+    }
+  } else {
+    modelConfig = await prisma.unionModelConfig.findFirst({
+      where: { enabled: true },
+      orderBy: { priority: 'desc' },
+    });
+    if (!modelConfig) {
+      throw AppError.badRequest('No enabled AI model config found');
+    }
+  }
+
+  // 2. Assemble prompt (or use override)
+  let assembledPrompt: string;
+
+  if (body.promptOverride) {
+    assembledPrompt = body.promptOverride;
+  } else {
+    const layerOrder = ['base_persona', 'phase_strategy', 'scene_script', 'user_context'];
+    const layers: string[] = [];
+
+    for (const layer of layerOrder) {
+      const prompt = await prisma.unionPromptVersion.findFirst({
+        where: {
+          layer,
+          status: 'active',
+          ...(layer === 'phase_strategy' || layer === 'scene_script'
+            ? { phase: (body.phase as any) ?? null }
+            : {}),
+          ...(layer === 'scene_script' ? { scene: body.scene ?? null } : {}),
+        },
+        orderBy: { version: 'desc' },
+      });
+      if (prompt) layers.push(prompt.content);
+    }
+
+    assembledPrompt = layers.join('\n\n');
+  }
+
+  // 3. If userId provided, inject user context
+  if (body.userId) {
+    const user = await prisma.unionUser.findUnique({
+      where: { id: body.userId },
+    });
+    if (user) {
+      assembledPrompt += `\n\n[User Context]\nPhase: ${user.phase}\nPhone: ${user.phone}`;
+    }
+  }
+
+  // 4. Build messages array for AI call
+  const messages = [
+    { role: 'system', content: assembledPrompt },
+    ...(body.userMessage
+      ? [{ role: 'user', content: body.userMessage }]
+      : []),
+  ];
+
+  // 5. Call AI model
+  const startTime = Date.now();
+  let rawOutput = '';
+  let promptTokens = 0;
+  let outputTokens = 0;
+  let aiError: string | undefined;
+
+  try {
+    const response = await fetch(`${modelConfig.endpoint}/v1/chat/completions`, {
+      method: 'POST',
+      headers: {
+        'Content-Type': 'application/json',
+        Authorization: `Bearer ${modelConfig.apiKey}`,
+      },
+      body: JSON.stringify({
+        model: modelConfig.modelName,
+        messages,
+        max_tokens: body.maxTokens ?? (modelConfig.params as any)?.maxTokens ?? 4096,
+        temperature: body.temperature ?? (modelConfig.params as any)?.temperature ?? 0.7,
+      }),
+    });
+
+    const result = await response.json() as any;
+
+    if (!response.ok || result.error) {
+      const errMsg = result.error?.message ?? JSON.stringify(result.error) ?? `HTTP ${response.status}`;
+      aiStats.track('playground', modelConfig.modelName, false, Date.now() - startTime);
+      aiError = `AI API error: ${errMsg}`;
+    } else {
+      rawOutput = result.choices?.[0]?.message?.content ?? '';
+      promptTokens = result.usage?.prompt_tokens ?? 0;
+      outputTokens = result.usage?.completion_tokens ?? 0;
+    }
+  } catch (err: any) {
+    aiStats.track('playground', modelConfig.modelName, false, Date.now() - startTime);
+    aiError = `AI inference failed: ${err.message}`;
+  }
+
+  const latencyMs = Date.now() - startTime;
+  if (!aiError) {
+    aiStats.track('playground', modelConfig.modelName, true, latencyMs);
+  }
+
+  // 6. Parse structured decision
+  let decision: any = undefined;
+
+  if (!aiError && rawOutput) {
+    decision = {
+      action: 'send_now',
+      replyText: rawOutput,
+      confidence: 0.5,
+      reasoning: undefined as string | undefined,
+    };
+
+    try {
+      const parsed = JSON.parse(rawOutput);
+      const texts = parsed.reply_texts ?? (parsed.reply_text ? [parsed.reply_text] : null);
+      decision = {
+        action: parsed.action ?? decision.action,
+        replyText: texts ? texts.join('\n') : decision.replyText,
+        confidence: parsed.confidence ?? decision.confidence,
+        reasoning: parsed.reasoning ?? undefined,
+      };
+    } catch {
+      // Raw output is not JSON, use as-is
+    }
+  }
+
+  success(ctx, {
+    decision,
+    ...(aiError ? { error: aiError } : {}),
+    debug: {
+      assembledPrompt,
+      messages,
+      modelUsed: modelConfig.modelName,
+      tokenUsage: { input: promptTokens, output: outputTokens },
+      latencyMs,
+      rawOutput,
+    },
+  });
+});
diff --git a/apps/minerva-server/src/routes/union/ai-prompt.ts b/apps/minerva-server/src/routes/union/ai-prompt.ts
new file mode 100644
index 00000000..511352d3
--- /dev/null
+++ b/apps/minerva-server/src/routes/union/ai-prompt.ts
@@ -0,0 +1,157 @@
+import Router from '@koa/router';
+import {
+  createUnionPromptRequestSchema,
+  updateUnionPromptRequestSchema,
+  unionPromptListQuerySchema,
+} from '@sitin/minerva-schemas';
+import { prisma } from '../../utils/prisma.js';
+import { success } from '../../utils/response.js';
+import { AppError } from '../../utils/AppError.js';
+import { authMiddleware, requirePermission } from '../../middlewares/auth.js';
+
+export const aiPromptRouter = new Router();
+
+aiPromptRouter.use(authMiddleware);
+
+/**
+ * GET /api/union/ai-prompt
+ * List prompt versions with optional filters
+ */
+aiPromptRouter.get('/', requirePermission('union.brain.config'), async (ctx) => {
+  const query = unionPromptListQuerySchema.parse(ctx.query);
+
+  const where: any = {};
+  if (query.layer) where.layer = query.layer;
+  if (query.phase) where.phase = query.phase;
+  if (query.status) where.status = query.status;
+
+  const items = await prisma.unionPromptVersion.findMany({
+    where,
+    orderBy: [{ layer: 'asc' }, { version: 'desc' }],
+  });
+
+  success(ctx, items);
+});
+
+/**
+ * GET /api/union/ai-prompt/:id
+ * Get prompt version detail
+ */
+aiPromptRouter.get('/:id', requirePermission('union.brain.config'), async (ctx) => {
+  const { id } = ctx.params;
+
+  const prompt = await prisma.unionPromptVersion.findUnique({
+    where: { id },
+  });
+
+  if (!prompt) {
+    throw AppError.notFound('Prompt version not found');
+  }
+
+  success(ctx, prompt);
+});
+
+/**
+ * POST /api/union/ai-prompt
+ * Create new prompt version
+ */
+aiPromptRouter.post('/', requirePermission('union.brain.config'), async (ctx) => {
+  const body = createUnionPromptRequestSchema.parse(ctx.request.body);
+
+  // Determine next version number for this layer+phase+scene combo
+  const latest = await prisma.unionPromptVersion.findFirst({
+    where: {
+      layer: body.layer,
+      phase: body.phase ?? null,
+      scene: body.scene ?? null,
+    },
+    orderBy: { version: 'desc' },
+  });
+
+  const nextVersion = (latest?.version ?? 0) + 1;
+
+  const prompt = await prisma.unionPromptVersion.create({
+    data: {
+      layer: body.layer,
+      phase: body.phase ?? null,
+      scene: body.scene ?? null,
+      content: body.content,
+      version: nextVersion,
+      status: 'draft',
+      creatorId: (ctx.state.user as any)?.id ?? null,
+    },
+  });
+
+  success(ctx, prompt, 201);
+});
+
+/**
+ * PATCH /api/union/ai-prompt/:id
+ * Update prompt content (creates new version)
+ */
+aiPromptRouter.patch('/:id', requirePermission('union.brain.config'), async (ctx) => {
+  const { id } = ctx.params;
+  const body = updateUnionPromptRequestSchema.parse(ctx.request.body);
+
+  const existing = await prisma.unionPromptVersion.findUnique({
+    where: { id },
+  });
+
+  if (!existing) {
+    throw AppError.notFound('Prompt version not found');
+  }
+
+  // Create a new version based on the existing one
+  const nextVersion = existing.version + 1;
+
+  const newPrompt = await prisma.unionPromptVersion.create({
+    data: {
+      layer: existing.layer,
+      phase: existing.phase,
+      scene: existing.scene,
+      content: body.content,
+      version: nextVersion,
+      status: 'draft',
+      creatorId: (ctx.state.user as any)?.id ?? null,
+    },
+  });
+
+  success(ctx, newPrompt);
+});
+
+/**
+ * POST /api/union/ai-prompt/resolve
+ * Resolve assembled prompt for given phase + scene (merges 4 layers)
+ */
+aiPromptRouter.post('/resolve', requirePermission('union.brain.config'), async (ctx) => {
+  const { phase, scene } = ctx.request.body as { phase?: string; scene?: string };
+
+  const layerOrder = ['base_persona', 'phase_strategy', 'scene_script', 'user_context'];
+
+  const layers: Record<string, string> = {};
+
+  for (const layer of layerOrder) {
+    const prompt = await prisma.unionPromptVersion.findFirst({
+      where: {
+        layer,
+        status: 'active',
+        ...(layer === 'phase_strategy' || layer === 'scene_script'
+          ? { phase: (phase as any) ?? undefined }
+          : {}),
+        ...(layer === 'scene_script' ? { scene: scene ?? null } : {}),
+      },
+      orderBy: { version: 'desc' },
+    });
+
+    if (prompt) {
+      layers[layer] = prompt.content;
+    }
+  }
+
+  const assembled = layerOrder
+    .map((l) => layers[l])
+    .filter(Boolean)
+    .join('\n\n');
+
+  success(ctx, { layers, assembled });
+});
