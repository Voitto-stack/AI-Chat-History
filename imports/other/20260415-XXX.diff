@@ -0,0 +1,80 @@
+/**
+ * Union Scheduler — Union 模块专属定时任务
+ *
+ * 在 Union 路由初始化时启动，不侵入主入口 index.ts
+ */
+import { prisma } from '../../utils/prisma.js';
+import { launchBatchJob } from './batch-job-processor.js';
+
+let _started = false;
+
+/**
+ * 启动所有 Union 定时任务（幂等，重复调用不会重复注册）
+ */
+export function startUnionScheduler() {
+  if (_started) return;
+  _started = true;
+
+  scheduleDailySentCountReset();
+  scheduleCheckPendingBatchJobs();
+}
+
+/**
+ * 每日午夜 UTC 重置所有设备的 todaySentCount
+ */
+function scheduleDailySentCountReset() {
+  const reset = async () => {
+    try {
+      const { count } = await prisma.unionDevice.updateMany({
+        data: { todaySentCount: 0 },
+      });
+      console.log(`[Union Scheduler] Reset todaySentCount for ${count} devices`);
+    } catch (err) {
+      console.error('[Union Scheduler] Failed to reset todaySentCount:', err);
+    }
+  };
+
+  const now = new Date();
+  const nextMidnight = new Date(
+    Date.UTC(now.getUTCFullYear(), now.getUTCMonth(), now.getUTCDate() + 1)
+  );
+  const msUntilMidnight = nextMidnight.getTime() - now.getTime();
+
+  setTimeout(() => {
+    reset();
+    setInterval(reset, 24 * 60 * 60 * 1000);
+  }, msUntilMidnight);
+
+  console.log(
+    `[Union Scheduler] Daily reset scheduled in ${Math.round(msUntilMidnight / 60000)} min`
+  );
+}
+
+/**
+ * 每 30 秒检查是否有到期的定时批量任务
+ */
+function scheduleCheckPendingBatchJobs() {
+  const INTERVAL = 30_000;
+
+  const check = async () => {
+    try {
+      const dueJobs = await prisma.unionBatchJob.findMany({
+        where: {
+          status: 'pending',
+          scheduledAt: { lte: new Date() },
+        },
+        select: { id: true },
+        take: 10,
+      });
+      for (const job of dueJobs) {
+        console.log(`[Union Scheduler] Launching scheduled batch job ${job.id}`);
+        launchBatchJob(job.id);
+      }
+    } catch (err) {
+      console.error('[Union Scheduler] Failed to check pending batch jobs:', err);
+    }
+  };
+
+  setInterval(check, INTERVAL);
+  console.log('[Union Scheduler] Batch job scheduler started (30s interval)');
+}
