@@ -0,0 +1,89 @@
+import Router from '@koa/router';
+import {
+  messageTemplateListQuerySchema,
+  createMessageTemplateRequestSchema,
+  updateMessageTemplateRequestSchema,
+} from '@sitin/minerva-schemas';
+import { prisma } from '../../utils/prisma.js';
+import { success } from '../../utils/response.js';
+import { AppError } from '../../utils/AppError.js';
+import { authMiddleware, requirePermission } from '../../middlewares/auth.js';
+
+export const messageTemplatesRouter = new Router();
+
+messageTemplatesRouter.use(authMiddleware);
+
+/**
+ * GET / — 分页列表，支持按 category / isActive 筛选
+ */
+messageTemplatesRouter.get('/', requirePermission('union.template.read'), async (ctx) => {
+  const query = messageTemplateListQuerySchema.parse(ctx.query);
+  const { page, pageSize, category, isActive } = query;
+
+  const where: Record<string, unknown> = {};
+  if (category) where.category = category;
+  if (isActive !== undefined) where.isActive = isActive;
+
+  const [items, total] = await Promise.all([
+    prisma.unionMessageTemplate.findMany({
+      where,
+      orderBy: { createdAt: 'desc' },
+      skip: (page - 1) * pageSize,
+      take: pageSize,
+    }),
+    prisma.unionMessageTemplate.count({ where }),
+  ]);
+
+  success(ctx, { items, total, page, pageSize });
+});
+
+/**
+ * GET /:id — 详情
+ */
+messageTemplatesRouter.get('/:id', requirePermission('union.template.read'), async (ctx) => {
+  const tpl = await prisma.unionMessageTemplate.findUnique({ where: { id: ctx.params.id } });
+  if (!tpl) throw AppError.notFound('Message template not found');
+  success(ctx, tpl);
+});
+
+/**
+ * POST / — 新增模板
+ */
+messageTemplatesRouter.post('/', requirePermission('union.template.write'), async (ctx) => {
+  const body = createMessageTemplateRequestSchema.parse(ctx.request.body);
+  const tpl = await prisma.unionMessageTemplate.create({
+    data: {
+      content: body.content,
+      category: body.category,
+      weight: body.weight,
+      creatorId: (ctx.state.user as any)?.userId ?? null,
+    },
+  });
+  success(ctx, tpl, 201);
+});
+
+/**
+ * PATCH /:id — 编辑模板
+ */
+messageTemplatesRouter.patch('/:id', requirePermission('union.template.write'), async (ctx) => {
+  const body = updateMessageTemplateRequestSchema.parse(ctx.request.body);
+  const existing = await prisma.unionMessageTemplate.findUnique({ where: { id: ctx.params.id } });
+  if (!existing) throw AppError.notFound('Message template not found');
+
+  const tpl = await prisma.unionMessageTemplate.update({
+    where: { id: ctx.params.id },
+    data: body,
+  });
+  success(ctx, tpl);
+});
+
+/**
+ * DELETE /:id — 删除模板
+ */
+messageTemplatesRouter.delete('/:id', requirePermission('union.template.write'), async (ctx) => {
+  const existing = await prisma.unionMessageTemplate.findUnique({ where: { id: ctx.params.id } });
+  if (!existing) throw AppError.notFound('Message template not found');
+
+  await prisma.unionMessageTemplate.delete({ where: { id: ctx.params.id } });
+  success(ctx, { deleted: true });
+});
diff --git a/apps/minerva-server/src/routes/union/simulator.ts b/apps/minerva-server/src/routes/union/simulator.ts
