@@ -0,0 +1,56 @@
+/**
+ * Feishu Alert — 关键错误推送到飞书（同类去重）
+ */
+
+const FEISHU_WEBHOOK = process.env.FEISHU_ERROR_WEBHOOK || '';
+const sentErrors = new Map<string, number>();
+const DEDUP_TTL = 3600_000; // 同类错误 1 小时内只发一次
+
+function errorKey(error: Error, context?: string): string {
+  return `${context || ''}:${error.name}:${error.message.slice(0, 120)}`;
+}
+
+export async function alertToFeishu(error: Error, context?: string) {
+  if (!FEISHU_WEBHOOK) return;
+
+  const key = errorKey(error, context);
+  const lastSent = sentErrors.get(key);
+  if (lastSent && Date.now() - lastSent < DEDUP_TTL) return;
+
+  sentErrors.set(key, Date.now());
+
+  // 清理过期缓存
+  if (sentErrors.size > 500) {
+    const now = Date.now();
+    for (const [k, t] of sentErrors) {
+      if (now - t > DEDUP_TTL) sentErrors.delete(k);
+    }
+  }
+
+  const card = {
+    msg_type: 'interactive',
+    card: {
+      header: {
+        title: { tag: 'plain_text', content: '🚨 服务错误告警' },
+        template: 'red',
+      },
+      elements: [
+        { tag: 'div', text: { tag: 'lark_md', content: `**环境**: ${process.env.NODE_ENV || 'unknown'}` } },
+        { tag: 'div', text: { tag: 'lark_md', content: `**接口**: ${context || 'N/A'}` } },
+        { tag: 'div', text: { tag: 'lark_md', content: `**错误**: ${error.name} — ${error.message}` } },
+        { tag: 'div', text: { tag: 'lark_md', content: `**堆栈**:\n\`\`\`\n${(error.stack || '').slice(0, 500)}\n\`\`\`` } },
+        { tag: 'div', text: { tag: 'lark_md', content: `**时间**: ${new Date().toISOString()}` } },
+      ],
+    },
+  };
+
+  try {
+    await fetch(FEISHU_WEBHOOK, {
+      method: 'POST',
+      headers: { 'Content-Type': 'application/json' },
+      body: JSON.stringify(card),
+    });
+  } catch (e) {
+    console.error('[FeishuAlert] send failed:', e);
+  }
+}
