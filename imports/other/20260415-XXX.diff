+
+export const unionUserListResponseSchema = z.object({
+  items: z.array(unionUserSchema),
+  total: z.number(),
+  page: z.number(),
+  pageSize: z.number(),
+});
+export type UnionUserListResponse = z.infer<typeof unionUserListResponseSchema>;
+
+// ── Create ─────────────────────────────────────────────────
+
+export const createUnionUserRequestSchema = z.object({
+  phone: z.string().min(1).max(20),
+  source: unionUserSourceSchema.default('manual'),
+  sourceDetail: z.any().optional(),
+});
+export type CreateUnionUserRequest = z.infer<typeof createUnionUserRequestSchema>;
+
+// ── Import ─────────────────────────────────────────────────
+
+export const unionUserImportRequestSchema = z.object({
+  source: unionUserSourceSchema.default('manual'),
+});
+export type UnionUserImportRequest = z.infer<typeof unionUserImportRequestSchema>;
+
+export const unionUserImportResultSchema = z.object({
+  importId: z.string(),
+  total: z.number(),
+  success: z.number(),
+  failed: z.number(),
+  errors: z.array(z.object({
+    row: z.number(),
+    phone: z.string().optional(),
+    reason: z.string(),
+  })).optional(),
+});
+export type UnionUserImportResult = z.infer<typeof unionUserImportResultSchema>;
+
+// ── Status Change ──────────────────────────────────────────
+
+export const unionUserStatusChangeSchema = z.object({
+  toStatus: unionUserStatusSchema,
+  note: z.string().optional(),
+});
+export type UnionUserStatusChange = z.infer<typeof unionUserStatusChangeSchema>;
+
+// ── Batch Operations ───────────────────────────────────────
+
+export const unionUserBatchActionSchema = z.object({
+  userIds: z.array(z.string()).min(1).max(500),
+  action: z.enum(['assign_device', 'change_status', 'add_tag', 'remove_tag', 'export', 'start_conversation', 'retry_conversation']),
+  params: z.record(z.any()).optional(),
+});
+export type UnionUserBatchAction = z.infer<typeof unionUserBatchActionSchema>;
+
+// ── Tags ───────────────────────────────────────────────────
+
+export const unionUserTagSchema = z.object({
+  id: z.string(),
+  userId: z.string(),
+  tagName: z.string(),
+  tagType: z.string(),
+  createdAt: z.string(),
+});
+export type UnionUserTag = z.infer<typeof unionUserTagSchema>;
+
+export const addUnionUserTagRequestSchema = z.object({
+  tagName: z.string().min(1).max(50),
+  tagType: z.enum(['system', 'manual']).default('manual'),
+});
+export type AddUnionUserTagRequest = z.infer<typeof addUnionUserTagRequestSchema>;
+
+// ── Status Log ─────────────────────────────────────────────
+
+export const unionStatusLogSchema = z.object({
+  id: z.string(),
+  userId: z.string(),
+  fromStatus: unionUserStatusSchema,
+  toStatus: unionUserStatusSchema,
+  trigger: z.string(),
+  operatorId: z.string().nullable(),
+  note: z.string().nullable(),
+  createdAt: z.string(),
+});
+export type UnionStatusLog = z.infer<typeof unionStatusLogSchema>;
