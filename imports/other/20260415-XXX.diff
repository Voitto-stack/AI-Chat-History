@@ -0,0 +1,92 @@
+/**
+ * AI 调用统计 — 数据库持久化
+ *
+ * track() 异步写入 DB（fire-and-forget，不阻塞主流程）
+ * getStats() 从 DB 聚合查询
+ */
+import { prisma } from '../../utils/prisma.js';
+
+export const aiStats = {
+  /** 记录一次调用（异步写 DB，不阻塞调用方） */
+  track(source: string, model: string, ok: boolean, latencyMs: number, error?: string) {
+    prisma.unionAiCallLog
+      .create({
+        data: { source, model, success: ok, latencyMs, error: error ?? null },
+      })
+      .catch((err) => console.error('[aiStats] write failed:', err.message));
+  },
+
+  /** 获取统计数据 */
+  async getStats() {
+    const [agg, byModel, recentCalls] = await Promise.all([
+      prisma.unionAiCallLog.groupBy({
+        by: ['success'],
+        _count: { id: true },
+      }),
+      prisma.unionAiCallLog.groupBy({
+        by: ['model', 'success'],
+        _count: { id: true },
+        _avg: { latencyMs: true },
+      }),
+      prisma.unionAiCallLog.findMany({
+        orderBy: { createdAt: 'desc' },
+        take: 20,
+        select: {
+          source: true,
+          model: true,
+          success: true,
+          latencyMs: true,
+          error: true,
+          createdAt: true,
+        },
+      }),
+    ]);
+
+    let successCount = 0;
+    let failedCount = 0;
+    for (const row of agg) {
+      if (row.success) successCount = row._count.id;
+      else failedCount = row._count.id;
+    }
+    const total = successCount + failedCount;
+
+    // 按模型聚合
+    const modelMap = new Map<string, { total: number; success: number; failed: number; avgLatencyMs: number }>();
+    for (const row of byModel) {
+      const existing = modelMap.get(row.model) || { total: 0, success: 0, failed: 0, avgLatencyMs: 0 };
+      const count = row._count.id;
+      if (row.success) {
+        existing.success += count;
+        existing.avgLatencyMs = Math.round(row._avg.latencyMs ?? 0);
+      } else {
+        existing.failed += count;
+      }
+      existing.total += count;
+      modelMap.set(row.model, existing);
+    }
+    const modelStats = Array.from(modelMap.entries()).map(([model, s]) => ({
+      model,
+      total: s.total,
+      success: s.success,
+      failed: s.failed,
+      successRate: s.total > 0 ? +(s.success / s.total * 100).toFixed(1) : 0,
+      avgLatencyMs: s.avgLatencyMs,
+    }));
+
+    return {
+      total,
+      success: successCount,
+      failed: failedCount,
+      successRate: total > 0 ? +(successCount / total * 100).toFixed(1) : 0,
+      modelStats,
+      recentCalls: recentCalls.map((r) => ({
+        source: r.source,
+        model: r.model,
+        success: r.success,
+        latencyMs: r.latencyMs,
+        error: r.error,
+        timestamp: r.createdAt.getTime(),
+      })),
+    };
+  },
+};
