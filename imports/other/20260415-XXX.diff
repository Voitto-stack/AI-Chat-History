@@ -0,0 +1,89 @@
+import { PrismaClient } from '../src/generated/prisma/index.js';
+
+const prisma = new PrismaClient();
+
+async function main() {
+  console.log('🌱 Seeding Union Prompt versions...');
+
+  // Delete existing prompts to avoid duplicates
+  await prisma.unionPromptVersion.deleteMany({
+    where: {
+      OR: [
+        { layer: 'base_persona', phase: null, scene: null },
+        { layer: 'phase_strategy', phase: 'activation', scene: null },
+        { layer: 'scene_script', phase: 'activation', scene: 'followup' },
+        { layer: 'scene_script', phase: 'activation', scene: 'reply' },
+      ],
+    },
+  });
+
+  // Layer 1: base_persona (全局基础人设)
+  await prisma.unionPromptVersion.create({
+    data: {
+      layer: 'base_persona',
+      content: `You are Freya, a friendly recruiter for GraceChat, a legitimate video-chat platform.
+Your role is to engage potential hosts in natural, helpful conversations.
+Keep messages concise (under 160 characters for SMS).
+Use a warm, professional tone.`,
+      version: 1,
+      status: 'active',
+    },
+  });
+
+  // Layer 2: phase_strategy - activation
+  await prisma.unionPromptVersion.create({
+    data: {
+      layer: 'phase_strategy',
+      phase: 'activation',
+      content: `Goal: Introduce the platform and gauge interest.
+Approach:
+- Lead with the sign-up bonus ($50)
+- Highlight earning potential ($90/hour)
+- Address safety/legitimacy concerns proactively
+- Ask qualifying questions (availability, comfort with video chat)`,
+      version: 1,
+      status: 'active',
+    },
+  });
+
+  // Layer 3: scene_script - activation + followup (初始问候)
+  await prisma.unionPromptVersion.create({
+    data: {
+      layer: 'scene_script',
+      phase: 'activation',
+      scene: 'followup',
+      content: `First message template:
+"Hi! 👋 I'm Freya from GraceChat. We're looking for video chat hosts. Earn $90/hr + $50 sign-up bonus. Interested? 😊"
+
+Keep it short, friendly, and include a clear call-to-action.`,
+      version: 1,
+      status: 'active',
+    },
+  });
+
+  // Layer 3: scene_script - activation + reply (回复话术)
+  await prisma.unionPromptVersion.create({
+    data: {
+      layer: 'scene_script',
+      phase: 'activation',
+      scene: 'reply',
+      content: `Respond naturally to user's message.
+If positive: Share next steps (app download, verification)
+If hesitant: Address concerns (safety, legitimacy, flexibility)
+If negative: Respect their decision, offer to answer questions`,
+      version: 1,
+      status: 'active',
+    },
+  });
+
+  console.log('✅ Seeded 4 prompt versions');
+}
+
+main()
+  .catch((e) => {
+    console.error(e);
+    process.exit(1);
+  })
+  .finally(async () => {
+    await prisma.$disconnect();
+  });
