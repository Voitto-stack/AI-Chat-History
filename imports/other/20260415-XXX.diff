@@ -0,0 +1,105 @@
+import Router from '@koa/router';
+import { prisma } from '../../utils/prisma.js';
+import { success } from '../../utils/response.js';
+import { AppError } from '../../utils/AppError.js';
+import { authMiddleware, requirePermission } from '../../middlewares/auth.js';
+
+export const templatesReviewRouter = new Router();
+
+templatesReviewRouter.use(authMiddleware);
+
+/** POST /:id/submit — draft → reviewing */
+templatesReviewRouter.post(
+  '/:id/submit',
+  requirePermission('union.template.publish'),
+  async (ctx) => {
+    const { id } = ctx.params;
+    const tpl = await prisma.unionTemplate.findUnique({ where: { id } });
+    if (!tpl) throw AppError.notFound('Template not found');
+    if (tpl.status !== 'draft') {
+      throw AppError.badRequest('Only draft templates can be submitted');
+    }
+    const updated = await prisma.unionTemplate.update({
+      where: { id },
+      data: { status: 'reviewing' },
+    });
+    success(ctx, updated);
+  },
+);
+
+/** POST /:id/approve — reviewing → published */
+templatesReviewRouter.post(
+  '/:id/approve',
+  requirePermission('union.template.publish'),
+  async (ctx) => {
+    const { id } = ctx.params;
+    const tpl = await prisma.unionTemplate.findUnique({ where: { id } });
+    if (!tpl) throw AppError.notFound('Template not found');
+    if (tpl.status !== 'reviewing') {
+      throw AppError.badRequest('Only reviewing templates can be approved');
+    }
+    const updated = await prisma.unionTemplate.update({
+      where: { id },
+      data: { status: 'published', publishedAt: new Date(), reviewerId: (ctx.state.user as any)?.userId ?? null },
+    });
+    success(ctx, updated);
+  },
+);
+
+/** POST /:id/reject — reviewing → draft, set reviewNote */
+templatesReviewRouter.post(
+  '/:id/reject',
+  requirePermission('union.template.publish'),
+  async (ctx) => {
+    const { id } = ctx.params;
+    const { note } = (ctx.request.body as { note?: string }) ?? {};
+    const tpl = await prisma.unionTemplate.findUnique({ where: { id } });
+    if (!tpl) throw AppError.notFound('Template not found');
+    if (tpl.status !== 'reviewing') {
+      throw AppError.badRequest('Only reviewing templates can be rejected');
+    }
+    const updated = await prisma.unionTemplate.update({
+      where: { id },
+      data: { status: 'draft', reviewNote: note ?? null, reviewerId: (ctx.state.user as any)?.userId ?? null },
+    });
+    success(ctx, updated);
+  },
+);
+
+/** POST /:id/archive — published → archived */
+templatesReviewRouter.post(
+  '/:id/archive',
+  requirePermission('union.template.publish'),
+  async (ctx) => {
+    const { id } = ctx.params;
+    const tpl = await prisma.unionTemplate.findUnique({ where: { id } });
+    if (!tpl) throw AppError.notFound('Template not found');
+    if (tpl.status !== 'published') {
+      throw AppError.badRequest('Only published templates can be archived');
+    }
+    const updated = await prisma.unionTemplate.update({
+      where: { id },
+      data: { status: 'archived' },
+    });
+    success(ctx, updated);
+  },
+);
+
+/** POST /:id/rollback — archived → draft */
+templatesReviewRouter.post(
+  '/:id/rollback',
+  requirePermission('union.template.publish'),
+  async (ctx) => {
+    const { id } = ctx.params;
+    const tpl = await prisma.unionTemplate.findUnique({ where: { id } });
+    if (!tpl) throw AppError.notFound('Template not found');
+    if (tpl.status !== 'archived') {
+      throw AppError.badRequest('Only archived templates can be rolled back');
+    }
+    const updated = await prisma.unionTemplate.update({
+      where: { id },
+      data: { status: 'draft', reviewNote: null, reviewerId: null, publishedAt: null },
+    });
+    success(ctx, updated);
+  },
+);
diff --git a/apps/minerva-server/src/routes/union/templates.ts b/apps/minerva-server/src/routes/union/templates.ts
new file mode 100644
index 00000000..d32de076
--- /dev/null
+++ b/apps/minerva-server/src/routes/union/templates.ts
@@ -0,0 +1,97 @@
+import Router from '@koa/router';
+import {
+  unionTemplateListQuerySchema,
+  createUnionTemplateRequestSchema,
+  updateUnionTemplateRequestSchema,
+} from '@sitin/minerva-schemas';
+import { prisma } from '../../utils/prisma.js';
+import { success } from '../../utils/response.js';
+import { AppError } from '../../utils/AppError.js';
+import { authMiddleware, requirePermission } from '../../middlewares/auth.js';
+
+export const templatesRouter = new Router();
+
+templatesRouter.use(authMiddleware);
+
+/**
+ * GET / — List templates with pagination, filter by phase, scene, status
+ */
+templatesRouter.get('/', requirePermission('union.template.read'), async (ctx) => {
+  const query = unionTemplateListQuerySchema.parse(ctx.query);
+  const { page, pageSize, phase, scene, status } = query;
+
+  const where: Record<string, unknown> = {};
+  if (phase) where.phase = phase;
+  if (scene) where.scene = scene;
+  if (status) where.status = status;
+
+  const [items, total] = await Promise.all([
+    prisma.unionTemplate.findMany({
+      where,
+      orderBy: { createdAt: 'desc' },
+      skip: (page - 1) * pageSize,
+      take: pageSize,
+    }),
+    prisma.unionTemplate.count({ where }),
+  ]);
+
+  success(ctx, { items, total, page, pageSize });
+});
+
+/**
+ * GET /:id — Get template detail
+ */
+templatesRouter.get('/:id', requirePermission('union.template.read'), async (ctx) => {
+  const { id } = ctx.params;
+
+  const template = await prisma.unionTemplate.findUnique({ where: { id } });
+  if (!template) {
+    throw AppError.notFound('Template not found');
+  }
+
+  success(ctx, template);
+});
+
+/**
+ * POST / — Create template
+ */
+templatesRouter.post('/', requirePermission('union.template.write'), async (ctx) => {
+  const body = createUnionTemplateRequestSchema.parse(ctx.request.body);
+
+  const template = await prisma.unionTemplate.create({
+    data: {
+      phase: body.phase,
+      scene: body.scene,
+      versionCode: body.versionCode,
+      content: body.content,
+      variables: body.variables ?? null,
+      dialogueTree: body.dialogueTree ?? null,
+      creatorId: (ctx.state.user as any)?.userId ?? null,
+    },
+  });
+
+  success(ctx, template, 201);
+});
+
+/**
+ * PATCH /:id — Update template (only if draft)
+ */
+templatesRouter.patch('/:id', requirePermission('union.template.write'), async (ctx) => {
+  const { id } = ctx.params;
+  const body = updateUnionTemplateRequestSchema.parse(ctx.request.body);
+
+  const existing = await prisma.unionTemplate.findUnique({ where: { id } });
+  if (!existing) {
+    throw AppError.notFound('Template not found');
+  }
+  if (existing.status !== 'draft') {
+    throw AppError.badRequest('Only draft templates can be updated');
+  }
+
+  const template = await prisma.unionTemplate.update({
+    where: { id },
+    data: body,
+  });
+
+  success(ctx, template);
+});
diff --git a/apps/minerva-server/src/routes/union/users-import.ts b/apps/minerva-server/src/routes/union/users-import.ts
new file mode 100644
index 00000000..7460fa9f
--- /dev/null
+++ b/apps/minerva-server/src/routes/union/users-import.ts
@@ -0,0 +1,206 @@
+import Router from '@koa/router';
+import crypto from 'crypto';
+import { unionUserSourceSchema } from '@sitin/minerva-schemas';
+import { z } from 'zod';
+import { prisma } from '../../utils/prisma.js';
+import { success } from '../../utils/response.js';
+import { AppError } from '../../utils/AppError.js';
+import { authMiddleware, requirePermission } from '../../middlewares/auth.js';
+import { launchBatchJob } from '../../services/union/batch-job-processor.js';
+
+export const usersImportRouter = new Router();
+
+usersImportRouter.use(authMiddleware);
+
+// E.164 phone format: + followed by 1-15 digits
+const E164_REGEX = /^\+[1-9]\d{1,14}$/;
+
+/**
+ * Normalize phone to E.164 format.
+ * Handles: "(857) 226-1938" → "+18572261938", "2156948533" → "+12156948533"
+ */
+function normalizePhone(raw: string): string {
+  // Strip all non-digit and non-plus characters
+  let digits = raw.replace(/[^\d+]/g, '');
+
+  // If already starts with +, return as-is
+  if (digits.startsWith('+')) return digits;
+
+  // Strip leading + if any remain
+  digits = digits.replace(/\+/g, '');
+
+  // 10-digit US number → prepend +1
+  if (digits.length === 10) return `+1${digits}`;
+
+  // 11-digit starting with 1 (US with country code but no +) → prepend +
+  if (digits.length === 11 && digits.startsWith('1')) return `+${digits}`;
+
+  // Otherwise prepend + and hope for the best
+  return `+${digits}`;
+}
+
+const csvImportBodySchema = z.object({
+  filename: z.string().optional(),
+  source: unionUserSourceSchema.default('manual'),
+  autoStartConversation: z.boolean().default(false),
+  scheduledAt: z.string().optional(),
+  rows: z.array(
+    z.object({
+      phone: z.string(),
+      source: unionUserSourceSchema.optional(),
+      sourceDetail: z.any().optional(),
+    })
+  ),
+});
+
+/**
+ * POST /api/union/users-import/csv
+ * CSV import — parse body as JSON with rows array
+ */
+usersImportRouter.post(
+  '/csv',
+  requirePermission('union.user.import'),
+  async (ctx) => {
+    const body = csvImportBodySchema.parse(ctx.request.body);
+    const operatorId = ctx.state.user.userId;
+
+    const errors: { row: number; phone?: string; reason: string }[] = [];
+    const validRows: { phone: string; source: string; sourceDetail?: any }[] = [];
+
+    // Validate E.164 and deduplicate
+    const seen = new Set<string>();
+    body.rows.forEach((row, idx) => {
+      const phone = normalizePhone(row.phone.trim());
+      if (!E164_REGEX.test(phone)) {
+        errors.push({ row: idx + 1, phone, reason: 'Invalid E.164 format' });
+        return;
+      }
+      if (seen.has(phone)) {
+        errors.push({ row: idx + 1, phone, reason: 'Duplicate in file' });
+        return;
+      }
+      seen.add(phone);
+      validRows.push({
+        phone,
+        source: row.source || body.source,
+        sourceDetail: row.sourceDetail,
+      });
+    });
+
+    // Check existing phones in DB
+    const existingUsers = await prisma.unionUser.findMany({
+      where: { phone: { in: validRows.map((r) => r.phone) } },
+      select: { phone: true },
+    });
+    const existingSet = new Set(existingUsers.map((u) => u.phone));
+
+    const toCreate = validRows.filter((r) => {
+      if (existingSet.has(r.phone)) {
+        errors.push({ row: 0, phone: r.phone, reason: 'Already exists in database' });
+        return false;
+      }
+      return true;
+    });
+
+    // Bulk create
+    const result = await prisma.unionUser.createMany({
+      data: toCreate.map((r) => ({
+        phone: r.phone,
+        source: r.source as any,
+        sourceDetail: r.sourceDetail ?? undefined,
+        refCode: crypto.randomBytes(4).toString('hex'),
+      })),
+      skipDuplicates: true,
+    });
+
+    // Create import log
+    const importLog = await prisma.unionImportLog.create({
+      data: {
+        operatorId,
+        filename: body.filename || 'import.csv',
+        total: body.rows.length,
+        success: result.count,
+        failed: errors.length,
+        errors: errors.length > 0 ? errors : undefined,
+      },
+    });
+
+    // Auto-start conversation if requested
+    let jobId: string | undefined;
+    let jobStatus: string | undefined;
+    if (body.autoStartConversation && toCreate.length > 0) {
+      // Fetch IDs of newly created users by phone
+      const createdUsers = await prisma.unionUser.findMany({
+        where: { phone: { in: toCreate.map((r) => r.phone) } },
+        select: { id: true },
+      });
+      const userIds = createdUsers.map((u) => u.id);
+
+      if (userIds.length > 0) {
+        // Split into chunks of 200 (batch job limit)
+        const chunks: string[][] = [];
+        for (let i = 0; i < userIds.length; i += 200) {
+          chunks.push(userIds.slice(i, i + 200));
+        }
+
+        const scheduledAt = body.scheduledAt ? new Date(body.scheduledAt) : undefined;
+        if (scheduledAt && scheduledAt.getTime() <= Date.now()) {
+          throw AppError.badRequest('定时时间必须是未来时间');
+        }
+
+        // Create batch job(s)
+        for (const chunk of chunks) {
+          const job = await prisma.unionBatchJob.create({
+            data: {
+              action: 'start_conversation',
+              totalCount: chunk.length,
+              userIds: chunk,
+              operatorId,
+              scheduledAt,
+            },
+          });
+          if (!jobId) {
+            jobId = job.id;
+            jobStatus = scheduledAt ? 'scheduled' : 'pending';
+          }
+          if (!scheduledAt) {
+            launchBatchJob(job.id);
+          }
+        }
+      }
+    }
+
+    success(ctx, {
+      importId: importLog.id,
+      total: body.rows.length,
+      success: result.count,
+      failed: errors.length,
+      errors,
+      ...(jobId ? { jobId, jobStatus } : {}),
+    }, 201);
+  }
+);
+
+/**
+ * GET /api/union/users-import/logs
+ * List import history with pagination
+ */
+usersImportRouter.get(
+  '/logs',
+  requirePermission('union.user.read'),
+  async (ctx) => {
+    const page = Math.max(1, Number(ctx.query.page) || 1);
+    const pageSize = Math.min(100, Math.max(1, Number(ctx.query.pageSize) || 20));
+
+    const [items, total] = await Promise.all([
+      prisma.unionImportLog.findMany({
+        orderBy: { createdAt: 'desc' },
+        skip: (page - 1) * pageSize,
+        take: pageSize,
+      }),
+      prisma.unionImportLog.count(),
+    ]);
+
+    success(ctx, { items, total, page, pageSize });
+  }
+);
diff --git a/apps/minerva-server/src/routes/union/users-state.ts b/apps/minerva-server/src/routes/union/users-state.ts
new file mode 100644
index 00000000..9f467b89
--- /dev/null
+++ b/apps/minerva-server/src/routes/union/users-state.ts
@@ -0,0 +1,124 @@
+import Router from '@koa/router';
+import { unionUserStatusChangeSchema } from '@sitin/minerva-schemas';
+import type { UnionUserStatus } from '@sitin/minerva-schemas';
+import { prisma } from '../../utils/prisma.js';
+import { success } from '../../utils/response.js';
+import { AppError } from '../../utils/AppError.js';
+import { authMiddleware, requirePermission } from '../../middlewares/auth.js';
+
+export const usersStateRouter = new Router();
+
+usersStateRouter.use(authMiddleware);
+
+/**
+ * Valid state transitions matrix.
+ * Key = current status, Value = set of allowed target statuses.
+ */
+const STATE_TRANSITIONS: Record<string, Set<string>> = {
+  pending_device: new Set(['pending_contact']),
+  pending_contact: new Set(['in_conversation']),
+  in_conversation: new Set([
+    'paused',
+    'silent',
+    'converted',
+    'opted_out',
+    'dead',
+  ]),
+  paused: new Set(['in_conversation', 'dead']),
+  silent: new Set(['in_conversation', 'dead']),
+};
+
+/**
+ * POST /api/union/users-state/:id/transition
+ * Transition user status (validate against matrix)
+ */
+usersStateRouter.post(
+  '/:id/transition',
+  requirePermission('union.user.write'),
+  async (ctx) => {
+    const { id } = ctx.params;
+    const body = unionUserStatusChangeSchema.parse(ctx.request.body);
+    const operatorId = ctx.state.user.userId;
+
+    const user = await prisma.unionUser.findUnique({
+      where: { id },
+      select: { id: true, status: true },
+    });
+
+    if (!user) {
+      throw AppError.notFound('Union user not found');
+    }
+
+    const fromStatus = user.status;
+    const toStatus = body.toStatus;
+
+    // Validate transition
+    const allowed = STATE_TRANSITIONS[fromStatus];
+    if (!allowed || !allowed.has(toStatus)) {
+      throw AppError.badRequest(
+        `Invalid transition: ${fromStatus} → ${toStatus}`,
+        'INVALID_TRANSITION'
+      );
+    }
+
+    // Update status and write log in a transaction
+    const [updated, log] = await prisma.$transaction([
+      prisma.unionUser.update({
+        where: { id },
+        data: {
+          status: toStatus as any,
+          ...(toStatus === 'converted' ? { convertedAt: new Date() } : {}),
+        },
+      }),
+      prisma.unionStatusLog.create({
+        data: {
+          userId: id,
+          fromStatus: fromStatus as any,
+          toStatus: toStatus as any,
+          trigger: 'manual',
+          operatorId,
+          note: body.note,
+        },
+      }),
+    ]);
+
+    success(ctx, { user: updated, log });
+  }
+);
+
+/**
+ * GET /api/union/users-state/:id/logs
+ * Get status transition history for a user
+ */
+usersStateRouter.get(
+  '/:id/logs',
+  requirePermission('union.user.read'),
+  async (ctx) => {
+    const { id } = ctx.params;
+    const page = Math.max(1, Number(ctx.query.page) || 1);
+    const pageSize = Math.min(100, Math.max(1, Number(ctx.query.pageSize) || 20));
+
+    // Verify user exists
+    const user = await prisma.unionUser.findUnique({
+      where: { id },
+      select: { id: true },
+    });
+    if (!user) {
+      throw AppError.notFound('Union user not found');
+    }
+
+    const where = { userId: id };
+
+    const [items, total] = await Promise.all([
+      prisma.unionStatusLog.findMany({
+        where,
+        orderBy: { createdAt: 'desc' },
+        skip: (page - 1) * pageSize,
+        take: pageSize,
+      }),
+      prisma.unionStatusLog.count({ where }),
+    ]);
+
+    success(ctx, { items, total, page, pageSize });
+  }
+);
