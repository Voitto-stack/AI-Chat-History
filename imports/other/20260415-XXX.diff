new file mode 100644
index 00000000..23a9ea45
--- /dev/null
+++ b/apps/minerva-server/src/routes/union/brain.ts
@@ -0,0 +1,148 @@
+import Router from '@koa/router';
+import { brainProcessRequestSchema } from '@sitin/minerva-schemas';
+import { prisma } from '../../utils/prisma.js';
+import { success } from '../../utils/response.js';
+import { AppError } from '../../utils/AppError.js';
+import { authMiddleware, requirePermission } from '../../middlewares/auth.js';
+import { aiStats } from '../../services/union/ai-stats.js';
+
+export const brainRouter = new Router();
+
+brainRouter.use(authMiddleware);
+
+/**
+ * POST /api/union/brain/process
+ * Brain engine decision entry point
+ */
+brainRouter.post('/process', requirePermission('union.brain.config'), async (ctx) => {
+  const body = brainProcessRequestSchema.parse(ctx.request.body);
+
+  // 1. Load user context
+  const user = await prisma.unionUser.findUnique({
+    where: { id: body.userId },
+  });
+
+  if (!user) {
+    throw AppError.notFound('Union user not found');
+  }
+
+  // 2. Load recent messages
+  const recentMessages = await prisma.unionMessage.findMany({
+    where: { userId: body.userId },
+    orderBy: { createdAt: 'desc' },
+    take: 20,
+  });
+
+  // 3. Load active prompt template (merge 4 layers)
+  const prompts = await prisma.unionPromptVersion.findMany({
+    where: { status: 'active' },
+    orderBy: [{ layer: 'asc' }, { version: 'desc' }],
+  });
+
+  const layerOrder = ['base_persona', 'phase_strategy', 'scene_script', 'user_context'];
+  const assembledPrompt = layerOrder
+    .map((layer) => {
+      const match = prompts.find(
+        (p) =>
+          p.layer === layer &&
+          (p.phase === null || p.phase === user.phase) &&
+          (p.scene === null || p.scene === body.triggerType)
+      );
+      return match?.content ?? '';
+    })
+    .filter(Boolean)
+    .join('\n\n');
+
+  // 4. Select model config
+  const modelConfig = await prisma.unionModelConfig.findFirst({
+    where: { enabled: true },
+    orderBy: { priority: 'desc' },
+  });
+
+  if (!modelConfig) {
+    throw AppError.badRequest('No enabled AI model config found');
+  }
+
+  // 5. Call AI service
+  const startTime = Date.now();
+  let rawOutput: string;
+  let promptTokens = 0;
+  let outputTokens = 0;
+
+  try {
+    const response = await fetch(`${modelConfig.endpoint}/v1/chat/completions`, {
+      method: 'POST',
+      headers: {
+        'Content-Type': 'application/json',
+        Authorization: `Bearer ${modelConfig.apiKey}`,
+      },
+      body: JSON.stringify({
+        model: modelConfig.modelName,
+        messages: [
+          { role: 'system', content: assembledPrompt },
+          ...(body.userMessage
+            ? [{ role: 'user', content: body.userMessage }]
+            : []),
+        ],
+        max_tokens: (modelConfig.params as any)?.maxTokens ?? 4096,
+        temperature: (modelConfig.params as any)?.temperature ?? 0.7,
+      }),
+    });
+
+    const result = await response.json() as any;
+    rawOutput = result.choices?.[0]?.message?.content ?? '';
+    promptTokens = result.usage?.prompt_tokens ?? 0;
+    outputTokens = result.usage?.completion_tokens ?? 0;
+  } catch (err: any) {
+    aiStats.track('brain', modelConfig.modelName, false, Date.now() - startTime);
+    throw new AppError(`AI inference failed: ${err.message}`, 500, 'AI_ERROR');
+  }
+
+  const latencyMs = Date.now() - startTime;
+  aiStats.track('brain', modelConfig.modelName, true, latencyMs);
+
+  // 6. Parse structured decision from raw output
+  let action = 'send_now';
+  let replyText = rawOutput;
+  let confidence = 0.5;
+  let reasoning: string | null = null;
+
+  try {
+    const parsed = JSON.parse(rawOutput);
+    action = parsed.action ?? action;
+    replyText = parsed.replyText ?? replyText;
+    confidence = parsed.confidence ?? confidence;
+    reasoning = parsed.reasoning ?? null;
+  } catch {
+    // If not JSON, treat raw output as replyText
+  }
+
+  // 7. Write decision log
+  const log = await prisma.unionDecisionLog.create({
+    data: {
+      userId: body.userId,
+      triggerType: body.triggerType,
+      modelUsed: modelConfig.modelName,
+      confidence,
+      action: action as any,
+      replyText,
+      reasoning,
+      promptTokens,
+      outputTokens,
+      latencyMs,
+      rawInput: { prompt: assembledPrompt, userMessage: body.userMessage },
+      rawOutput: { text: rawOutput },
+    },
+  });
+
+  success(ctx, {
+    decisionId: log.id,
+    action: log.action,
+    replyText: log.replyText,
+    confidence: log.confidence,
+    reasoning: log.reasoning,
+    modelUsed: log.modelUsed,
+    tokenUsage: { input: promptTokens, output: outputTokens },
+    latencyMs,
+  });
+});
