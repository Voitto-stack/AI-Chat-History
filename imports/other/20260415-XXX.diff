+const { RangePicker } = DatePicker;
+
+const METRIC_LABELS: Record<string, string> = {
+  new_users: '新增用户',
+  contacted: '已触达',
+  replied: '已回复',
+  converted: '已转化',
+};
+
+const METRIC_COLORS: Record<string, string> = {
+  new_users: '#1890ff',
+  contacted: '#722ed1',
+  replied: '#13c2c2',
+  converted: '#52c41a',
+};
+
+const UnionDashboard: React.FC = () => {
+  const access = useAccess();
+  const [dateRange, setDateRange] = useState<[dayjs.Dayjs, dayjs.Dayjs]>([
+    dayjs().subtract(6, 'day'),
+    dayjs(),
+  ]);
+
+  const { data, loading } = useRequest(() => getUnionDashboard());
+  const { data: trendData, loading: trendLoading } = useRequest(
+    () => getUnionTrend({
+      startDate: dateRange[0].format('YYYY-MM-DD'),
+      endDate: dateRange[1].format('YYYY-MM-DD'),
+    }),
+    { refreshDeps: [dateRange] },
+  );
+
+  // 构建趋势表格数据：每天一行，每个指标一列
+  const trendTableData = React.useMemo(() => {
+    if (!trendData?.series?.length) return [];
+    const dateMap = new Map<string, Record<string, number>>();
+    for (const s of trendData.series) {
+      for (const d of s.data) {
+        if (!dateMap.has(d.date)) dateMap.set(d.date, {});
+        dateMap.get(d.date)![s.metric] = d.value;
+      }
+    }
+    return Array.from(dateMap.entries())
+      .map(([date, values]) => ({ date, ...values }))
+      .sort((a, b) => a.date.localeCompare(b.date));
+  }, [trendData]);
+
+  // 各指标最大值，用于 Progress 百分比
+  const maxValues = React.useMemo(() => {
+    const maxes: Record<string, number> = {};
+    for (const s of trendData?.series ?? []) {
+      maxes[s.metric] = Math.max(1, ...s.data.map((d: any) => d.value));
+    }
+    return maxes;
+  }, [trendData]);
+
+  const trendColumns = [
+    {
+      title: '日期',
+      dataIndex: 'date',
+      width: 110,
+      render: (v: string) => dayjs(v).format('MM-DD ddd'),
+    },
+    ...Object.entries(METRIC_LABELS).map(([key, label]) => ({
+      title: label,
+      dataIndex: key,
+      width: 200,
+      render: (v: number) => (
+        <Space>
+          <Progress
+            percent={maxValues[key] ? Math.round((v / maxValues[key]) * 100) : 0}
+            size="small"
+            strokeColor={METRIC_COLORS[key]}
+            showInfo={false}
+            style={{ width: 100 }}
+          />
+          <span>{v ?? 0}</span>
+        </Space>
+      ),
+    })),
+  ];
+
+  const statCards: StatCardItem[] = [
+    {
+      title: '进行中会话',
+      value: data?.today?.activeConversations ?? 0,
+      suffix: '个',
+      icon: <MessageOutlined />,
+      color: '#1890ff',
+      bg: 'linear-gradient(135deg, #e6f4ff 0%, #bae0ff 100%)',
+    },
+    {
+      title: '发出消息',
+      value: data?.today?.outboundMessages ?? 0,
+      suffix: '条',
+      icon: <SendOutlined />,
+      color: '#722ed1',
+      bg: 'linear-gradient(135deg, #f9f0ff 0%, #efdbff 100%)',
+      sub: { label: 'AI 调用', value: data?.today?.aiCalls ?? 0, icon: <RobotOutlined /> },
+    },
+    {
+      title: '收到消息',
+      value: data?.today?.inboundMessages ?? 0,
+      suffix: '条',
+      icon: <MailOutlined />,
+      color: '#13c2c2',
+      bg: 'linear-gradient(135deg, #e6fffb 0%, #b5f5ec 100%)',
+      sub: { label: '回复用户', value: data?.today?.replied ?? 0, icon: <UserSwitchOutlined /> },
+    },
+    {
+      title: '今日触达',
+      value: data?.today?.contacted ?? 0,
+      suffix: '人',
+      icon: <AimOutlined />,
+      color: '#fa8c16',
+      bg: 'linear-gradient(135deg, #fff7e6 0%, #ffe7ba 100%)',
+    },
+    {
+      title: '今日转化',
+      value: data?.today?.converted ?? 0,
+      suffix: '人',
+      icon: <RiseOutlined />,
+      color: '#52c41a',
+      bg: 'linear-gradient(135deg, #f6ffed 0%, #d9f7be 100%)',
+    },
+    {
+      title: '用户总量',
+      value: data?.today?.totalUsers ?? 0,
+      suffix: '人',
+      icon: <TeamOutlined />,
+      color: '#eb2f96',
+      bg: 'linear-gradient(135deg, #fff0f6 0%, #ffd6e7 100%)',
+    },
+  ];
+
+  return (
+    <PageContainer title="Guild Ops 总览" content="Sessions, messages, conversions & more">
+      <Spin spinning={loading}>
+        <GradientStatRow cards={statCards} style={{ marginBottom: 24 }} />
+
+        <ProCard
+          title="数据趋势"
+          extra={
+            <RangePicker
+              value={dateRange}
+              onChange={(dates) => {
+                if (dates?.[0] && dates?.[1]) {
+                  setDateRange([dates[0], dates[1]]);
+                }
+              }}
+              presets={[
+                { label: '最近7天', value: [dayjs().subtract(6, 'day'), dayjs()] },
+                { label: '最近14天', value: [dayjs().subtract(13, 'day'), dayjs()] },
+                { label: '最近30天', value: [dayjs().subtract(29, 'day'), dayjs()] },
+              ]}
+            />
+          }
+        >
+          <Spin spinning={trendLoading}>
+            <Table
+              rowKey="date"
+              dataSource={trendTableData}
+              columns={trendColumns}
+              pagination={false}
+              size="small"
+              locale={{ emptyText: '暂无趋势数据' }}
+            />
+          </Spin>
+        </ProCard>
+      </Spin>
+    </PageContainer>
+  );
+};
+
+export default UnionDashboard;
