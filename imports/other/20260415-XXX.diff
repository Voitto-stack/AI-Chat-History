+import { PageContainer, ProCard } from '@ant-design/pro-components';
+import { useAccess } from '@umijs/max';
+import { useRequest } from 'ahooks';
+import { Spin, DatePicker, Space, Table, Progress } from 'antd';
+import {
+  MessageOutlined,
+  SendOutlined,
+  MailOutlined,
+  AimOutlined,
+  RiseOutlined,
+  TeamOutlined,
+  RobotOutlined,
+  UserSwitchOutlined,
+} from '@ant-design/icons';
+import React, { useState } from 'react';
+import { getUnionDashboard, getUnionTrend } from '@/api/union';
+import { GradientStatRow } from '@/components/GradientStatCard';
+import type { StatCardItem } from '@/components/GradientStatCard';
