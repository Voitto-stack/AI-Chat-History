+          <Table rowKey="phone" dataSource={rows} columns={columns} pagination={{ pageSize: 50 }} />
+          <div style={{ marginTop: 16, display: 'flex', alignItems: 'center', gap: 12, flexWrap: 'wrap' }}>
+            <Switch checked={autoStart} onChange={(v) => { setAutoStart(v); if (!v) { setUseSchedule(false); setScheduledAt(null); } }} size="small" />
+            <span>导入后自动发起对话</span>
+            {autoStart && (
+              <>
+                <Switch checked={useSchedule} onChange={(v) => { setUseSchedule(v); if (!v) setScheduledAt(null); }} size="small" />
