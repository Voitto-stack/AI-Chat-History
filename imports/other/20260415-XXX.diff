+  minInbound: z.coerce.number().int().min(0).optional(),
+  maxInbound: z.coerce.number().int().min(0).optional(),
+  sortBy: z.enum(['createdAt', 'lastContactAt', 'qualityScore']).default('createdAt'),
+  sortOrder: z.enum(['asc', 'desc']).default('desc'),
+});
