+import { PageContainer, ProCard } from '@ant-design/pro-components';
+import { useRequest } from 'ahooks';
+import { Form, Input, Button, message, Descriptions } from 'antd';
+import React from 'react';
+import { listUnionGlobalConfig, updateUnionGlobalConfig } from '@/api/union';
+
+const CONFIG_LABELS: Record<string, string> = {
+  appUrl: '应用下载链接',
+  platformName: '平台名称',
+};
+
+const CONFIG_TIPS: Record<string, string> = {
+  appUrl: 'AI 对话中引导用户下载时使用的链接，会自动拼接用户渠道标识 (?c=xxx)',
+  platformName: 'AI 对话中使用的平台品牌名',
+};
+
+const UnionSettings: React.FC = () => {
+  const [form] = Form.useForm();
+
+  const { loading, refresh } = useRequest(listUnionGlobalConfig, {
+    onSuccess: (data) => {
+      const values: Record<string, string> = {};
+      data.forEach((item) => { values[item.key] = item.value; });
+      form.setFieldsValue(values);
+    },
+  });
+
+  const { run: save, loading: saving } = useRequest(
+    async (values: Record<string, string>) => {
+      await Promise.all(
+        Object.entries(values).map(([key, value]) => updateUnionGlobalConfig(key, value)),
+      );
+    },
+    {
+      manual: true,
+      onSuccess: () => {
+        message.success('配置已保存，立即生效');
+        refresh();
+      },
+    },
+  );
+
+  return (
+    <PageContainer title="全局配置" content="管理系统级配置参数，如应用下载链接、平台名称等全局设置。">
+      <ProCard loading={loading}>
+        <Form form={form} layout="vertical" onFinish={save} style={{ maxWidth: 600 }}>
+          <Form.Item
+            name="appUrl"
+            label={CONFIG_LABELS.appUrl}
+            tooltip={CONFIG_TIPS.appUrl}
+            rules={[{ required: true, message: '请输入下载链接' }]}
+          >
+            <Input placeholder="https://gracechat.com/download" />
+          </Form.Item>
+          <Form.Item
+            name="platformName"
+            label={CONFIG_LABELS.platformName}
+            tooltip={CONFIG_TIPS.platformName}
+            rules={[{ required: true, message: '请输入平台名称' }]}
+          >
+            <Input placeholder="GraceChat" />
+          </Form.Item>
+          <Button type="primary" htmlType="submit" loading={saving}>保存</Button>
+        </Form>
+      </ProCard>
+    </PageContainer>
+  );
+};
+
+export default UnionSettings;
diff --git a/apps/minerva/src/pages/Union/Simulator/index.tsx b/apps/minerva/src/pages/Union/Simulator/index.tsx
new file mode 100644
index 00000000..eab2c275
--- /dev/null
+++ b/apps/minerva/src/pages/Union/Simulator/index.tsx
@@ -0,0 +1,191 @@
+import { PageContainer, ProCard } from '@ant-design/pro-components';
+import { useAccess } from '@umijs/max';
+import { useRequest } from 'ahooks';
+import { Button, Collapse, message, Select, Space, Tag, Typography } from 'antd';
+import React, { useState } from 'react';
+import { CopyOutlined } from '@ant-design/icons';
+import { createSimulatorSession, simulatorSend, simulatorReset, simulatorFastForward, simulatorRegenerate, listUnionModelConfigs } from '@/api/union';
+import ChatPanel from '@/components/ChatPanel';
+import type { ChatMessage } from '@/components/ChatPanel';
+
+const { Text } = Typography;
+
+const quickReplies = [
+  { label: '积极回复', text: 'Sounds great! Tell me more about the app.' },
+  { label: '犹豫', text: "I'm not sure... is it safe?" },
+  { label: '拒绝', text: "No thanks, I'm not interested." },
+  { label: '退订', text: 'STOP' },
+  { label: '沉默', text: '__SILENCE__' },
+];
+
+const Simulator: React.FC = () => {
+  const access = useAccess();
+  const [sessionId, setSessionId] = useState<string>();
+  const [messages, setMessages] = useState<ChatMessage[]>([]);
+  const [input, setInput] = useState('');
+  const [lastDecision, setLastDecision] = useState<any>(null);
+  const [userStatus, setUserStatus] = useState('');
+  const [selectedModel, setSelectedModel] = useState<string | undefined>(() => {
+    return localStorage.getItem('simulator_model_id') || undefined;
+  });
+
+  // 拉取可用模型列表
+  const { data: modelConfigs } = useRequest(() => listUnionModelConfigs(), {
+    onSuccess: (data) => {
+      const enabled = data.filter((m: any) => m.enabled);
+      if (enabled.length > 0 && !selectedModel) {
+        const gemini = enabled.find((m: any) => m.displayName?.toLowerCase().includes('gemini'));
+        const defaultModel = (gemini || enabled[0]).id;
+        setSelectedModel(defaultModel);
+        localStorage.setItem('simulator_model_id', defaultModel);
+      }
+    },
+  });
+
+  const handleModelChange = (value: string) => {
+    setSelectedModel(value);
+    localStorage.setItem('simulator_model_id', value);
+  };
+
+  const { run: createSession, loading: creating } = useRequest(
+    () => createSimulatorSession({
+      phone: `+1555${Date.now().toString().slice(-7)}`,
+      modelConfigId: selectedModel,
+    }),
+    {
+      manual: true,
+      onSuccess: (res) => {
+        setSessionId(res.id);
+        setMessages(res.messages || []);
+        setUserStatus(res.userStatus);
+        setLastDecision(res.initialDecision || null);
+      },
+    },
+  );
+
+  const { run: send, loading: sending } = useRequest(
+    (msg: string) => simulatorSend({ sessionId: sessionId!, message: msg, modelConfigId: selectedModel }),
+    {
+      manual: true,
+      onSuccess: (res) => {
+        const aiMessages: ChatMessage[] = (res.aiResponse.contents || [res.aiResponse.content]).filter(Boolean).map((text: string, i: number) => ({
+          direction: 'outbound',
+          content: text,
+          createdAt: new Date(new Date(res.aiResponse.createdAt).getTime() + i * 100).toISOString(),
+        }));
+        setMessages((prev) => [...prev, ...aiMessages]);
+        setLastDecision(res.aiResponse.decision);
+        setUserStatus(res.newStatus);
+      },
+    },
+  );
+
+  const { run: reset } = useRequest(
+    () => simulatorReset({ sessionId: sessionId! }),
+    { manual: true, onSuccess: () => { setMessages([]); setLastDecision(null); setUserStatus('pending_contact'); } },
+  );
+
+  const { run: fastForward } = useRequest(
+    () => simulatorFastForward({ sessionId: sessionId!, hours: 24 }),
+    { manual: true, onSuccess: (res) => { setMessages(res.messages || []); setUserStatus(res.userStatus); } },
+  );
+
+  const { run: regenerate, loading: regenerating } = useRequest(
+    () => simulatorRegenerate({ sessionId: sessionId!, modelConfigId: selectedModel }),
+    {
+      manual: true,
+      onSuccess: (res) => {
+        // Remove old AI messages after the last user message, then add new ones
+        setMessages((prev) => {
+          const lastInboundIdx = prev.findLastIndex((m) => m.direction === 'inbound');
+          const trimmed = lastInboundIdx >= 0 ? prev.slice(0, lastInboundIdx + 1) : prev;
+          const aiMessages: ChatMessage[] = (res.aiResponse.contents || [res.aiResponse.content]).filter(Boolean).map((text: string, i: number) => ({
+            direction: 'outbound',
+            content: text,
+            createdAt: new Date(Date.now() + i * 100).toISOString(),
+          }));
+          return [...trimmed, ...aiMessages];
+        });
+        setLastDecision(res.aiResponse.decision);
+        message.success('已重新生成');
+      },
+      onError: () => message.error('重新生成失败'),
+    },
+  );
+
+  const handleSend = (text?: string) => {
+    const msg = text || input;
+    if (!msg.trim() || !sessionId) return;
+    setMessages((prev) => [...prev, { direction: 'inbound', content: msg, createdAt: new Date().toISOString() }]);
+    setInput('');
+    send(msg);
+  };
+
+  return (
+    <PageContainer title="对话模拟器" content="模拟用户对话交互，测试 AI 在不同场景下的决策与回复表现。">
+      <Space style={{ marginBottom: 16 }}>
+        <Button type="primary" onClick={createSession} loading={creating}>新建会话</Button>
+        <Button onClick={reset} disabled={!sessionId}>重置</Button>
+        <Button onClick={fastForward} disabled={!sessionId}>快进 24h</Button>
+        <Select
+          style={{ width: 200 }}
+          placeholder="选择模型"
+          value={selectedModel}
+          onChange={handleModelChange}
+          options={(modelConfigs ?? [])
+            .filter((m: any) => m.enabled)
+            .map((m: any) => ({ label: m.displayName, value: m.id }))}
+        />
+        <Text type="secondary" style={{ fontSize: 12 }}>切换后下次发送生效</Text>
+        {userStatus && <Tag>{userStatus}</Tag>}
+      </Space>
+
+      <ProCard title="对话" style={{ minHeight: 500 }}>
+        <ChatPanel
+          messages={messages}
+          sending={sending}
+          regenerating={regenerating}
+          input={input}
+          onInputChange={setInput}
+          onSend={handleSend}
+          onRegenerate={regenerate}
+          disabled={!sessionId}
+          quickReplies={quickReplies}
+        />
+      </ProCard>
+
+      <ProCard title="决策详情" style={{ marginTop: 16 }}>
+            {lastDecision ? (
+              <Collapse defaultActiveKey={['result']} size="small">
+                <Collapse.Panel header="决策结果" key="result" extra={<CopyOutlined onClick={(e) => { e.stopPropagation(); navigator.clipboard.writeText(JSON.stringify({ action: lastDecision.action, confidence: lastDecision.confidence, reasoning: lastDecision.reasoning, modelUsed: lastDecision.modelUsed, tokenUsage: lastDecision.tokenUsage, latencyMs: lastDecision.latencyMs }, null, 2)); message.success('已复制'); }} />}>
+                  <pre style={{ whiteSpace: 'pre-wrap', fontSize: 12, margin: 0 }}>
+                    {JSON.stringify({
+                      action: lastDecision.action,
+                      confidence: lastDecision.confidence,
+                      reasoning: lastDecision.reasoning,
+                      modelUsed: lastDecision.modelUsed,
+                      tokenUsage: lastDecision.tokenUsage,
+                      latencyMs: lastDecision.latencyMs,
+                    }, null, 2)}
+                  </pre>
+                </Collapse.Panel>
+                <Collapse.Panel header="完整 Prompt" key="prompt" extra={<CopyOutlined onClick={(e) => { e.stopPropagation(); navigator.clipboard.writeText(lastDecision.assembledPrompt || ''); message.success('已复制'); }} />}>
+                  <pre style={{ whiteSpace: 'pre-wrap', fontSize: 12, margin: 0, maxHeight: 400, overflow: 'auto' }}>
+                    {lastDecision.assembledPrompt || '无'}
+                  </pre>
+                </Collapse.Panel>
+                <Collapse.Panel header="原始 AI 响应" key="rawOutput" extra={<CopyOutlined onClick={(e) => { e.stopPropagation(); navigator.clipboard.writeText(lastDecision.rawOutput || ''); message.success('已复制'); }} />}>
+                  <pre style={{ whiteSpace: 'pre-wrap', fontSize: 12, margin: 0, maxHeight: 400, overflow: 'auto' }}>
+                    {lastDecision.rawOutput || '无'}
+                  </pre>
+                </Collapse.Panel>
+              </Collapse>
+            ) : (
+              <Text type="secondary">发送消息后查看 AI 决策详情</Text>
+            )}
+          </ProCard>
+    </PageContainer>
+  );
+};
+
+export default Simulator;
