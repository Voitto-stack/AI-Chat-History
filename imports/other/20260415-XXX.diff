+import Router from '@koa/router';
+import { unionDecisionLogListQuerySchema } from '@sitin/minerva-schemas';
+import { prisma } from '../../utils/prisma.js';
+import { success } from '../../utils/response.js';
+import { AppError } from '../../utils/AppError.js';
+import { authMiddleware, requirePermission } from '../../middlewares/auth.js';
+
+export const brainLogRouter = new Router();
+
+brainLogRouter.use(authMiddleware);
+
+/**
+ * GET /api/union/brain-log
+ * List decision logs with pagination and filters
+ */
+brainLogRouter.get('/', requirePermission('union.brain.log'), async (ctx) => {
+  const query = unionDecisionLogListQuerySchema.parse(ctx.query);
+
+  const where: any = {};
+
+  if (query.userId) where.userId = query.userId;
+  if (query.action) where.action = query.action;
+  if (query.modelUsed) where.modelUsed = query.modelUsed;
+
+  if (query.minConfidence !== undefined || query.maxConfidence !== undefined) {
+    where.confidence = {};
+    if (query.minConfidence !== undefined) where.confidence.gte = query.minConfidence;
+    if (query.maxConfidence !== undefined) where.confidence.lte = query.maxConfidence;
+  }
+
+  if (query.startDate || query.endDate) {
+    where.createdAt = {};
+    if (query.startDate) where.createdAt.gte = new Date(query.startDate);
+    if (query.endDate) where.createdAt.lte = new Date(query.endDate);
+  }
+
+  const [items, total] = await Promise.all([
+    prisma.unionDecisionLog.findMany({
+      where,
+      orderBy: { createdAt: 'desc' },
+      skip: (query.page - 1) * query.pageSize,
+      take: query.pageSize,
+    }),
+    prisma.unionDecisionLog.count({ where }),
+  ]);
+
+  success(ctx, { items, total, page: query.page, pageSize: query.pageSize });
+});
+
+/**
+ * GET /api/union/brain-log/:id
+ * Get single decision log detail
+ */
+brainLogRouter.get('/:id', requirePermission('union.brain.log'), async (ctx) => {
+  const { id } = ctx.params;
+
+  const log = await prisma.unionDecisionLog.findUnique({
+    where: { id },
+    include: {
+      user: {
+        select: {
+          id: true,
+          phone: true,
+          phase: true,
+        },
+      },
+    },
+  });
+
+  if (!log) {
+    throw AppError.notFound('Decision log not found');
+  }
+
+  success(ctx, log);
+});
