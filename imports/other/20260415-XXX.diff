--- /dev/null
+++ b/apps/src/utils/feishu-alert.ts
@@ -0,0 +1,46 @@
+/**
+ * Feishu Alert - 关键错误推送到飞书（去重）
+ */
+
+const FEISHU_WEBHOOK = process.env.FEISHU_ERROR_WEBHOOK || '';
+const errorCache = new Set<string>();
+const CACHE_TTL = 3600000; // 1小时后允许重复发送
+
+function getErrorKey(error: Error, context?: string): string {
+  return `${context || 'unknown'}:${error.name}:${error.message.slice(0, 100)}`;
+}
+
+export async function alertToFeishu(error: Error, context?: string) {
+  if (!FEISHU_WEBHOOK) return;
+
+  const key = getErrorKey(error, context);
+  if (errorCache.has(key)) return;
+
+  errorCache.add(key);
+  setTimeout(() => errorCache.delete(key), CACHE_TTL);
+
+  const payload = {
+    msg_type: 'interactive',
+    card: {
+      header: { title: { tag: 'plain_text', content: '🚨 服务错误告警' }, template: 'red' },
+      elements: [
+        { tag: 'div', text: { tag: 'lark_md', content: `**环境**: ${process.env.NODE_ENV || 'unknown'}` } },
+        { tag: 'div', text: { tag: 'lark_md', content: `**上下文**: ${context || 'N/A'}` } },
+        { tag: 'div', text: { tag: 'lark_md', content: `**错误类型**: ${error.name}` } },
+        { tag: 'div', text: { tag: 'lark_md', content: `**错误信息**: ${error.message}` } },
+        { tag: 'div', text: { tag: 'lark_md', content: `**堆栈**: \`\`\`\n${error.stack?.slice(0, 500) || 'N/A'}\n\`\`\`` } },
+        { tag: 'div', text: { tag: 'lark_md', content: `**时间**: ${new Date().toISOString()}` } },
+      ],
+    },
+  };
+
+  try {
+    await fetch(FEISHU_WEBHOOK, {
+      method: 'POST',
+      headers: { 'Content-Type': 'application/json' },
+      body: JSON.stringify(payload),
+    });
+  } catch (err) {
+    console.error('[FeishuAlert] Failed to send alert:', err);
+  }
+}
