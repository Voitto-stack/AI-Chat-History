diff --git a/apps/minerva-server/prisma/query-example.ts b/apps/minerva-server/prisma/query-example.ts
new file mode 100644
index 00000000..091993e5
--- /dev/null
+++ b/apps/minerva-server/prisma/query-example.ts
@@ -0,0 +1,38 @@
+import { PrismaClient } from '../src/generated/prisma';
+
+const prisma = new PrismaClient();
+
+async function main() {
+  const basePersona = await prisma.unionPromptVersion.findFirst({
+    where: { layer: 'base_persona', status: 'active' },
+    orderBy: { version: 'desc' }
+  });
+  
+  const phaseStrategy = await prisma.unionPromptVersion.findFirst({
+    where: { layer: 'phase_strategy', phase: 'activation', status: 'active' },
+    orderBy: { version: 'desc' }
+  });
+  
+  const sceneScript = await prisma.unionPromptVersion.findFirst({
+    where: { layer: 'scene_script', phase: 'activation', status: 'active' },
+    orderBy: { version: 'desc' }
+  });
+  
+  const template = await prisma.unionTemplate.findFirst({
+    where: { phase: 'activation', status: 'published' },
+    orderBy: { publishedAt: 'desc' }
+  });
+  
+  console.log('=== BASE PERSONA ===');
+  console.log(basePersona?.content || 'N/A');
+  console.log('\n=== PHASE STRATEGY (activation) ===');
+  console.log(phaseStrategy?.content || 'N/A');
+  console.log('\n=== SCENE SCRIPT ===');
+  console.log(sceneScript?.content || 'N/A');
+  console.log('\n=== TEMPLATE ===');
+  console.log(template?.content || 'N/A');
+  
+  await prisma.$disconnect();
+}
+
+main();
diff --git a/apps/minerva-server/prisma/schema.prisma b/apps/minerva-server/prisma/schema.prisma
index 32f2af14..e5b3a2be 100644
--- a/apps/minerva-server/prisma/schema.prisma
+++ b/apps/minerva-server/prisma/schema.prisma
@@ -2725,3 +2725,472 @@ enum post_interact_type {
   FEMALE_COMMENT
   NON_BINARY_COMMENT
 }
+
+// ============================================================
+// Union Ops — AI 工会运营系统
+// ============================================================
+
+enum UnionUserStatus {
+  pending_device
+  pending_contact
+  in_conversation
+  paused
+  silent
+  converted
+  opted_out
+  invalid_number
+  rejected
+  dead
+}
+
+enum UnionUserSource {
+  tiktok
+  facebook
+  manual
+  other
+}
+
+enum UnionPhase {
+  activation
+  retention
+  conversion
+  recall
+}
+
+enum UnionMsgDirection {
+  inbound
+  outbound
+}
+
+enum UnionMsgStatus {
+  pending
+  sent
+  delivered
+  failed
+}
+
+enum UnionTemplateStatus {
+  draft
+  reviewing
+  published
+  archived
+}
+
+enum UnionTriggerType {
+  user_reply
+  scheduled_followup
+  manual
+  initial_contact
+}
+
+enum UnionDecisionAction {
+  send_now
+  schedule_followup
+  mark_converted
+  mark_dead
+  escalate_to_human
+}
+
+enum UnionDeviceStatus {
+  online
+  offline
+  maintenance
+}
+
+enum UnionAlertLevel {
+  critical
+  warning
+  info
+}
+
+/// Union user pool — each row is a female user acquired from ads
+model UnionUser {
+  id              String            @id @default(cuid())
+  phone           String            @unique @db.VarChar(20)
+  source          UnionUserSource   @default(other)
+  status          UnionUserStatus   @default(pending_device)
+  phase           UnionPhase        @default(activation)
+  deviceId        String?           @map("device_id")
+  abGroup         String?           @map("ab_group") @db.VarChar(50)
+  refCode         String?           @unique @map("ref_code") @db.VarChar(8)
+  qualityScore    Float?            @default(0) @map("quality_score")
+  isTest          Boolean           @default(false) @map("is_test")
+  sourceDetail    Json?             @map("source_detail")
+  zipCode         String?           @map("zip_code") @db.VarChar(10)
+  lastContactAt   DateTime?         @map("last_contact_at")
+  convertedAt     DateTime?         @map("converted_at")
+  isTakenOver     Boolean           @default(false) @map("is_taken_over")
+  takenOverAt     DateTime?         @map("taken_over_at")
+  createdAt       DateTime          @default(now()) @map("created_at")
+  updatedAt       DateTime          @updatedAt @map("updated_at")
+
+  device          UnionDevice?      @relation(fields: [deviceId], references: [id])
+  conversations   UnionConversation[]
+  statusLogs      UnionStatusLog[]
+  tags            UnionUserTag[]
+  messages        UnionMessage[]
+  decisionLogs    UnionDecisionLog[]
+
+  @@index([status])
+  @@index([phase])
+  @@index([deviceId])
+  @@index([source])
+  @@index([createdAt])
+  @@map("union_users")
+}
+
+/// Conversation messages between AI/operator and union user
+model UnionConversation {
+  id          String           @id @default(cuid())
+  userId      String           @map("user_id")
+  direction   UnionMsgDirection
+  content     String
+  deviceId    String?          @map("device_id")
+  decisionId  String?          @map("decision_id")
+  sendStatus  UnionMsgStatus   @default(pending) @map("send_status")
+  isManual    Boolean          @default(false) @map("is_manual")
+  metadata    Json?
+  createdAt   DateTime         @default(now()) @map("created_at")
+
+  user        UnionUser        @relation(fields: [userId], references: [id])
+  traces      UnionMessageTrace[]
+
+  @@index([userId])
+  @@index([createdAt])
+  @@map("union_conversations")
+}
+
+/// Status transition audit log
+model UnionStatusLog {
+  id          String   @id @default(cuid())
+  userId      String   @map("user_id")
+  fromStatus  UnionUserStatus @map("from_status")
+  toStatus    UnionUserStatus @map("to_status")
+  trigger     String   @db.VarChar(50)
+  operatorId  String?  @map("operator_id")
+  note        String?
+  createdAt   DateTime @default(now()) @map("created_at")
+
+  user        UnionUser @relation(fields: [userId], references: [id])
+
+  @@index([userId])
+  @@index([createdAt])
+  @@map("union_status_logs")
+}
+
+/// User tags (system-generated or manual)
+model UnionUserTag {
+  id        String   @id @default(cuid())
+  userId    String   @map("user_id")
+  tagName   String   @map("tag_name") @db.VarChar(50)
+  tagType   String   @default("system") @map("tag_type") @db.VarChar(20)
+  createdAt DateTime @default(now()) @map("created_at")
+
+  user      UnionUser @relation(fields: [userId], references: [id])
+
+  @@unique([userId, tagName])
+  @@index([tagName])
+  @@map("union_user_tags")
+}
+
+/// Script templates organized by phase → scene → version
+model UnionTemplate {
+  id            String              @id @default(cuid())
+  phase         UnionPhase
+  scene         String              @db.VarChar(50)
+  versionCode   String              @map("version_code") @db.VarChar(20)
+  status        UnionTemplateStatus @default(draft)
+  content       String
+  variables     Json?
+  dialogueTree  Json?               @map("dialogue_tree")
+  creatorId     String?             @map("creator_id")
+  reviewerId    String?             @map("reviewer_id")
+  reviewNote    String?             @map("review_note")
+  publishedAt   DateTime?           @map("published_at")
+  createdAt     DateTime            @default(now()) @map("created_at")
+  updatedAt     DateTime            @updatedAt @map("updated_at")
+
+  @@unique([phase, scene, versionCode])
+  @@index([status])
+  @@map("union_templates")
+}
+
+/// Pre-written first-message templates (sent directly, no LLM)
+model UnionMessageTemplate {
+  id        String   @id @default(cuid())
+  content   String                          // 消息正文
+  category  String   @default("default") @db.VarChar(50) // 分类标签
+  isActive  Boolean  @default(true) @map("is_active")
+  weight    Int      @default(1)            // 随机权重（越大越容易被选中）
+  usedCount Int      @default(0) @map("used_count")
+  creatorId String?  @map("creator_id")
+  createdAt DateTime @default(now()) @map("created_at")
+  updatedAt DateTime @updatedAt @map("updated_at")
+
+  @@index([isActive, category])
+  @@map("union_message_templates")
+}
+
+/// AB test experiments
+model UnionExperiment {
+  id              String   @id @default(cuid())
+  name            String   @db.VarChar(100)
+  phase           UnionPhase
+  scene           String   @db.VarChar(50)
+  variants        Json
+  allocationRule  Json     @map("allocation_rule")
+  status          String   @default("draft") @db.VarChar(20)
+  startedAt       DateTime? @map("started_at")
+  endedAt         DateTime? @map("ended_at")
+  createdAt       DateTime @default(now()) @map("created_at")
+  updatedAt       DateTime @updatedAt @map("updated_at")
+
+  @@map("union_experiments")
+}
+
+/// Physical phone devices used for SMS
+model UnionDevice {
+  id                String           @id @default(cuid())
+  deviceId          String           @unique @map("device_id") @db.VarChar(100)
+  phoneNumber       String           @map("phone_number") @db.VarChar(20)
+  status            UnionDeviceStatus @default(offline)
+  dailyLimit        Int              @default(200) @map("daily_limit")
+  todaySentCount    Int              @default(0) @map("today_sent_count")
+  assignedUsersCount Int             @default(0) @map("assigned_users_count")
+  lastHeartbeatAt   DateTime?        @map("last_heartbeat_at")
+  metadata          Json?
+  createdAt         DateTime         @default(now()) @map("created_at")
+  updatedAt         DateTime         @updatedAt @map("updated_at")
+
+  users             UnionUser[]
+  messages          UnionMessage[]
+
+  @@index([status])
+  @@map("union_devices")
+}
+
+/// WebSocket communication log per device (raw frames, excludes heartbeat)
+model UnionDeviceLog {
+  id        String   @id @default(cuid())
+  deviceId  String   @map("device_id") @db.VarChar(100)
+  direction String   @db.VarChar(20)   // "inbound" | "outbound"
+  frameType String   @map("frame_type") @db.VarChar(50)
+  payload   Json
+  createdAt DateTime @default(now()) @map("created_at")
+
+  @@index([deviceId, createdAt])
+  @@map("union_device_logs")
+}
+
+/// Message queue for reliable delivery
+model UnionMessage {
+  id          String         @id @default(cuid())
+  userId      String         @map("user_id")
+  deviceId    String?        @map("device_id")
+  content     String
+  priority    Int            @default(0)
+  sendStatus  UnionMsgStatus @default(pending) @map("send_status")
+  retryCount  Int            @default(0) @map("retry_count")
+  scheduledAt DateTime?      @map("scheduled_at")
+  sentAt      DateTime?      @map("sent_at")
+  failReason  String?        @map("fail_reason")
+  createdAt   DateTime       @default(now()) @map("created_at")
+  updatedAt   DateTime       @updatedAt @map("updated_at")
+
+  user        UnionUser      @relation(fields: [userId], references: [id])
+  device      UnionDevice?   @relation(fields: [deviceId], references: [id])
+  traces      UnionMessageTrace[]
+
+  @@index([sendStatus])
+  @@index([scheduledAt])
+  @@index([userId])
+  @@map("union_messages")
+}
+
+/// Message trace log - tracks message lifecycle across the entire pipeline
+/// Message trace log - tracks message lifecycle across the entire pipeline
+model UnionMessageTrace {
+  id               String             @id @default(cuid())
+  messageId        String?            @map("message_id")
+  conversationId   String?            @map("conversation_id")
+  stage            String             @db.VarChar(50)
+  status           String             @db.VarChar(20)
+  latencyMs        Int?               @map("latency_ms")
+  metadata         Json?
+  createdAt        DateTime           @default(now()) @map("created_at")
+
+  message          UnionMessage?      @relation(fields: [messageId], references: [id], onDelete: Cascade)
+  conversation     UnionConversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
+
+  @@index([messageId])
+  @@index([conversationId])
+  @@index([stage])
+  @@index([createdAt])
+  @@map("union_message_traces")
+}
+
+/// Brain engine decision log
+model UnionDecisionLog {
+  id           String              @id @default(cuid())
+  userId       String              @map("user_id")
+  triggerType  UnionTriggerType    @map("trigger_type")
+  modelUsed    String?             @map("model_used") @db.VarChar(50)
+  confidence   Float?
+  action       UnionDecisionAction
+  replyText    String?             @map("reply_text")
+  reasoning    String?
+  promptTokens Int?                @map("prompt_tokens")
+  outputTokens Int?                @map("output_tokens")
+  latencyMs    Int?                @map("latency_ms")
+  rawInput     Json?               @map("raw_input")
+  rawOutput    Json?               @map("raw_output")
+  createdAt    DateTime            @default(now()) @map("created_at")
+
+  user         UnionUser           @relation(fields: [userId], references: [id])
+
+  @@index([userId])
+  @@index([action])
+  @@index([createdAt])
+  @@map("union_decision_logs")
+}
+
+/// Prompt version management (4-layer structure)
+model UnionPromptVersion {
+  id        String   @id @default(cuid())
+  layer     String   @db.VarChar(30)
+  phase     UnionPhase?
+  scene     String?  @db.VarChar(50)
+  content   String
+  version   Int      @default(1)
+  status    String   @default("draft") @db.VarChar(20)
+  creatorId String?  @map("creator_id")
+  createdAt DateTime @default(now()) @map("created_at")
+  updatedAt DateTime @updatedAt @map("updated_at")
+
+  @@unique([layer, phase, scene, version])
+  @@map("union_prompt_versions")
+}
+
+/// AI model configuration with priority-based fallback
+model UnionModelConfig {
+  id          String   @id @default(cuid())
+  displayName String   @map("display_name") @db.VarChar(100)
+  modelName   String   @map("model_name") @db.VarChar(50)
+  provider    String   @db.VarChar(30)
+  priority    Int      @default(0)
+  apiKey      String   @map("api_key") @db.VarChar(500)
+  endpoint    String?  @db.VarChar(500)
+  params      Json?
+  enabled     Boolean  @default(true)
+  createdAt   DateTime @default(now()) @map("created_at")
+  updatedAt   DateTime @updatedAt @map("updated_at")
+
+  @@unique([displayName])
+  @@map("union_model_configs")
+}
+
+/// Alert rules for monitoring
+model UnionAlertRule {
+  id              String   @id @default(cuid())
+  name            String   @db.VarChar(100)
+  condition       String   @db.VarChar(200)
+  threshold       Float
+  level           UnionAlertLevel @default(warning)
+  enabled         Boolean  @default(true)
+  silenceMinutes  Int      @default(30) @map("silence_minutes")
+  createdAt       DateTime @default(now()) @map("created_at")
+  updatedAt       DateTime @updatedAt @map("updated_at")
+
+  alerts          UnionAlertLog[]
+
+  @@map("union_alert_rules")
+}
+
+/// Alert history
+model UnionAlertLog {
+  id         String          @id @default(cuid())
+  ruleId     String          @map("rule_id")
+  level      UnionAlertLevel
+  message    String
+  resolvedAt DateTime?       @map("resolved_at")
+  createdAt  DateTime        @default(now()) @map("created_at")
+
+  rule       UnionAlertRule  @relation(fields: [ruleId], references: [id])
+
+  @@index([ruleId])
+  @@index([createdAt])
+  @@map("union_alert_logs")
+}
+
+/// Import history log
+model UnionImportLog {
+  id         String   @id @default(cuid())
+  operatorId String   @map("operator_id")
+  filename   String   @db.VarChar(255)
+  total      Int      @default(0)
+  success    Int      @default(0)
+  failed     Int      @default(0)
+  errors     Json?
+  createdAt  DateTime @default(now()) @map("created_at")
+
+  @@index([createdAt])
+  @@map("union_import_logs")
+}
+
+/// AI call log — 大模型调用记录（持久化统计）
+model UnionAiCallLog {
+  id        String   @id @default(cuid())
+  source    String   @db.VarChar(30)
+  model     String   @db.VarChar(80)
+  success   Boolean
+  latencyMs Int      @map("latency_ms")
+  error     String?
+  createdAt DateTime @default(now()) @map("created_at")
+
+  @@index([createdAt])
+  @@index([success])
+  @@map("union_ai_call_logs")
+}
+
+/// Global configuration (key-value), decoupled from templates
+model UnionGlobalConfig {
+  key       String   @id @db.VarChar(100)
+  value     String
+  label     String?  @db.VarChar(200)
+  updatedAt DateTime @updatedAt @map("updated_at")
+
+  @@map("union_global_config")
+}
+
+enum UnionBatchJobStatus {
+  pending
+  processing
+  completed
+  failed
+  cancelled
+}
+
+/// Async batch job record — tracks progress for long-running batch operations
+model UnionBatchJob {
+  id           String              @id @default(cuid())
+  action       String              @db.VarChar(50)
+  status       UnionBatchJobStatus @default(pending)
+  totalCount   Int                 @default(0) @map("total_count")
+  successCount Int                 @default(0) @map("success_count")
+  failedCount  Int                 @default(0) @map("failed_count")
+  userIds      Json                @map("user_ids")
+  params       Json?
+  results      Json?
+  operatorId   String?             @map("operator_id")
+  scheduledAt  DateTime?           @map("scheduled_at")
+  startedAt    DateTime?           @map("started_at")
+  completedAt  DateTime?           @map("completed_at")
+  error        String?
+  createdAt    DateTime            @default(now()) @map("created_at")
+  updatedAt    DateTime            @updatedAt @map("updated_at")
+
+  @@index([status])
+  @@index([scheduledAt])
+  @@index([createdAt])
+  @@map("union_batch_jobs")
+}
