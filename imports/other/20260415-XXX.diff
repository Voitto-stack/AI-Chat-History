+
+const TEMPLATES = [
+  // ============ greeting: 轻松问候型 ============
+  { id: 'tpl_greet_01', content: "Hey! 👋 I came across your profile and thought you'd be a great fit for {{app_name}}. We're a video chat platform where hosts earn up to $90/hr. Interested in learning more?", category: 'greeting', weight: 2 },
+  { id: 'tpl_greet_02', content: "Hi there! I'm reaching out because you match what we look for in {{app_name}} hosts. It's a fun way to earn extra income through video chats. Have you ever tried anything like that?", category: 'greeting', weight: 2 },
+  { id: 'tpl_greet_03', content: "Hey! Quick question — have you ever thought about making money through video chatting? {{app_name}} hosts earn $90/hr on average and we think you'd do great. Wanna hear more?", category: 'greeting', weight: 2 },
+  { id: 'tpl_greet_04', content: "Hi! 😊 Just wanted to reach out — we have an opening for video chat hosts on {{app_name}} and your profile really stood out. Would you be open to chatting about it?", category: 'greeting', weight: 1 },
+  { id: 'tpl_greet_05', content: "Hey! Hope your day is going well. I work with {{app_name}}, a social platform where hosts earn great money doing video chats. Thought of you — interested?", category: 'greeting', weight: 1 },
+
+  // ============ promotion: 利益驱动型 ============
+  { id: 'tpl_promo_01', content: "Hi! {{app_name}} is offering a $50 sign-up bonus for new hosts right now. You'd also earn up to $90/hr doing fun video chats. Want me to send you the details?", category: 'promotion', weight: 3 },
+  { id: 'tpl_promo_02', content: "Hey! Just a heads up — {{app_name}} has a limited $50 bonus for new creators who join this week. Plus ongoing earnings of $90/hr. Sounds interesting?", category: 'promotion', weight: 3 },
+  { id: 'tpl_promo_03', content: "Hi there! Wanted to let you know about an opportunity — {{app_name}} hosts earn $90/hr with a $50 welcome bonus. No experience needed, just be yourself on video. Curious?", category: 'promotion', weight: 2 },
+  { id: 'tpl_promo_04', content: "Hey! 💰 Quick heads up: {{app_name}} is looking for new video chat hosts. $50 sign-up bonus + $90/hr earnings. Flexible schedule, work from anywhere. Would you like to know more?", category: 'promotion', weight: 2 },
+  { id: 'tpl_promo_05', content: "Hi! I'm with {{app_name}} — we pay hosts up to $90/hour for video chats, and there's a $50 bonus just for signing up. It's flexible and fun. Want to give it a try?", category: 'promotion', weight: 2 },
+
+  // ============ casual: 自然聊天型 ============
+  { id: 'tpl_casual_01', content: "Hey! So I know this might sound random, but I think you'd be really good at this — {{app_name}} is a video chat app where people earn money just by being themselves. Ever heard of it?", category: 'casual', weight: 2 },
+  { id: 'tpl_casual_02', content: "Hi! 😄 Not gonna lie, I was browsing profiles and yours caught my eye. Have you ever considered being a video chat host? {{app_name}} makes it super easy to start.", category: 'casual', weight: 1 },
+  { id: 'tpl_casual_03', content: "Hey there! Random question — would you ever try making money through video chatting? I ask because {{app_name}} is looking for people just like you. No pressure, just curious!", category: 'casual', weight: 1 },
+  { id: 'tpl_casual_04', content: "Hi! Hope I'm not bothering you. I wanted to share something cool — {{app_name}} lets you earn money chatting with people over video. Super flexible, no commitments. Thoughts?", category: 'casual', weight: 1 },
