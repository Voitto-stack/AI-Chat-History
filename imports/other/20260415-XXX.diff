new file mode 100644
index 00000000..b7e05f8c
--- /dev/null
+++ b/apps/minerva-server/prisma/check-keys.ts
@@ -0,0 +1,31 @@
+import { PrismaClient } from '../src/generated/prisma';
+
+const prisma = new PrismaClient();
+
+async function main() {
+  const models = await prisma.unionModelConfig.findMany({
+    select: {
+      modelName: true,
+      provider: true,
+      apiKey: true,
+      enabled: true,
+      priority: true,
+    },
+    orderBy: { priority: 'asc' },
+  });
+
+  console.log('Current API Key status:');
+  models.forEach(m => {
+    const keyStatus = m.apiKey === 'placeholder' ? '❌ PLACEHOLDER' :
+                      m.apiKey.length > 20 ? '✅ CONFIGURED' : '⚠️  SHORT KEY';
+    console.log(`  ${m.modelName} (${m.provider})`);
+    console.log(`    Priority: ${m.priority}, Enabled: ${m.enabled}`);
+    console.log(`    API Key: ${keyStatus}`);
+    console.log('');
+  });
+}
+
+main()
+  .finally(async () => {
+    await prisma.$disconnect();
+  });
