+
+export const simulatorSendResponseSchema = z.object({
+  userMessage: z.object({
+    content: z.string(),
+    createdAt: z.string(),
+  }),
+  aiResponse: z.object({
+    content: z.string(),
+    contents: z.array(z.string()),
