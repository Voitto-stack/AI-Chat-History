+  ];
+
+  const aiStatCards: StatCardItem[] = [
+    {
+      title: '总调用次数',
+      value: stats?.total ?? 0,
+      icon: <ThunderboltOutlined />,
+      color: '#1890ff',
+      bg: 'linear-gradient(135deg, #e6f4ff 0%, #bae0ff 100%)',
