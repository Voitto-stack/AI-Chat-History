+import Router from '@koa/router';
+import { prisma } from '../../utils/prisma.js';
+import { success } from '../../utils/response.js';
+import { AppError } from '../../utils/AppError.js';
+import { authMiddleware, requirePermission } from '../../middlewares/auth.js';
+
+export const gatewayRouter = new Router();
+
+/**
+ * POST /api/union/gateway/send
+ * Send message to user via assigned device
+ */
+gatewayRouter.post(
+  '/send',
+  authMiddleware,
+  requirePermission('union.device.write'),
+  async (ctx) => {
+    const { userId, content, priority } = ctx.request.body as {
+      userId: string;
+      content: string;
+      priority?: number;
+    };
+
+    if (!userId || !content) {
+      throw AppError.badRequest('userId and content are required');
+    }
+
+    const user = await prisma.unionUser.findUnique({
+      where: { id: userId },
+      select: { id: true, deviceId: true },
+    });
+
+    if (!user) {
+      throw AppError.notFound('User not found');
+    }
+
+    if (!user.deviceId) {
+      throw AppError.badRequest(
+        'User has no assigned device',
+        'NO_DEVICE_ASSIGNED'
+      );
+    }
+
+    const message = await prisma.unionMessage.create({
+      data: {
+        userId,
+        deviceId: user.deviceId,
+        content,
+        priority: priority ?? 0,
+      },
+    });
+
+    success(ctx, { messageId: message.id }, 201);
+  }
+);
+
+/**
+ * POST /api/union/gateway/receive
+ * Webhook endpoint for inbound messages from devices
+ */
+gatewayRouter.post('/receive', async (ctx) => {
+  const { deviceId, phone, content } = ctx.request.body as {
+    deviceId: string;
+    phone: string;
+    content: string;
+  };
+
+  if (!deviceId || !phone || !content) {
+    throw AppError.badRequest('deviceId, phone, and content are required');
+  }
+
+  const user = await prisma.unionUser.findUnique({
+    where: { phone },
+    select: { id: true },
+  });
+
+  if (!user) {
+    throw AppError.notFound('User not found for this phone number');
+  }
+
+  const conversation = await prisma.unionConversation.create({
+    data: {
+      userId: user.id,
+      deviceId,
+      direction: 'inbound',
+      content,
+    },
+  });
+
+  success(ctx, { conversationId: conversation.id, acknowledged: true }, 201);
+});
\ No newline at end of file
