+import Router from '@koa/router';
+import { usersRouter } from './users.js';
+import { usersImportRouter } from './users-import.js';
+import { usersStateRouter } from './users-state.js';
+import { usersTagsRouter } from './users-tags.js';
+import { templatesRouter } from './templates.js';
+import { templatesReviewRouter } from './templates-review.js';
+import { messageTemplatesRouter } from './message-templates.js';
+import { experimentsRouter } from './experiments.js';
+import { brainRouter } from './brain.js';
+import { brainLogRouter } from './brain-log.js';
+import { aiServiceRouter } from './ai-service.js';
+import { aiPromptRouter } from './ai-prompt.js';
+import { aiModelConfigRouter } from './ai-model-config.js';
+import { aiPlaygroundRouter } from './ai-playground.js';
+import { gatewayRouter } from './gateway.js';
+import { gatewayDeviceRouter } from './gateway-device.js';
+import { gatewayQueueRouter } from './gateway-queue.js';
+import { gatewayTraceRouter } from './gateway-trace.js';
+import { analyticsRouter } from './analytics.js';
+import { alertsRouter } from './alerts.js';
+import { simulatorRouter } from './simulator.js';
+import { globalConfigRouter } from './global-config.js';
+import { batchJobsRouter } from './batch-jobs.js';
+import { startUnionScheduler } from '../../services/union/scheduler.js';
+
+export const unionRouter = new Router();
+
+// 启动 Union 定时任务
+startUnionScheduler();
+
+// Plan 1: User Pool
+unionRouter.use('/users', usersRouter.routes(), usersRouter.allowedMethods());
+unionRouter.use('/users-import', usersImportRouter.routes(), usersImportRouter.allowedMethods());
+unionRouter.use('/users-state', usersStateRouter.routes(), usersStateRouter.allowedMethods());
+unionRouter.use('/users-tags', usersTagsRouter.routes(), usersTagsRouter.allowedMethods());
+
+// Plan 2: Brain Engine + AI
+unionRouter.use('/brain', brainRouter.routes(), brainRouter.allowedMethods());
+unionRouter.use('/brain-log', brainLogRouter.routes(), brainLogRouter.allowedMethods());
+unionRouter.use('/ai-service', aiServiceRouter.routes(), aiServiceRouter.allowedMethods());
+unionRouter.use('/ai-prompt', aiPromptRouter.routes(), aiPromptRouter.allowedMethods());
+unionRouter.use('/ai-model-config', aiModelConfigRouter.routes(), aiModelConfigRouter.allowedMethods());
+unionRouter.use('/ai-playground', aiPlaygroundRouter.routes(), aiPlaygroundRouter.allowedMethods());
+
+// Plan 3: Communication Gateway
+unionRouter.use('/gateway', gatewayRouter.routes(), gatewayRouter.allowedMethods());
+unionRouter.use('/gateway-device', gatewayDeviceRouter.routes(), gatewayDeviceRouter.allowedMethods());
+unionRouter.use('/gateway-queue', gatewayQueueRouter.routes(), gatewayQueueRouter.allowedMethods());
+unionRouter.use('/gateway-trace', gatewayTraceRouter.routes(), gatewayTraceRouter.allowedMethods());
+
+// Plan 4: Templates
+unionRouter.use('/templates', templatesRouter.routes(), templatesRouter.allowedMethods());
+unionRouter.use('/templates-review', templatesReviewRouter.routes(), templatesReviewRouter.allowedMethods());
+unionRouter.use('/experiments', experimentsRouter.routes(), experimentsRouter.allowedMethods());
+unionRouter.use('/message-templates', messageTemplatesRouter.routes(), messageTemplatesRouter.allowedMethods());
+
+// Plan 6: Analytics & Alerts
+unionRouter.use('/analytics', analyticsRouter.routes(), analyticsRouter.allowedMethods());
+unionRouter.use('/alerts', alertsRouter.routes(), alertsRouter.allowedMethods());
+
+// Plan 7: Simulator
+unionRouter.use('/simulator', simulatorRouter.routes(), simulatorRouter.allowedMethods());
+
+// Batch Jobs
+unionRouter.use('/batch-jobs', batchJobsRouter.routes(), batchJobsRouter.allowedMethods());
+
+// Global Config
+unionRouter.use('/config', globalConfigRouter.routes(), globalConfigRouter.allowedMethods());
