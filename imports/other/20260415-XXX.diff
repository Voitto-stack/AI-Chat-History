+import { PrismaClient } from '../src/generated/prisma';
+
+const prisma = new PrismaClient();
+
+async function main() {
+  console.log('🤖 Seeding AI model configurations...');
+
+  // Claude Opus 4.6
+  await prisma.unionModelConfig.upsert({
+    where: { modelName: 'claude-opus-4-6' },
+    update: {},
+    create: {
+      modelName: 'claude-opus-4-6',
+      provider: 'anthropic',
+      priority: 1,
+      apiKey: process.env.ANTHROPIC_API_KEY || 'placeholder',
+      params: { maxTokens: 4096, temperature: 0.7, timeoutMs: 30000 },
+      enabled: true,
+    },
+  });
+
+  // Gemini 2.0 Flash
+  await prisma.unionModelConfig.upsert({
+    where: { modelName: 'gemini-2.0-flash-exp' },
+    update: {},
+    create: {
+      modelName: 'gemini-2.0-flash-exp',
+      provider: 'google',
+      priority: 2,
+      apiKey: process.env.GOOGLE_API_KEY || 'placeholder',
+      params: { maxTokens: 4096, temperature: 0.7, timeoutMs: 30000 },
+      enabled: true,
+    },
+  });
+
+  console.log('✅ Model configurations seeded!');
+}
+
+main()
+  .catch((e) => {
+    console.error('❌ Seed failed:', e);
+    process.exit(1);
+  })
+  .finally(async () => {
+    await prisma.$disconnect();
+  });
