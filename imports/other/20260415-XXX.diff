+import React, { useState, useCallback, useEffect } from 'react';
+import { PageContainer } from '@ant-design/pro-components';
+import {
+  Card,
+  Row,
+  Col,
+  Tag,
+  Badge,
+  Typography,
+  Descriptions,
+  Timeline,
+  Select,
+  Input,
+  Button,
+  message,
+  Spin,
+  Space,
+  Pagination,
+  Empty,
+} from 'antd';
+import { ArrowUpOutlined, ArrowDownOutlined, SendOutlined, ReloadOutlined } from '@ant-design/icons';
+import { useParams, history } from '@umijs/max';
+import { useRequest } from 'ahooks';
+import dayjs from 'dayjs';
+import { getUnionDevice, listDeviceLogs, sendToDevice, getDeviceConnectionsDebug } from '@/api/union';
+
+const { Text, Paragraph } = Typography;
+const { TextArea } = Input;
+
+const FRAME_TYPE_OPTIONS = [
+  { label: 'push_message', value: 'push_message' },
+  { label: 'registered', value: 'registered' },
+  { label: 'heartbeat_ack', value: 'heartbeat_ack' },
+  { label: 'error', value: 'error' },
+];
+
+const DEFAULT_PAYLOADS: Record<string, object> = {
+  push_message: {
+    messageId: '',
+    phone: '13800138000',
+    zipCode: '',
+    content: '测试消息',
+    priority: 0,
+  },
+  registered: { deviceId: '', status: 'online' },
+  heartbeat_ack: {},
+  error: { code: 'UNKNOWN', message: '' },
+};
+
+const statusColorMap: Record<string, string> = {
+  online: 'green',
+  offline: 'red',
+};
+
+const statusTextMap: Record<string, string> = {
+  online: '在线',
+  offline: '离线',
+};
+
+const DeviceDetail: React.FC = () => {
+  const { id } = useParams<{ id: string }>();
+  const [sendType, setSendType] = useState('push_message');
+  const [payloadText, setPayloadText] = useState(
+    JSON.stringify(DEFAULT_PAYLOADS['push_message'], null, 2),
+  );
+  const [payloadError, setPayloadError] = useState('');
+  const [logPage, setLogPage] = useState(1);
+  const LOG_PAGE_SIZE = 20;
+
+  // ── Device Info (3s polling) ────────────────────────────
+  const { data: device, loading: deviceLoading, refresh: refreshDevice } = useRequest(
+    () => getUnionDevice(id!),
+    {
+      refreshInterval: 3000,
+      ready: !!id,
+    },
+  );
+
+  // ── Debug: WS connections Map ──────────────────────────
+  const { data: debugData, refresh: refreshDebug } = useRequest(
+    () => getDeviceConnectionsDebug(),
+    { refreshInterval: 3000, ready: !!id },
+  );
+
+  // ── Logs (5s polling) ──────────────────────────────────
+  const { data: logData, loading: logLoading, refresh: refreshLogs } = useRequest(
+    () => listDeviceLogs(id!, { page: logPage, pageSize: LOG_PAGE_SIZE }),
+    {
+      ready: !!id,
+      refreshDeps: [logPage],
+    },
+  );
+
+  useEffect(() => {
+    if (!id) return;
+    const timer = setInterval(() => {
+      refreshLogs();
+    }, 5000);
+    return () => clearInterval(timer);
+  }, [id, refreshLogs]);
+
+  // ── Send ───────────────────────────────────────────────
+  const { run: doSend, loading: sending } = useRequest(
+    (type: string, data: object) => sendToDevice(id!, { type, data }),
+    {
+      manual: true,
+      onSuccess: (res) => {
+        if (res.pushed) {
+          message.success('发送成功');
+        } else {
+          message.warning(`发送失败：${res.reason ?? 'device_offline'}`);
+        }
+        refreshLogs();
+      },
+      onError: () => message.error('发送请求失败'),
+    },
+  );
+
+  const handleSend = useCallback(() => {
+    setPayloadError('');
+    let parsed: object;
+    try {
+      parsed = JSON.parse(payloadText);
+    } catch {
+      setPayloadError('JSON 格式有误，请检查后重试');
+      return;
+    }
+    doSend(sendType, parsed);
+  }, [payloadText, sendType, doSend]);
+
+  const isOnline = device?.online ?? false;
+
+  // ── Timeline items ─────────────────────────────────────
+  const timelineItems = (logData?.items ?? []).map((log) => ({
+    color: log.direction === 'inbound' ? 'blue' : 'green',
+    dot:
+      log.direction === 'inbound' ? (
+        <ArrowDownOutlined style={{ color: '#1677ff' }} />
+      ) : (
+        <ArrowUpOutlined style={{ color: '#52c41a' }} />
+      ),
+    children: (
+      <div style={{ marginBottom: 4 }}>
+        <Space size={4} style={{ marginBottom: 4 }}>
+          <Tag color={log.direction === 'inbound' ? 'blue' : 'green'}>
+            {log.direction === 'inbound' ? '↓ 入' : '↑ 出'}
+          </Tag>
+          <Tag>{log.frameType}</Tag>
+          <Text type="secondary" style={{ fontSize: 12 }}>
+            {dayjs(log.createdAt).format('HH:mm:ss')}
+          </Text>
+        </Space>
+        {log.payload && Object.keys(log.payload).length > 0 && (
+          <pre
+            style={{
+              margin: '4px 0 0',
+              fontSize: 12,
+              lineHeight: 1.5,
+              background: '#f5f5f5',
+              padding: '6px 10px',
+              borderRadius: 4,
+              maxHeight: 160,
+              overflow: 'auto',
+              color: '#333',
+            }}
+          >
+            {JSON.stringify(log.payload, null, 2)}
+          </pre>
+        )}
+      </div>
+    ),
+  }));
+
+  return (
+    <PageContainer
+      title="设备详情"
+      onBack={() => history.back()}
+      loading={deviceLoading && !device}
+    >
+      {/* ── Device Info Card ── */}
+      <Card style={{ marginBottom: 16 }} loading={deviceLoading && !device}>
+        {device && (
+          <Descriptions column={4} size="small">
+            <Descriptions.Item label="Device ID">
+              <Text copyable>{device.deviceId}</Text>
+            </Descriptions.Item>
+            <Descriptions.Item label="手机号">{device.phoneNumber}</Descriptions.Item>
+            <Descriptions.Item label="DB 状态">
+              <Tag color={statusColorMap[device.status] ?? 'default'}>
+                {statusTextMap[device.status] ?? device.status}
+              </Tag>
+            </Descriptions.Item>
+            <Descriptions.Item label="WS 在线">
+              <Badge
+                status={isOnline ? 'success' : 'error'}
+                text={isOnline ? '已连接' : '未连接'}
+              />
+            </Descriptions.Item>
+            <Descriptions.Item label="日限额">{device.dailyLimit}</Descriptions.Item>
+            <Descriptions.Item label="今日已发">{device.todaySentCount}</Descriptions.Item>
+            <Descriptions.Item label="分配用户">{device.assignedUsersCount}</Descriptions.Item>
+            <Descriptions.Item label="最后心跳">
+              {device.lastHeartbeatAt ? dayjs(device.lastHeartbeatAt).format('MM-DD HH:mm:ss') : '—'}
+            </Descriptions.Item>
+          </Descriptions>
+        )}
+      </Card>
+
+      {/* ── Debug: WS Connections Map ── */}
+      <Card
+        size="small"
+        title={`🔍 Debug: WS Connections Map (size=${debugData?.size ?? '?'})`}
+        style={{ marginBottom: 16, background: '#fffbe6', border: '1px solid #ffe58f' }}
+      >
+        <pre style={{ margin: 0, fontSize: 12, whiteSpace: 'pre-wrap' }}>
+          {debugData ? JSON.stringify(debugData, null, 2) : 'Loading...'}
+        </pre>
+        {device && debugData && (
+          <div style={{ marginTop: 8 }}>
+            <Text strong>当前设备 deviceId: </Text>
+            <Text code>{device.deviceId}</Text>
+            <Text strong style={{ marginLeft: 16 }}>在 Map 中: </Text>
+            <Tag color={debugData.connections[device.deviceId] ? 'green' : 'red'}>
+              {debugData.connections[device.deviceId] ? '✓ 存在' : '✗ 不存在'}
+            </Tag>
+          </div>
+        )}
+      </Card>
+
+      <Row gutter={16}>
+        {/* ── Left: Communication Log ── */}
+        <Col span={14}>
+          <Card
+            title={
+              <Space>
+                通信日志
+                <Text type="secondary" style={{ fontSize: 12, fontWeight: 'normal' }}>
+                  (5s 自动刷新)
+                </Text>
+              </Space>
+            }
+            extra={
+              <Button
+                size="small"
+                icon={<ReloadOutlined />}
+                onClick={refreshLogs}
+                loading={logLoading}
+              >
+                刷新
+              </Button>
+            }
+            style={{ minHeight: 500 }}
+          >
+            <Spin spinning={logLoading && !logData}>
+              {timelineItems.length > 0 ? (
+                <>
+                  <Timeline items={timelineItems} />
+                  <div style={{ textAlign: 'right', marginTop: 8 }}>
+                    <Pagination
+                      size="small"
+                      current={logPage}
+                      pageSize={LOG_PAGE_SIZE}
+                      total={logData?.total ?? 0}
+                      onChange={(p) => setLogPage(p)}
+                      showSizeChanger={false}
+                      showTotal={(t) => `共 ${t} 条`}
+                    />
+                  </div>
+                </>
+              ) : (
+                <Empty description="暂无通信记录" image={Empty.PRESENTED_IMAGE_SIMPLE} />
+              )}
+            </Spin>
+          </Card>
+        </Col>
+
+        {/* ── Right: Send Panel ── */}
+        <Col span={10}>
+          <Card title="主动推送">
+            <div style={{ marginBottom: 12 }}>
+              <div style={{ marginBottom: 4 }}>
+                <Text strong>帧类型</Text>
+              </div>
+              <Select
+                style={{ width: '100%' }}
+                options={FRAME_TYPE_OPTIONS}
+                value={sendType}
+                onChange={(v) => {
+                  setSendType(v);
+                  setPayloadText(JSON.stringify(DEFAULT_PAYLOADS[v] ?? {}, null, 2));
+                }}
+                showSearch
+                allowClear={false}
+              />
+            </div>
+
+            <div style={{ marginBottom: 12 }}>
+              <div style={{ marginBottom: 4 }}>
+                <Text strong>Payload (JSON)</Text>
+              </div>
+              <TextArea
+                rows={10}
+                value={payloadText}
+                onChange={(e) => {
+                  setPayloadText(e.target.value);
+                  setPayloadError('');
+                }}
+                style={{ fontFamily: 'monospace', fontSize: 13 }}
+                placeholder='{\n  "key": "value"\n}'
+              />
+              {payloadError && (
+                <Text type="danger" style={{ fontSize: 12 }}>
+                  {payloadError}
+                </Text>
+              )}
+            </div>
+
+            {!isOnline && (
+              <div style={{ marginBottom: 8 }}>
+                <Tag color="red">设备离线，无法发送</Tag>
+              </div>
+            )}
+
+            <Button
+              type="primary"
+              icon={<SendOutlined />}
+              onClick={handleSend}
+              loading={sending}
+              disabled={!isOnline}
+              block
+            >
+              发送
+            </Button>
+          </Card>
+        </Col>
+      </Row>
+    </PageContainer>
+  );
+};
+
+export default DeviceDetail;
