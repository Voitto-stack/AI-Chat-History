+            formRef.current?.setFieldsValue({
+              phone: undefined,
+              source: undefined,
+              status: undefined,
+              phase: undefined,
+              outboundCount: undefined,
+              inboundCount: undefined,
+            });
+          },
+        }}
+      />
+
+      {/* ── 批量操作弹窗 ── */}
+      <Modal
+        title={`批量操作 (${selectedRowKeys.length} 个用户)`}
+        open={batchModalOpen}
+        onCancel={() => { setBatchModalOpen(false); setBatchAction(''); setBatchParam(''); setUseSchedule(false); setScheduledAt(null); }}
+        onOk={handleBatchSubmit}
+        confirmLoading={batchLoading}
+        okButtonProps={{ disabled: !batchAction || (useSchedule && !scheduledAt) }}
+        okText={useSchedule && scheduledAt ? '创建定时任务' : '立即执行'}
+      >
+        <Select
+          placeholder="选择操作类型"
+          value={batchAction || undefined}
+          onChange={(v) => { setBatchAction(v); setBatchParam(''); }}
+          style={{ width: '100%' }}
+          options={BATCH_ACTIONS.map((a) => ({ label: a.label, value: a.value }))}
+        />
+        {renderParamInput()}
+        {batchAction === 'start_conversation' && (
+          <Alert
+            type="warning"
+            showIcon
+            style={{ marginTop: 12 }}
+            message={`将为 ${selectedRowKeys.length} 个用户启动短信对话，AI 将自动生成首条消息并通过网关发送到用户手机。`}
+          />
+        )}
+        {batchAction === 'retry_conversation' && (
+          <Alert
+            type="warning"
+            showIcon
+            style={{ marginTop: 12 }}
+            message={`将为 ${selectedRowKeys.length} 个用户重新生成并发送消息。适用于因 LLM 生成失败导致对话中但无消息发出的用户。`}
+          />
+        )}
+        {batchAction && (
+          <div style={{ marginTop: 12, display: 'flex', alignItems: 'center', gap: 12 }}>
+            <Switch
+              checked={useSchedule}
+              onChange={(v) => { setUseSchedule(v); if (!v) setScheduledAt(null); }}
+              size="small"
+            />
+            <span>定时执行</span>
+            {useSchedule && (
+              <DatePicker
+                showTime
+                format="YYYY-MM-DD HH:mm"
+                placeholder="选择执行时间"
+                value={scheduledAt}
+                onChange={setScheduledAt}
+                style={{ flex: 1 }}
+              />
+            )}
+          </div>
+        )}
+      </Modal>
+    </PageContainer>
+  );
+};
+
+export default UnionUserList;
