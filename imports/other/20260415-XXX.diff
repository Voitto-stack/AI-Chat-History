@@ -0,0 +1,48 @@
+/**
+ * Trace Writer — 消息链路追踪写入器
+ *
+ * Fire-and-forget：trace 写入失败不阻塞主消息管道
+ */
+import { prisma } from '../../utils/prisma.js';
+
+export type TraceStage =
+  | 'ai_decision'
+  | 'device_allocated'
+  | 'queue_created'
+  | 'ws_pushed'
+  | 'device_sent'
+  | 'sms_delivered'
+  | 'send_failed'
+  | 'inbound_received'
+  | 'user_identified'
+  | 'ai_triggered'
+  | 'ai_skipped'
+  | 'operator_sent';
+
+export type TraceStatus = 'success' | 'failed' | 'skipped';
+
+export interface TraceParams {
+  messageId?: string;
+  conversationId?: string;
+  stage: TraceStage;
+  status: TraceStatus;
+  latencyMs?: number;
+  metadata?: Record<string, unknown>;
+}
+
+export function writeTrace(params: TraceParams): void {
+  prisma.unionMessageTrace
+    .create({
+      data: {
+        messageId: params.messageId ?? null,
+        conversationId: params.conversationId ?? null,
+        stage: params.stage,
+        status: params.status,
+        latencyMs: params.latencyMs ?? null,
+        metadata: (params.metadata as any) ?? null,
+      },
+    })
+    .catch((err) => {
+      console.error('[Trace] Failed to write trace:', params.stage, err.message);
+    });
+}
