+              loading={loading}
+              onClick={doImport}
+              disabled={autoStart && useSchedule && !scheduledAt}
+            >
+              {autoStart ? '导入并发起对话' : '确认导入'}
+            </Button>
+            <Button onClick={() => setRows([])}>重新选择</Button>
+          </Space>
+        </>
+      )}
+    </PageContainer>
+  );
+};
+
+export default UnionUserImport;
