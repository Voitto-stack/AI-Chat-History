+  value: number | string;
+  suffix?: string;
+  icon: React.ReactNode;
+  color: string;
+  bg: string;
+  sub?: {
+    label: string;
+    value: number | string;
+    icon?: React.ReactNode;
+  };
+}
+
+/** 单张渐变统计卡片 */
+export const GradientStatCard: React.FC<{ card: StatCardItem }> = ({ card }) => (
+  <div
+    style={{
+      background: card.bg,
+      borderRadius: 12,
+      padding: '20px 16px 16px',
+      height: '100%',
+      position: 'relative',
+      overflow: 'hidden',
+      border: `1px solid ${card.color}22`,
+      transition: 'box-shadow .2s, transform .2s',
+      cursor: 'default',
+    }}
+    onMouseEnter={(e) => {
+      e.currentTarget.style.boxShadow = `0 4px 16px ${card.color}30`;
+      e.currentTarget.style.transform = 'translateY(-2px)';
+    }}
+    onMouseLeave={(e) => {
+      e.currentTarget.style.boxShadow = 'none';
+      e.currentTarget.style.transform = 'none';
+    }}
+  >
+    {/* 右上角装饰水印 */}
+    <div
+      style={{
+        position: 'absolute',
+        top: -8,
+        right: -8,
+        fontSize: 64,
+        color: card.color,
+        opacity: 0.08,
+        lineHeight: 1,
+      }}
+    >
+      {card.icon}
+    </div>
+
+    <div style={{ fontSize: 13, color: '#666', marginBottom: 8, display: 'flex', alignItems: 'center', gap: 6 }}>
+      <span style={{ color: card.color, fontSize: 16 }}>{card.icon}</span>
+      {card.title}
+    </div>
+
+    <div style={{ fontSize: 28, fontWeight: 700, color: '#1a1a1a', lineHeight: 1.2 }}>
+      {typeof card.value === 'number' ? card.value.toLocaleString() : card.value}
+      {card.suffix && (
+        <span style={{ fontSize: 14, fontWeight: 400, color: '#999', marginLeft: 4 }}>{card.suffix}</span>
+      )}
+    </div>
+
+    {card.sub && (
+      <div style={{ marginTop: 10, paddingTop: 10, borderTop: `1px dashed ${card.color}33`, display: 'flex', alignItems: 'center', gap: 4 }}>
+        {card.sub.icon && <span style={{ color: card.color, fontSize: 12 }}>{card.sub.icon}</span>}
+        <span style={{ fontSize: 12, color: '#999' }}>{card.sub.label}</span>
+        <span style={{ fontSize: 14, fontWeight: 600, color: '#555', marginLeft: 'auto' }}>
+          {typeof card.sub.value === 'number' ? card.sub.value.toLocaleString() : card.sub.value}
+        </span>
+      </div>
+    )}
+  </div>
+);
+
+/** 渐变统计卡片行：自动按数量分配列宽 */
+export const GradientStatRow: React.FC<{
+  cards: StatCardItem[];
+  gutter?: [number, number];
+  colSpan?: number;
+  style?: React.CSSProperties;
+}> = ({ cards, gutter = [16, 16], colSpan, style }) => {
+  const span = colSpan ?? Math.floor(24 / Math.min(cards.length, 6));
+  return (
+    <Row gutter={gutter} style={style}>
+      {cards.map((card) => (
+        <Col key={card.title} xs={12} sm={8} lg={span}>
+          <GradientStatCard card={card} />
+        </Col>
+      ))}
+    </Row>
+  );
+};
