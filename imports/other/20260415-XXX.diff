@@ -0,0 +1,584 @@
+import Router from '@koa/router';
+import crypto from 'crypto';
+import { prisma } from '../../utils/prisma.js';
+import { success } from '../../utils/response.js';
+import { AppError } from '../../utils/AppError.js';
+import { authMiddleware, requirePermission } from '../../middlewares/auth.js';
+import { processBrainDecisionSafe } from '../../services/union/brain-engine.js';
+import { writeTrace } from '../../services/union/trace-writer.js';
+import { sendOutboundMessage } from '../../services/union/gateway-service.js';
+
+export const simulatorRouter = new Router();
+simulatorRouter.use(authMiddleware);
+
+/** POST /session — Create simulator session */
+simulatorRouter.post('/session', requirePermission('union.simulator.use'), async (ctx) => {
+  const { phone, userId, phase = 'activation', abGroup, modelConfigId, liveMode } =
+    (ctx.request.body as any) ?? {};
+
+  // Find or create user
+  let user;
+  if (userId) {
+    user = await prisma.unionUser.findUnique({ where: { id: userId } });
+    if (!user) throw AppError.notFound('User not found');
+  } else {
+    const phoneToUse = phone || '+1555000TEST';
+    user = await prisma.unionUser.findUnique({ where: { phone: phoneToUse } });
+    if (!user) {
+      user = await prisma.unionUser.create({
+        data: {
+          phone: phoneToUse,
+          source: 'manual',
+          status: 'pending_contact',
+          phase,
+          abGroup: abGroup || null,
+          isTest: true,
+          refCode: crypto.randomBytes(4).toString('hex'),
+        },
+      });
+    }
+  }
+
+  let conversations = await prisma.unionConversation.findMany({
+    where: { userId: user.id },
+    orderBy: { createdAt: 'asc' },
+  });
+
+  let decision = null;
+  // If no conversations, trigger initial greeting
+  if (conversations.length === 0) {
+    decision = await processBrainDecisionSafe({
+      userId: user.id,
+      triggerType: 'initial_contact',
+      modelConfigId: modelConfigId || undefined,
+    });
+
+    if (decision.replyTexts.length > 0) {
+      if (liveMode) {
+        // Live mode: send via real gateway (device auto-allocated)
+        for (const text of decision.replyTexts) {
+          await sendOutboundMessage({
+            userId: user.id,
+            content: text,
+            decisionId: decision.decisionId,
+          });
+        }
+      } else {
+        // Simulator mode: record each message as separate conversation
+        for (const text of decision.replyTexts) {
+          const outConv = await prisma.unionConversation.create({
+            data: {
+              userId: user.id,
+              direction: 'outbound',
+              content: text,
+              decisionId: decision.decisionId,
+              sendStatus: 'delivered',
+            },
+          });
+
+          // Trace: AI decision for initial greeting
+          writeTrace({
+            conversationId: outConv.id,
+            stage: 'ai_decision',
+            status: 'success',
+            latencyMs: decision.latencyMs,
+            metadata: {
+              decisionId: decision.decisionId,
+              action: decision.action,
+              confidence: decision.confidence,
+              modelUsed: decision.modelUsed,
+              simulated: true,
+            },
+          });
+          // Trace: device stage skipped in simulator
+          writeTrace({
+            conversationId: outConv.id,
+            stage: 'device_sent',
+            status: 'skipped',
+            metadata: { reason: 'simulator_mode' },
+          });
+        }
+      }
+
+      conversations = await prisma.unionConversation.findMany({
+        where: { userId: user.id },
+        orderBy: { createdAt: 'asc' },
+      });
+    }
+  }
+
+  success(ctx, {
+    id: user.id,
+    userId: user.id,
+    userStatus: user.status,
+    phase: user.phase,
+    messages: conversations.map((c) => ({
+      direction: c.direction,
+      content: c.content,
+      createdAt: c.createdAt.toISOString(),
+    })),
+    createdAt: user.createdAt.toISOString(),
+    initialDecision: decision ? {
+      action: decision.action,
+      confidence: decision.confidence,
+      reasoning: decision.reasoning,
+      modelUsed: decision.modelUsed,
+      tokenUsage: decision.tokenUsage,
+      latencyMs: decision.latencyMs,
+      assembledPrompt: decision.assembledPrompt,
+      rawOutput: decision.rawOutput,
+    } : null,
+  }, 201);
+});
+
+/** POST /send — Simulate user sending message (works for both test and real users) */
+simulatorRouter.post('/send', requirePermission('union.simulator.use'), async (ctx) => {
+  const { sessionId, message, modelConfigId, liveMode } = (ctx.request.body as any) ?? {};
+  if (!sessionId || !message) throw AppError.badRequest('sessionId and message are required');
+
+  const user = await prisma.unionUser.findUnique({ where: { id: sessionId } });
+  if (!user) throw AppError.notFound('User not found');
+
+  // Record user message
+  const inboundConv = await prisma.unionConversation.create({
+    data: {
+      userId: user.id,
+      direction: 'inbound',
+      content: message,
+      sendStatus: 'delivered',
+    },
+  });
+
+  // Trace: inbound received (simulator)
+  writeTrace({
+    conversationId: inboundConv.id,
+    stage: 'inbound_received',
+    status: 'success',
+    metadata: { simulated: true },
+  });
+
+  // If operator has taken over, skip Brain Engine — just record inbound
+  if (user.isTakenOver) {
+    writeTrace({
+      conversationId: inboundConv.id,
+      stage: 'ai_skipped',
+      status: 'success',
+      metadata: { reason: 'operator_takeover', simulated: true },
+    });
+
+    success(ctx, {
+      userMessage: { content: message, createdAt: new Date().toISOString() },
+      aiResponse: null,
+      newStatus: user.status,
+      takenOver: true,
+    });
+    return;
+  }
+
+  // Call brain engine directly (bypass gateway)
+  const brainStart = Date.now();
+  const decision = await processBrainDecisionSafe({
+    userId: user.id,
+    triggerType: 'user_reply',
+    userMessage: message,
+    modelConfigId: modelConfigId || undefined,
+  });
+
+  // Trace: AI triggered
+  writeTrace({
+    conversationId: inboundConv.id,
+    stage: 'ai_triggered',
+    status: 'success',
+    latencyMs: Date.now() - brainStart,
+    metadata: {
+      decisionId: decision.decisionId,
+      action: decision.action,
+      confidence: decision.confidence,
+      modelUsed: decision.modelUsed,
+      simulated: true,
+    },
+  });
+
+  // Record AI response
+  let outConv = null;
+  if (decision.replyTexts.length > 0) {
+    if (liveMode) {
+      // Live mode: send via real gateway (device auto-allocated)
+      for (const text of decision.replyTexts) {
+        await sendOutboundMessage({
+          userId: user.id,
+          content: text,
+          decisionId: decision.decisionId,
+          inboundConversationId: inboundConv.id,
+        });
+      }
+      // Fetch the last outbound conversation created by sendOutboundMessage
+      outConv = await prisma.unionConversation.findFirst({
+        where: { userId: user.id, direction: 'outbound' },
+        orderBy: { createdAt: 'desc' },
+      });
+    } else {
+      // Simulator mode: record each message as separate conversation
+      for (const text of decision.replyTexts) {
+        outConv = await prisma.unionConversation.create({
+          data: {
+            userId: user.id,
+            direction: 'outbound',
+            content: text,
+            decisionId: decision.decisionId,
+            sendStatus: 'delivered',
+          },
+        });
+
+        // Trace: AI decision on outbound
+        writeTrace({
+          conversationId: outConv.id,
+          stage: 'ai_decision',
+          status: 'success',
+          latencyMs: decision.latencyMs,
+          metadata: {
+            decisionId: decision.decisionId,
+            action: decision.action,
+            confidence: decision.confidence,
+            modelUsed: decision.modelUsed,
+            simulated: true,
+          },
+        });
+        // Trace: device skipped in simulator
+        writeTrace({
+          conversationId: outConv.id,
+          stage: 'device_sent',
+          status: 'skipped',
+          metadata: { reason: 'simulator_mode' },
+        });
+      }
+    }
+  }
+
+  // Update user status if needed
+  let newStatus = user.status;
+  if (decision.action === 'mark_converted') {
+    await prisma.unionUser.update({
+      where: { id: user.id },
+      data: { status: 'converted', convertedAt: new Date() },
+    });
+    newStatus = 'converted';
+  } else if (user.status === 'pending_contact') {
+    await prisma.unionUser.update({
+      where: { id: user.id },
+      data: { status: 'in_conversation' },
+    });
+    newStatus = 'in_conversation';
+  }
+
+  success(ctx, {
+    userMessage: { content: message, createdAt: new Date().toISOString() },
+    aiResponse: {
+      content: decision.replyTexts.join('\n'),
+      contents: decision.replyTexts,
+      createdAt: new Date().toISOString(),
+      decision: {
+        action: decision.action,
+        confidence: decision.confidence,
+        reasoning: decision.reasoning,
+        modelUsed: decision.modelUsed,
+        tokenUsage: decision.tokenUsage,
+        latencyMs: decision.latencyMs,
+        assembledPrompt: decision.assembledPrompt,
+        rawOutput: decision.rawOutput,
+      },
+    },
+    newStatus,
+  });
+});
+
+/** POST /fast-forward — Time fast-forward */
+simulatorRouter.post('/fast-forward', requirePermission('union.simulator.use'), async (ctx) => {
+  const { sessionId, hours = 24 } = (ctx.request.body as any) ?? {};
+  if (!sessionId) throw AppError.badRequest('sessionId is required');
+
+  const user = await prisma.unionUser.findUnique({ where: { id: sessionId } });
+  if (!user) throw AppError.notFound('Session not found');
+
+  // Trigger scheduled followup
+  const decision = await processBrainDecisionSafe({
+    userId: user.id,
+    triggerType: 'scheduled_followup',
+  });
+
+  if (decision.replyTexts.length > 0) {
+    for (const text of decision.replyTexts) {
+      await prisma.unionConversation.create({
+        data: {
+          userId: user.id,
+          direction: 'outbound',
+          content: text,
+          decisionId: decision.decisionId,
+          sendStatus: 'delivered',
+        },
+      });
+    }
+  }
+
+  const conversations = await prisma.unionConversation.findMany({
+    where: { userId: user.id },
+    orderBy: { createdAt: 'asc' },
+  });
+
+  success(ctx, {
+    id: user.id,
+    userId: user.id,
+    userStatus: user.status,
+    phase: user.phase,
+    messages: conversations.map((c) => ({
+      direction: c.direction,
+      content: c.content,
+      createdAt: c.createdAt.toISOString(),
+    })),
+    createdAt: user.createdAt.toISOString(),
+  });
+});
+
+/** POST /regenerate — Regenerate last AI response (retry failed LLM call) */
+simulatorRouter.post('/regenerate', requirePermission('union.simulator.use'), async (ctx) => {
+  const { sessionId, modelConfigId, liveMode } = (ctx.request.body as any) ?? {};
+  if (!sessionId) throw AppError.badRequest('sessionId is required');
+
+  const user = await prisma.unionUser.findUnique({ where: { id: sessionId } });
+  if (!user) throw AppError.notFound('User not found');
+
+  // 1. Find the last inbound message
+  const lastInbound = await prisma.unionConversation.findFirst({
+    where: { userId: sessionId, direction: 'inbound' },
+    orderBy: { createdAt: 'desc' },
+  });
+  if (!lastInbound) throw AppError.badRequest('No user message found to regenerate from');
+
+  // 2. Delete outbound messages after the last inbound (the failed/old AI responses)
+  await prisma.unionConversation.deleteMany({
+    where: {
+      userId: sessionId,
+      direction: 'outbound',
+      createdAt: { gte: lastInbound.createdAt },
+    },
+  });
+
+  // 3. Re-run brain engine
+  const brainStart = Date.now();
+  const decision = await processBrainDecisionSafe({
+    userId: sessionId,
+    triggerType: 'user_reply',
+    userMessage: lastInbound.content,
+    modelConfigId: modelConfigId || undefined,
+  });
+
+  // Trace: AI triggered (regenerate)
+  writeTrace({
+    conversationId: lastInbound.id,
+    stage: 'ai_triggered',
+    status: 'success',
+    latencyMs: Date.now() - brainStart,
+    metadata: {
+      decisionId: decision.decisionId,
+      action: decision.action,
+      confidence: decision.confidence,
+      modelUsed: decision.modelUsed,
+      simulated: true,
+      regenerated: true,
+    },
+  });
+
+  // 4. Record new AI response
+  let outConv = null;
+  if (decision.replyTexts.length > 0) {
+    if (liveMode) {
+      for (const text of decision.replyTexts) {
+        await sendOutboundMessage({
+          userId: user.id,
+          content: text,
+          decisionId: decision.decisionId,
+          inboundConversationId: lastInbound.id,
+        });
+      }
+      outConv = await prisma.unionConversation.findFirst({
+        where: { userId: user.id, direction: 'outbound' },
+        orderBy: { createdAt: 'desc' },
+      });
+    } else {
+      for (const text of decision.replyTexts) {
+        outConv = await prisma.unionConversation.create({
+          data: {
+            userId: user.id,
+            direction: 'outbound',
+            content: text,
+            decisionId: decision.decisionId,
+            sendStatus: 'delivered',
+          },
+        });
+
+        writeTrace({
+          conversationId: outConv.id,
+          stage: 'ai_decision',
+          status: 'success',
+          latencyMs: decision.latencyMs,
+          metadata: {
+            decisionId: decision.decisionId,
+            action: decision.action,
+            confidence: decision.confidence,
+            modelUsed: decision.modelUsed,
+            simulated: true,
+            regenerated: true,
+          },
+        });
+        writeTrace({
+          conversationId: outConv.id,
+          stage: 'device_sent',
+          status: 'skipped',
+          metadata: { reason: 'simulator_mode' },
+        });
+      }
+    }
+  }
+
+  success(ctx, {
+    aiResponse: {
+      content: decision.replyTexts.join('\n'),
+      contents: decision.replyTexts,
+      createdAt: new Date().toISOString(),
+      decision: {
+        action: decision.action,
+        confidence: decision.confidence,
+        reasoning: decision.reasoning,
+        modelUsed: decision.modelUsed,
+        tokenUsage: decision.tokenUsage,
+        latencyMs: decision.latencyMs,
+        assembledPrompt: decision.assembledPrompt,
+        rawOutput: decision.rawOutput,
+      },
+    },
+  });
+});
+
+/** POST /reset — Reset session */
+simulatorRouter.post('/reset', requirePermission('union.simulator.use'), async (ctx) => {
+  const { sessionId } = (ctx.request.body as any) ?? {};
+  if (!sessionId) throw AppError.badRequest('sessionId is required');
+
+  await prisma.unionConversation.deleteMany({ where: { userId: sessionId } });
+  await prisma.unionDecisionLog.deleteMany({ where: { userId: sessionId } });
+  await prisma.unionUser.update({
+    where: { id: sessionId },
+    data: { status: 'pending_contact', convertedAt: null, lastContactAt: null },
+  });
+
+  success(ctx, { message: 'Session reset' });
+});
+
+/** POST /operator-send — Operator sends message on behalf of AI (bypasses Brain Engine) */
+simulatorRouter.post('/operator-send', requirePermission('union.simulator.use'), async (ctx) => {
+  const { userId, message, liveMode } = (ctx.request.body as any) ?? {};
+  if (!userId || !message) throw AppError.badRequest('userId and message are required');
+
+  const user = await prisma.unionUser.findUnique({ where: { id: userId } });
+  if (!user) throw AppError.notFound('User not found');
+  if (!user.isTakenOver) throw AppError.badRequest('User is not in takeover mode');
+
+  if (liveMode) {
+    // Live mode: send via real gateway
+    await sendOutboundMessage({ userId, content: message });
+    // Mark the conversation as manual
+    const lastOutbound = await prisma.unionConversation.findFirst({
+      where: { userId, direction: 'outbound' },
+      orderBy: { createdAt: 'desc' },
+    });
+    if (lastOutbound) {
+      await prisma.unionConversation.update({
+        where: { id: lastOutbound.id },
+        data: { isManual: true },
+      });
+    }
+  } else {
+    // Simulator mode: record directly
+    const outConv = await prisma.unionConversation.create({
+      data: {
+        userId,
+        direction: 'outbound',
+        content: message,
+        sendStatus: 'delivered',
+        isManual: true,
+      },
+    });
+
+    writeTrace({
+      conversationId: outConv.id,
+      stage: 'operator_sent',
+      status: 'success',
+      metadata: { simulated: true },
+    });
+  }
+
+  // Update lastContactAt
+  await prisma.unionUser.update({
+    where: { id: userId },
+    data: { lastContactAt: new Date() },
+  });
+
+  success(ctx, { sent: true, content: message });
+});
+
+/** POST /takeover — Toggle operator takeover mode */
+simulatorRouter.post('/takeover', requirePermission('union.simulator.use'), async (ctx) => {
+  const { userId, takeover } = (ctx.request.body as any) ?? {};
+  if (!userId || typeof takeover !== 'boolean') throw AppError.badRequest('userId and takeover (boolean) are required');
+
+  const user = await prisma.unionUser.findUnique({ where: { id: userId } });
+  if (!user) throw AppError.notFound('User not found');
+
+  await prisma.unionUser.update({
+    where: { id: userId },
+    data: {
+      isTakenOver: takeover,
+      takenOverAt: takeover ? new Date() : null,
+    },
+  });
+
+  await prisma.unionStatusLog.create({
+    data: {
+      userId,
+      fromStatus: user.status,
+      toStatus: user.status,
+      trigger: takeover ? 'operator_takeover' : 'operator_release',
+    },
+  });
+
+  success(ctx, { userId, isTakenOver: takeover });
+});
+
+/** GET /session/:id — Get session detail */
+simulatorRouter.get('/session/:id', requirePermission('union.simulator.use'), async (ctx) => {
+  const { id } = ctx.params;
+  const user = await prisma.unionUser.findUnique({ where: { id } });
+  if (!user) throw AppError.notFound('Session not found');
+
+  const conversations = await prisma.unionConversation.findMany({
+    where: { userId: id },
+    orderBy: { createdAt: 'asc' },
+  });
+
+  success(ctx, {
+    id: user.id,
+    userId: user.id,
+    userStatus: user.status,
+    phase: user.phase,
+    isTakenOver: user.isTakenOver,
+    messages: conversations.map((c) => ({
+      id: c.id,
+      direction: c.direction,
+      content: c.content,
+      createdAt: c.createdAt.toISOString(),
+      sendStatus: c.sendStatus,
+      isManual: c.isManual,
+    })),
+    createdAt: user.createdAt.toISOString(),
+  });
+});
