+import { PageContainer, ProCard } from '@ant-design/pro-components';
+import { useAccess, useParams, history } from '@umijs/max';
+import { useRequest } from 'ahooks';
+import { Descriptions, Spin, Tabs, Tag, Table, Timeline, Space, Button, Input, List, Typography, Collapse, message, Steps, Tooltip, Switch, Alert, Popconfirm, Select, Badge, Modal } from 'antd';
+import { NodeIndexOutlined, PlusOutlined, ClockCircleOutlined } from '@ant-design/icons';
+import React, { useState, useMemo, useEffect } from 'react';
+import { getUnionUser, simulatorSend, createSimulatorSession, simulatorReset, simulatorRegenerate, getMessageTraces, addUnionUserTag, removeUnionUserTag, transitionUnionUserStatus, operatorSend, toggleTakeover } from '@/api/union';
+import type { ConversationTrace } from '@/api/union';
+import ChatPanel from '@/components/ChatPanel';
+import type { ChatMessage } from '@/components/ChatPanel';
+import dayjs from 'dayjs';
+
+const { Text } = Typography;
+
+const STATUS_MAP: Record<string, { text: string; color: string }> = {
+  pending_device: { text: '待分配设备', color: 'default' },
+  pending_contact: { text: '待联系', color: 'default' },
+  in_conversation: { text: '对话中', color: 'processing' },
+  paused: { text: '暂停', color: 'warning' },
+  silent: { text: '沉默', color: 'warning' },
+  converted: { text: '已转化', color: 'success' },
+  opted_out: { text: '已退出', color: 'default' },
+  invalid_number: { text: '无效号码', color: 'error' },
+  rejected: { text: '已拒绝', color: 'error' },
+  dead: { text: '已失效', color: 'error' },
+};
+
+const SEND_STATUS_MAP: Record<string, { text: string; color: string }> = {
+  pending: { text: '待发送', color: 'default' },
+  sent: { text: '已发送', color: 'processing' },
+  delivered: { text: '已送达', color: 'success' },
+  failed: { text: '失败', color: 'error' },
+};
+
+const SOURCE_MAP: Record<string, string> = {
+  tiktok: 'TikTok',
+  facebook: 'Facebook',
+  manual: '手动添加',
+  api: 'API',
+  csv: 'CSV 导入',
+  campaign: '活动',
+  other: '其他',
+};
+
+const STATE_TRANSITIONS: Record<string, string[]> = {
+  pending_device: ['pending_contact'],
+  pending_contact: ['in_conversation'],
+  in_conversation: ['paused', 'silent', 'converted', 'opted_out', 'dead'],
+  paused: ['in_conversation', 'dead'],
+  silent: ['in_conversation', 'dead'],
+};
+
+const STAGE_LABELS: Record<string, string> = {
+  ai_decision: 'AI 决策',
+  device_allocated: '设备分配',
+  queue_created: '消息入队',
+  ws_pushed: 'WebSocket 推送',
+  device_sent: '设备已发送',
+  sms_delivered: '短信已送达',
+  send_failed: '发送失败',
+  inbound_received: '收到上行消息',
+  user_identified: '用户匹配',
+  ai_triggered: '触发 AI 回复',
+  ai_skipped: 'AI 已跳过',
+  operator_sent: '运营手动发送',
+};
+
+const stageToStepStatus = (s: string): 'finish' | 'error' | 'wait' =>
+  s === 'success' ? 'finish' : s === 'failed' ? 'error' : 'wait';
+
+function formatTraceDesc(trace: { stage: string; latencyMs: number | null; metadata: Record<string, any> | null }) {
+  const parts: string[] = [];
+  if (trace.latencyMs != null) parts.push(`${trace.latencyMs}ms`);
+  const m = trace.metadata;
+  if (!m) return parts.join(' · ');
+  if (m.modelUsed) parts.push(`模型: ${m.modelUsed}`);
+  if (m.confidence != null) parts.push(`置信度: ${m.confidence}`);
+  if (m.action) parts.push(`动作: ${m.action}`);
+  if (m.deviceId) parts.push(`设备: ${m.deviceId}`);
+  if (m.failReason) parts.push(`原因: ${m.failReason}`);
+  if (m.reason) parts.push(m.reason);
