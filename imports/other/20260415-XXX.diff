index 00000000..80db8b06
--- /dev/null
+++ b/apps/minerva-server/src/routes/union/analytics.ts
@@ -0,0 +1,105 @@
+import Router from '@koa/router';
+import { prisma } from '../../utils/prisma.js';
+import { success } from '../../utils/response.js';
+import { authMiddleware, requirePermission } from '../../middlewares/auth.js';
+import { getDashboardMetrics, getFunnelData } from '../../services/union/analytics-service.js';
+
+export const analyticsRouter = new Router();
+analyticsRouter.use(authMiddleware);
+
+/** GET /dashboard — Dashboard overview */
+analyticsRouter.get('/dashboard', requirePermission('union.analytics.read'), async (ctx) => {
+  const { startDate, endDate } = ctx.query as { startDate?: string; endDate?: string };
+  const data = await getDashboardMetrics(startDate, endDate);
+  success(ctx, data);
+});
+
+/** GET /funnel — Funnel analysis */
+analyticsRouter.get('/funnel', requirePermission('union.analytics.read'), async (ctx) => {
+  const { startDate, endDate, source, abGroup } = ctx.query as Record<string, string>;
+  if (!startDate || !endDate) {
+    ctx.throw(400, 'startDate and endDate are required');
+  }
+  const data = await getFunnelData({ startDate, endDate, source, abGroup });
+  success(ctx, data);
+});
+
+/** GET /trend — Trend data */
+analyticsRouter.get('/trend', requirePermission('union.analytics.read'), async (ctx) => {
+  const { startDate, endDate, granularity = 'day' } = ctx.query as Record<string, string>;
+  if (!startDate || !endDate) {
+    ctx.throw(400, 'startDate and endDate are required');
+  }
+
+  // Generate date series and count metrics per period
+  const start = new Date(startDate);
+  const end = new Date(endDate);
+  const series: Array<{ metric: string; data: Array<{ date: string; value: number }> }> = [];
+
+  for (const metric of ['new_users', 'contacted', 'replied', 'converted']) {
+    const data: Array<{ date: string; value: number }> = [];
+    const current = new Date(start);
+    while (current <= end) {
+      const dayStart = new Date(current);
+      const dayEnd = new Date(current);
+      dayEnd.setDate(dayEnd.getDate() + 1);
+
+      let count = 0;
+      if (metric === 'new_users') {
+        count = await prisma.unionUser.count({
+          where: { isTest: false, createdAt: { gte: dayStart, lt: dayEnd } },
+        });
+      } else if (metric === 'contacted') {
+        count = await prisma.unionUser.count({
+          where: { isTest: false, lastContactAt: { gte: dayStart, lt: dayEnd } },
+        });
+      } else if (metric === 'replied') {
+        const groups = await prisma.unionConversation.groupBy({
+          by: ['userId'],
+          where: {
+            direction: 'inbound',
+            createdAt: { gte: dayStart, lt: dayEnd },
+            user: { isTest: false },
+          },
+        });
+        count = groups.length;
+      } else if (metric === 'converted') {
+        count = await prisma.unionUser.count({
+          where: { isTest: false, convertedAt: { gte: dayStart, lt: dayEnd } },
+        });
+      }
+
+      data.push({ date: dayStart.toISOString().split('T')[0], value: count });
+      current.setDate(current.getDate() + 1);
+    }
+    series.push({ metric, data });
+  }
+
+  success(ctx, { series });
+});
+
+/** GET /ab-test/:experimentId — AB test results */
+analyticsRouter.get('/ab-test/:experimentId', requirePermission('union.analytics.read'), async (ctx) => {
+  const { experimentId } = ctx.params;
+  const experiment = await prisma.unionExperiment.findUnique({ where: { id: experimentId } });
+  if (!experiment) { ctx.throw(404, 'Experiment not found'); return; }
+
+  const variants = (experiment.variants as any[]) || [];
+  const results = await Promise.all(
+    variants.map(async (v: any) => {
+      const users = await prisma.unionUser.count({ where: { abGroup: v.name, isTest: false } });
+      const converted = await prisma.unionUser.count({
+        where: { abGroup: v.name, status: 'converted', isTest: false },
+      });
+      return {
+        name: v.name || v.templateId,
+        userCount: users,
+        replyRate: 0,
+        conversionRate: users > 0 ? converted / users : 0,
+        avgResponseTime: 0,
+      };
+    }),
+  );
+
+  success(ctx, { experimentId, variants: results });
+});
