@@ -0,0 +1,172 @@
+import { Button, Input, List, Space, Spin, Tag, Tooltip, Typography } from 'antd';
+import { ReloadOutlined } from '@ant-design/icons';
+import React, { useEffect, useMemo, useRef } from 'react';
+
+const { TextArea } = Input;
+const { Text } = Typography;
+
+export interface ChatMessage {
+  id?: string;
+  direction: string;
+  content: string;
+  createdAt: string;
+  sendStatus?: string;
+  [key: string]: any;
+}
+
+export interface QuickReply {
+  label: string;
+  text: string;
+}
+
+export interface ChatPanelProps {
+  messages: ChatMessage[];
+  sending?: boolean;
+  regenerating?: boolean;
+  input: string;
+  onInputChange: (value: string) => void;
+  onSend: (text?: string) => void;
+  onRegenerate?: () => void;
+  disabled?: boolean;
+  placeholder?: string;
+  /** 快捷回复按钮列表 */
+  quickReplies?: QuickReply[];
+  /** 自定义消息标签（覆盖默认的 用户/AI 标签） */
+  renderTag?: (msg: ChatMessage) => React.ReactNode;
+  /** 每条消息气泡内底部的额外内容（如时间戳、sendStatus） */
+  renderBubbleFooter?: (msg: ChatMessage) => React.ReactNode;
+  /** 每条消息气泡旁的额外操作（如 trace 按钮） */
+  renderMessageExtra?: (msg: ChatMessage) => React.ReactNode;
+  /** 每条消息下方的展开内容（如 trace Steps） */
+  renderMessageExpanded?: (msg: ChatMessage) => React.ReactNode;
+}
+
+const ChatPanel: React.FC<ChatPanelProps> = ({
+  messages,
+  sending,
+  regenerating,
+  input,
+  onInputChange,
+  onSend,
+  onRegenerate,
+  disabled,
+  placeholder,
+  quickReplies,
+  renderTag,
+  renderBubbleFooter,
+  renderMessageExtra,
+  renderMessageExpanded,
+}) => {
+  const chatContainerRef = useRef<HTMLDivElement>(null);
+
+  useEffect(() => {
+    const el = chatContainerRef.current;
+    if (el) el.scrollTop = el.scrollHeight;
+  }, [messages, sending, regenerating]);
+
+  const handleSend = (text?: string) => {
+    const msg = text || input;
+    if (!msg.trim()) return;
+    onSend(msg);
+  };
+
+  // Find the last outbound message index for showing the regenerate button
+  const lastOutboundIdx = useMemo(() => {
+    for (let i = messages.length - 1; i >= 0; i--) {
+      if (messages[i].direction === 'outbound') return i;
+    }
+    return -1;
+  }, [messages]);
+
+  // Show regenerate in two cases:
+  // 1. Last message is outbound (AI responded, user wants to regenerate)
+  // 2. Last message is inbound (AI failed to respond, user wants to retry)
+  const lastMsg = messages[messages.length - 1];
+  const showRegenerateOnOutbound = onRegenerate && lastOutboundIdx >= 0 && lastOutboundIdx === messages.length - 1;
+  const showRegenerateOnInbound = onRegenerate && lastMsg?.direction === 'inbound';
+
+  return (
+    <div>
+      <div ref={chatContainerRef} style={{ height: 460, overflow: 'auto', marginBottom: 12, padding: '0 12px' }}>
+        <List
+          dataSource={messages}
+          locale={{ emptyText: '暂无对话记录' }}
+          renderItem={(msg: ChatMessage, index: number) => (
+            <List.Item style={{ justifyContent: msg.direction === 'inbound' ? 'flex-end' : 'flex-start', border: 'none', padding: '6px 0' }}>
+              <div style={{ maxWidth: '70%', display: 'flex', flexDirection: 'column', alignItems: msg.direction === 'inbound' ? 'flex-end' : 'flex-start' }}>
+                <div style={{ minWidth: 0, display: 'flex', flexDirection: msg.direction === 'inbound' ? 'row-reverse' : 'row', gap: 8, alignItems: 'flex-start' }}>
+                  {renderTag ? renderTag(msg) : (
+                    <Tag color={msg.direction === 'inbound' ? 'blue' : 'green'} style={{ flexShrink: 0 }}>
+                      {msg.direction === 'inbound' ? '用户' : 'AI'}
+                    </Tag>
+                  )}
+                  <div style={{ background: msg.direction === 'inbound' ? '#e6f7ff' : '#f6ffed', padding: '8px 12px', borderRadius: 8, wordBreak: 'break-word', overflow: 'hidden' }}>
+                    <Text>{msg.content}</Text>
+                    {renderBubbleFooter?.(msg)}
+                  </div>
+                  {renderMessageExtra?.(msg)}
+                  {showRegenerateOnOutbound && index === lastOutboundIdx && (
+                    <Tooltip title="重新生成">
+                      <Button
+                        type="text"
+                        size="small"
+                        icon={<ReloadOutlined />}
+                        loading={regenerating}
+                        onClick={onRegenerate}
+                        style={{ color: '#999' }}
+                      />
+                    </Tooltip>
+                  )}
+                </div>
+                {renderMessageExpanded?.(msg)}
+              </div>
+            </List.Item>
+          )}
+        />
+        {showRegenerateOnInbound && !sending && !regenerating && (
+          <div style={{ display: 'flex', gap: 8, alignItems: 'center', padding: '6px 0' }}>
+            <Tag color="orange" style={{ flexShrink: 0 }}>未回复</Tag>
+            <Text type="secondary">AI 未生成回复</Text>
+            <Tooltip title="触发 AI 生成回复">
+              <Button
+                type="primary"
+                size="small"
+                icon={<ReloadOutlined />}
+                loading={regenerating}
+                onClick={onRegenerate}
+              >
+                生成回复
+              </Button>
+            </Tooltip>
+          </div>
+        )}
+        {(sending || regenerating) && (
+          <div style={{ display: 'flex', gap: 8, alignItems: 'flex-start', padding: '6px 0' }}>
+            <Tag color="green" style={{ flexShrink: 0 }}>AI</Tag>
+            <div style={{ background: '#f6ffed', padding: '8px 12px', borderRadius: 8 }}>
+              <Text type="secondary"><Spin size="small" /> {regenerating ? '重新生成中...' : '思考中...'}</Text>
+            </div>
+          </div>
+        )}
+      </div>
+      <TextArea
+        rows={2}
+        value={input}
+        onChange={(e) => onInputChange(e.target.value)}
+        onPressEnter={(e) => { if (!e.shiftKey) { e.preventDefault(); handleSend(); } }}
+        placeholder={placeholder || '输入消息...'}
+        disabled={disabled}
+      />
+      <Space style={{ marginTop: 8 }} wrap>
+        <Button type="primary" onClick={() => handleSend()} loading={sending} disabled={disabled}>发送</Button>
+        {quickReplies?.map((qr) => (
+          <Button key={qr.label} size="small" onClick={() => handleSend(qr.text)} disabled={disabled}>
+            {qr.label}
+          </Button>
+        ))}
+      </Space>
+    </div>
+  );
+};
+
+export default ChatPanel;
