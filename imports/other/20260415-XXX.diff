@@ -0,0 +1,71 @@
+import Router from '@koa/router';
+import { prisma } from '../../utils/prisma.js';
+import { success } from '../../utils/response.js';
+import { AppError } from '../../utils/AppError.js';
+import { authMiddleware, requirePermission } from '../../middlewares/auth.js';
+import { createUnionAlertRuleRequestSchema, updateUnionAlertRuleRequestSchema } from '@sitin/minerva-schemas';
+
+export const alertsRouter = new Router();
+alertsRouter.use(authMiddleware);
+
+/** GET /rules — List alert rules */
+alertsRouter.get('/rules', requirePermission('union.system.alert'), async (ctx) => {
+  const rules = await prisma.unionAlertRule.findMany({ orderBy: { createdAt: 'desc' } });
+  success(ctx, rules);
+});
+
+/** POST /rules — Create alert rule */
+alertsRouter.post('/rules', requirePermission('union.system.alert'), async (ctx) => {
+  const body = createUnionAlertRuleRequestSchema.parse(ctx.request.body);
+  const rule = await prisma.unionAlertRule.create({
+    data: {
+      name: body.name,
+      condition: body.condition,
+      threshold: body.threshold,
+      level: body.level,
+      silenceMinutes: body.silenceMinutes,
+    },
+  });
+  success(ctx, rule, 201);
+});
+
+/** PATCH /rules/:id — Update alert rule */
+alertsRouter.patch('/rules/:id', requirePermission('union.system.alert'), async (ctx) => {
+  const { id } = ctx.params;
+  const body = updateUnionAlertRuleRequestSchema.parse(ctx.request.body);
+  const rule = await prisma.unionAlertRule.findUnique({ where: { id } });
+  if (!rule) throw AppError.notFound('Alert rule not found');
+
+  const updated = await prisma.unionAlertRule.update({ where: { id }, data: body });
+  success(ctx, updated);
+});
+
+/** DELETE /rules/:id — Delete alert rule */
+alertsRouter.delete('/rules/:id', requirePermission('union.system.alert'), async (ctx) => {
+  const { id } = ctx.params;
+  await prisma.unionAlertRule.delete({ where: { id } });
+  success(ctx, { message: 'Deleted' });
+});
+
+/** GET /logs — List alert logs */
+alertsRouter.get('/logs', requirePermission('union.system.alert'), async (ctx) => {
+  const { page = '1', pageSize = '20', level, ruleId, resolved } = ctx.query as Record<string, string>;
+  const where: any = {};
+  if (level) where.level = level;
+  if (ruleId) where.ruleId = ruleId;
+  if (resolved === 'true') where.resolvedAt = { not: null };
+  if (resolved === 'false') where.resolvedAt = null;
+
+  const [items, total] = await Promise.all([
+    prisma.unionAlertLog.findMany({
+      where,
+      orderBy: { createdAt: 'desc' },
+      skip: (Number(page) - 1) * Number(pageSize),
+      take: Number(pageSize),
+      include: { rule: { select: { name: true } } },
+    }),
+    prisma.unionAlertLog.count({ where }),
+  ]);
+
+  success(ctx, { items, total, page: Number(page), pageSize: Number(pageSize) });
+});
