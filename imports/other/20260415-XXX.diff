+import { PageContainer, ProTable } from '@ant-design/pro-components';
+import type { ProColumns, ActionType } from '@ant-design/pro-components';
+import { useAccess, history } from '@umijs/max';
+import { Button, Tag, Popconfirm, message } from 'antd';
+import { PlusOutlined } from '@ant-design/icons';
+import React, { useRef } from 'react';
+import { listUnionTemplates, reviewUnionTemplate } from '@/api/union';
+
+type TemplateItem = {
+  id: string;
+  phase: string;
+  scene: string;
+  versionCode: string;
+  status: string;
+  content: string;
+  createdAt: string;
+};
+
+const statusEnum: Record<string, { text: string; status: string }> = {
+  draft: { text: '草稿', status: 'Default' },
+  reviewing: { text: '审核中', status: 'Processing' },
+  published: { text: '已发布', status: 'Success' },
+  archived: { text: '已归档', status: 'Default' },
+};
+
+const UnionTemplateList: React.FC = () => {
+  const access = useAccess();
+  const actionRef = useRef<ActionType>(null);
+
+  const handleReview = async (id: string, action: string) => {
+    await reviewUnionTemplate(id, { action });
+    message.success('操作成功');
+    actionRef.current?.reload();
+  };
+
+  const columns: ProColumns<TemplateItem>[] = [
+    { title: '阶段', dataIndex: 'phase', valueType: 'select' },
+    { title: '场景', dataIndex: 'scene', hideInSearch: true },
+    { title: '版本号', dataIndex: 'versionCode', hideInSearch: true },
+    { title: '状态', dataIndex: 'status', valueType: 'select', valueEnum: statusEnum },
+    { title: '内容预览', dataIndex: 'content', ellipsis: true, hideInSearch: true, width: 300 },
+    { title: '创建时间', dataIndex: 'createdAt', valueType: 'dateTime', hideInSearch: true, sorter: true },
+    {
+      title: '操作',
+      valueType: 'option',
+      render: (_, record) => [
+        <a key="detail" onClick={() => history.push(`/union/templates/editor?id=${record.id}&readonly=1`)}>详情</a>,
+        record.status === 'draft' && (
+          <a key="edit" onClick={() => history.push(`/union/templates/editor?id=${record.id}`)}>编辑</a>
+        ),
+        record.status === 'draft' && (
+          <a key="submit" onClick={() => handleReview(record.id, 'submit')}>提交审核</a>
+        ),
+        record.status === 'reviewing' && (
+          <a key="edit-reviewing" onClick={() => history.push(`/union/templates/editor?id=${record.id}`)}>编辑</a>
+        ),
+        record.status === 'reviewing' && access.canPublishUnionTemplates && (
+          <a key="approve" onClick={() => handleReview(record.id, 'approve')}>通过</a>
+        ),
+        record.status === 'reviewing' && access.canPublishUnionTemplates && (
+          <Popconfirm key="reject" title="确认驳回该模板？" onConfirm={() => handleReview(record.id, 'reject')}>
+            <a>驳回</a>
+          </Popconfirm>
+        ),
+        record.status === 'published' && access.canPublishUnionTemplates && (
+          <a key="archive" onClick={() => handleReview(record.id, 'archive')}>归档</a>
+        ),
+        record.status === 'archived' && access.canPublishUnionTemplates && (
+          <a key="rollback" onClick={() => handleReview(record.id, 'rollback')}>恢复</a>
+        ),
+      ],
+    },
+  ];
+
+  return (
+    <PageContainer content="管理各阶段话术模板，支持版本控制和审核发布流程。">
+      <ProTable<TemplateItem>
+        headerTitle="模板列表"
+        actionRef={actionRef}
+        rowKey="id"
+        columns={columns}
+        request={(async (params: any) => {
+          const res = await listUnionTemplates({
+            page: params.current,
+            pageSize: params.pageSize,
+            phase: params.phase,
+            status: params.status,
+          });
+          return { data: res.items, total: res.total, success: true };
+        }) as any}
+        toolBarRender={() => [
+          <Button
+            key="create"
+            type="primary"
+            icon={<PlusOutlined />}
+            onClick={() => history.push('/union/templates/editor')}
+          >
+            新建模板
+          </Button>,
+        ]}
+        search={{ labelWidth: 'auto' }}
+      />
+    </PageContainer>
+  );
+};
+
+export default UnionTemplateList;
