+import Router from '@koa/router';
+import { addUnionUserTagRequestSchema } from '@sitin/minerva-schemas';
+import { prisma } from '../../utils/prisma.js';
+import { success } from '../../utils/response.js';
+import { AppError } from '../../utils/AppError.js';
+import { authMiddleware, requirePermission } from '../../middlewares/auth.js';
+
+export const usersTagsRouter = new Router();
+
+usersTagsRouter.use(authMiddleware);
+
+/**
+ * GET /api/union/users-tags/:userId/tags
+ * List all tags for a user
+ */
+usersTagsRouter.get(
+  '/:userId/tags',
+  requirePermission('union.user.read'),
+  async (ctx) => {
+    const { userId } = ctx.params;
+
+    const user = await prisma.unionUser.findUnique({
+      where: { id: userId },
+      select: { id: true },
+    });
+    if (!user) {
+      throw AppError.notFound('Union user not found');
+    }
+
+    const tags = await prisma.unionUserTag.findMany({
+      where: { userId },
+      orderBy: { createdAt: 'desc' },
+    });
+
+    success(ctx, tags);
+  }
+);
+
+/**
+ * POST /api/union/users-tags/:userId/tags
+ * Add a tag to a user
+ */
+usersTagsRouter.post(
+  '/:userId/tags',
+  requirePermission('union.user.write'),
+  async (ctx) => {
+    const { userId } = ctx.params;
+    const body = addUnionUserTagRequestSchema.parse(ctx.request.body);
+
+    const user = await prisma.unionUser.findUnique({
+      where: { id: userId },
+      select: { id: true },
+    });
+    if (!user) {
+      throw AppError.notFound('Union user not found');
+    }
+
+    // Unique constraint on [userId, tagName] — catch duplicate
+    const existing = await prisma.unionUserTag.findUnique({
+      where: { userId_tagName: { userId, tagName: body.tagName } },
+    });
+    if (existing) {
+      throw AppError.conflict('Tag already exists on this user', 'TAG_EXISTS');
+    }
+
+    const tag = await prisma.unionUserTag.create({
+      data: {
+        userId,
+        tagName: body.tagName,
+        tagType: body.tagType,
+      },
+    });
+
+    success(ctx, tag, 201);
+  }
+);
+
+/**
+ * DELETE /api/union/users-tags/:userId/tags/:tagName
+ * Remove a tag from a user
+ */
+usersTagsRouter.delete(
+  '/:userId/tags/:tagName',
+  requirePermission('union.user.write'),
+  async (ctx) => {
+    const { userId, tagName } = ctx.params;
+
+    const tag = await prisma.unionUserTag.findUnique({
+      where: { userId_tagName: { userId, tagName } },
+    });
+    if (!tag) {
+      throw AppError.notFound('Tag not found on this user');
+    }
+
+    await prisma.unionUserTag.delete({
+      where: { id: tag.id },
+    });
+
+    success(ctx, { message: 'Tag removed successfully' });
+  }
+);
diff --git a/apps/minerva-server/src/routes/union/users.ts b/apps/minerva-server/src/routes/union/users.ts
new file mode 100644
index 00000000..14ecf3bc
--- /dev/null
+++ b/apps/minerva-server/src/routes/union/users.ts
@@ -0,0 +1,291 @@
+import Router from '@koa/router';
+import crypto from 'crypto';
+import {
+  unionUserListQuerySchema,
+  createUnionUserRequestSchema,
+  unionUserBatchActionSchema,
+} from '@sitin/minerva-schemas';
+import { prisma } from '../../utils/prisma.js';
+import { success } from '../../utils/response.js';
+import { AppError } from '../../utils/AppError.js';
+import { authMiddleware, requirePermission } from '../../middlewares/auth.js';
+import { launchBatchJob } from '../../services/union/batch-job-processor.js';
+
+export const usersRouter = new Router();
+
+// Apply auth middleware to all routes
+usersRouter.use(authMiddleware);
+
+/**
+ * GET /api/union/users
+ * List users with pagination, filtering, sorting
+ */
+usersRouter.get('/', requirePermission('union.user.read'), async (ctx) => {
+  const query = unionUserListQuerySchema.parse(ctx.query);
+  const { page, pageSize, sortBy, sortOrder, ...filters } = query;
+
+  const where: Record<string, unknown> = {};
+
+  if (filters.status) where.status = filters.status;
+  if (filters.phase) where.phase = filters.phase;
+  if (filters.source) where.source = filters.source;
+  if (filters.deviceId) where.deviceId = filters.deviceId;
+  if (filters.abGroup) where.abGroup = filters.abGroup;
+  if (filters.search) {
+    where.phone = { contains: filters.search };
+  }
+  if (filters.startDate || filters.endDate) {
+    where.createdAt = {
+      ...(filters.startDate ? { gte: new Date(filters.startDate) } : {}),
+      ...(filters.endDate ? { lte: new Date(filters.endDate) } : {}),
+    };
+  }
+
+  // 消息数范围筛选：先查出符合条件的 userIds，再加入 where
+  const hasMsgFilter = filters.minOutbound != null || filters.maxOutbound != null
+    || filters.minInbound != null || filters.maxInbound != null;
+
+  if (hasMsgFilter) {
+    // 用原生 SQL 子查询按消息数筛选
+    const conditions: string[] = [];
+    const params: (string | number)[] = [];
+
+    if (filters.minOutbound != null) {
+      conditions.push(`COALESCE(oc.cnt, 0) >= $${params.length + 1}`);
+      params.push(filters.minOutbound);
+    }
+    if (filters.maxOutbound != null) {
+      conditions.push(`COALESCE(oc.cnt, 0) <= $${params.length + 1}`);
+      params.push(filters.maxOutbound);
+    }
+    if (filters.minInbound != null) {
+      conditions.push(`COALESCE(ic.cnt, 0) >= $${params.length + 1}`);
+      params.push(filters.minInbound);
+    }
+    if (filters.maxInbound != null) {
+      conditions.push(`COALESCE(ic.cnt, 0) <= $${params.length + 1}`);
+      params.push(filters.maxInbound);
+    }
+
+    const sql = `
+      SELECT u.id FROM union_users u
+      LEFT JOIN (
+        SELECT user_id, COUNT(*)::int AS cnt FROM union_conversations WHERE direction = 'outbound' GROUP BY user_id
+      ) oc ON u.id = oc.user_id
+      LEFT JOIN (
+        SELECT user_id, COUNT(*)::int AS cnt FROM union_conversations WHERE direction = 'inbound' GROUP BY user_id
+      ) ic ON u.id = ic.user_id
+      WHERE ${conditions.join(' AND ')}
+    `;
+    const rows = await prisma.$queryRawUnsafe<{ id: string }[]>(sql, ...params);
+    const matchIds = rows.map((r) => r.id);
+
+    if (matchIds.length === 0) {
+      success(ctx, { items: [], total: 0, page, pageSize });
+      return;
+    }
+    where.id = { in: matchIds };
+  }
+
+  const [items, total] = await Promise.all([
+    prisma.unionUser.findMany({
+      where,
+      orderBy: [{ [sortBy]: sortOrder }, { id: 'asc' }],
+      skip: (page - 1) * pageSize,
+      take: pageSize,
+    }),
+    prisma.unionUser.count({ where }),
+  ]);
+
+  // 批量查询每个用户的发出/接收消息数
+  const userIds = items.map((u) => u.id);
+  const msgCounts = userIds.length > 0
+    ? await prisma.unionConversation.groupBy({
+        by: ['userId', 'direction'],
+        where: { userId: { in: userIds } },
+        _count: true,
+      })
+    : [];
+
+  const countMap = new Map<string, { outbound: number; inbound: number }>();
+  for (const row of msgCounts) {
+    if (!countMap.has(row.userId)) countMap.set(row.userId, { outbound: 0, inbound: 0 });
+    const entry = countMap.get(row.userId)!;
+    if (row.direction === 'outbound') entry.outbound = row._count;
+    else if (row.direction === 'inbound') entry.inbound = row._count;
+  }
+
+  const enrichedItems = items.map((u) => ({
+    ...u,
+    outboundCount: countMap.get(u.id)?.outbound ?? 0,
+    inboundCount: countMap.get(u.id)?.inbound ?? 0,
+  }));
+
+  success(ctx, { items: enrichedItems, total, page, pageSize });
+});
+
+/**
+ * GET /api/union/users/:id
+ * Get user detail with conversations, tags, status logs
+ */
+usersRouter.get('/:id', requirePermission('union.user.read'), async (ctx) => {
+  const { id } = ctx.params;
+
+  const user = await prisma.unionUser.findUnique({
+    where: { id },
+    include: {
+      conversations: {
+        orderBy: { createdAt: 'desc' },
+        take: 50,
+      },
+      tags: true,
+      statusLogs: {
+        orderBy: { createdAt: 'desc' },
+        take: 20,
+      },
+      device: {
+        select: {
+          id: true,
+          deviceId: true,
+          phoneNumber: true,
+          status: true,
+        },
+      },
+    },
+  });
+
+  if (!user) {
+    throw AppError.notFound('Union user not found');
+  }
+
+  success(ctx, user);
+});
+
+/**
+ * POST /api/union/users
+ * Create a single union user
+ */
+usersRouter.post('/', requirePermission('union.user.write'), async (ctx) => {
+  const body = createUnionUserRequestSchema.parse(ctx.request.body);
+
+  const existing = await prisma.unionUser.findUnique({
+    where: { phone: body.phone },
+  });
+
+  if (existing) {
+    throw AppError.conflict('User with this phone already exists', 'PHONE_EXISTS');
+  }
+
+  const user = await prisma.unionUser.create({
+    data: {
+      phone: body.phone,
+      source: body.source,
+      sourceDetail: body.sourceDetail,
+      refCode: crypto.randomBytes(4).toString('hex'),
+    },
+  });
+
+  success(ctx, user, 201);
+});
+
+/**
+ * POST /api/union/users/batch
+ * Batch operations: assign_device, change_status, add_tag, remove_tag
+ */
+usersRouter.post('/batch', requirePermission('union.user.write'), async (ctx) => {
+  const body = unionUserBatchActionSchema.parse(ctx.request.body);
+  const { userIds, action, params } = body;
+
+  // 定时任务：任何 action 都支持，统一创建 job 延后执行
+  const scheduledAtRaw = params?.scheduledAt as string | undefined;
+  if (scheduledAtRaw) {
+    const scheduledAt = new Date(scheduledAtRaw);
+    if (scheduledAt.getTime() <= Date.now()) {
+      throw AppError.badRequest('定时时间必须是未来时间');
+    }
+    if (userIds.length > 200) throw AppError.badRequest('单次最多对 200 个用户启动定时任务');
+    const job = await prisma.unionBatchJob.create({
+      data: {
+        action,
+        totalCount: userIds.length,
+        userIds,
+        params: params ?? undefined,
+        operatorId: (ctx.state.user as any)?.sub ?? null,
+        scheduledAt,
+      },
+    });
+    ctx.status = 202;
+    success(ctx, { action, jobId: job.id, jobStatus: 'scheduled', scheduledAt: scheduledAt.toISOString() });
+    return;
+  }
+
+  let affected = 0;
+
+  switch (action) {
+    case 'assign_device': {
+      const deviceId = params?.deviceId as string | undefined;
+      if (!deviceId) throw AppError.badRequest('params.deviceId is required');
+      const result = await prisma.unionUser.updateMany({
+        where: { id: { in: userIds } },
+        data: { deviceId },
+      });
+      affected = result.count;
+      break;
+    }
+    case 'change_status': {
+      const status = params?.status as string | undefined;
+      if (!status) throw AppError.badRequest('params.status is required');
+      const result = await prisma.unionUser.updateMany({
+        where: { id: { in: userIds } },
+        data: { status: status as any },
+      });
+      affected = result.count;
+      break;
+    }
+    case 'add_tag': {
+      const tagName = params?.tagName as string | undefined;
+      if (!tagName) throw AppError.badRequest('params.tagName is required');
+      const data = userIds.map((userId) => ({
+        userId,
+        tagName,
+        tagType: (params?.tagType as string) || 'manual',
+      }));
+      const result = await prisma.unionUserTag.createMany({
+        data,
+        skipDuplicates: true,
+      });
+      affected = result.count;
+      break;
+    }
+    case 'remove_tag': {
+      const tagName = params?.tagName as string | undefined;
+      if (!tagName) throw AppError.badRequest('params.tagName is required');
+      const result = await prisma.unionUserTag.deleteMany({
+        where: { userId: { in: userIds }, tagName },
+      });
+      affected = result.count;
+      break;
+    }
+    case 'start_conversation':
+    case 'retry_conversation': {
+      if (userIds.length > 200) throw AppError.badRequest('单次最多对 200 个用户启动对话');
+      const job = await prisma.unionBatchJob.create({
+        data: {
+          action,
+          totalCount: userIds.length,
+          userIds,
+          params: params ?? undefined,
+          operatorId: (ctx.state.user as any)?.sub ?? null,
+        },
+      });
+      launchBatchJob(job.id);
+      ctx.status = 202;
+      success(ctx, { action, jobId: job.id, jobStatus: 'pending' });
+      return;
+    }
+    default:
+      throw AppError.badRequest(`Unsupported batch action: ${action}`);
+  }
+
+  success(ctx, { action, affected });
+});
diff --git a/apps/minerva-server/src/services/union/ai-client.ts b/apps/minerva-server/src/services/union/ai-client.ts
