+  { id: 'tpl_direct_02', content: "Hey! Earn $90/hr as a {{app_name}} video chat host. Work from home, set your own schedule. Want in?", category: 'direct', weight: 1 },
+  { id: 'tpl_direct_03', content: "Hi there! {{app_name}} is looking for video chat hosts. Great pay ($90/hr), no experience needed. Should I send you more info?", category: 'direct', weight: 1 },
+  { id: 'tpl_direct_04', content: "Hey! We're expanding our {{app_name}} host team. $90/hr + $50 bonus. Flexible schedule. Interested in joining?", category: 'direct', weight: 1 },
