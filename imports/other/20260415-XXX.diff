@@ -0,0 +1,118 @@
+/**
+ * Analytics Service — 统计聚合服务
+ */
+import { prisma } from '../../utils/prisma.js';
+
+/** Get start of day in Beijing time (UTC+8) */
+function getBeijingDayStart(date?: string): Date {
+  if (date) return new Date(date);
+  const now = new Date();
+  // Beijing = UTC + 8h. Calculate current Beijing time, then set to midnight Beijing.
+  const beijingOffset = 8 * 60 * 60 * 1000;
+  const beijingNow = new Date(now.getTime() + beijingOffset);
+  beijingNow.setUTCHours(0, 0, 0, 0);
+  // Convert back to UTC: subtract 8h
+  return new Date(beijingNow.getTime() - beijingOffset);
+}
+
+export async function getDashboardMetrics(startDate?: string, endDate?: string) {
+  const start = getBeijingDayStart(startDate);
+  const end = endDate ? new Date(endDate) : new Date();
+
+  const [totalUsers, contacted, replied, converted, aiCalls, activeConversations, outboundMessages, inboundMessages] = await Promise.all([
+    prisma.unionUser.count({ where: { isTest: false } }),
+    prisma.unionUser.count({
+      where: { isTest: false, lastContactAt: { gte: start, lte: end } },
+    }),
+    prisma.unionConversation.groupBy({
+      by: ['userId'],
+      where: { direction: 'inbound', createdAt: { gte: start, lte: end } },
+    }).then((r) => r.length),
+    prisma.unionUser.count({
+      where: { isTest: false, status: 'converted', convertedAt: { gte: start, lte: end } },
+    }),
+    prisma.unionDecisionLog.count({
+      where: { createdAt: { gte: start, lte: end } },
+    }),
+    // 当前活跃会话数
+    prisma.unionUser.count({
+      where: { isTest: false, status: 'in_conversation' },
+    }),
+    // 发出的消息数
+    prisma.unionConversation.count({
+      where: { direction: 'outbound', createdAt: { gte: start, lte: end } },
+    }),
+    // 收到的消息数
+    prisma.unionConversation.count({
+      where: { direction: 'inbound', createdAt: { gte: start, lte: end } },
+    }),
+  ]);
+
+  const statusDistribution = await prisma.unionUser.groupBy({
+    by: ['status'],
+    where: { isTest: false },
+    _count: true,
+  });
+
+  const sourceDistribution = await prisma.unionUser.groupBy({
+    by: ['source'],
+    where: { isTest: false },
+    _count: true,
+  });
+
+  return {
+    today: {
+      totalUsers,
+      contacted,
+      replied,
+      converted,
+      aiCalls,
+      activeConversations,
+      outboundMessages,
+      inboundMessages,
+      estimatedCost: 0, // TODO: calculate from token usage
+    },
+    statusDistribution: statusDistribution.map((s) => ({
+      status: s.status,
+      count: s._count,
+    })),
+    sourceDistribution: sourceDistribution.map((s) => ({
+      source: s.source,
+      count: s._count,
+    })),
+  };
+}
+
+export async function getFunnelData(params: {
+  startDate: string;
+  endDate: string;
+  source?: string;
+  abGroup?: string;
+}) {
+  const where: any = {
+    isTest: false,
+    createdAt: { gte: new Date(params.startDate), lte: new Date(params.endDate) },
+  };
+  if (params.source) where.source = params.source;
+  if (params.abGroup) where.abGroup = params.abGroup;
+
+  const total = await prisma.unionUser.count({ where });
+  const contacted = await prisma.unionUser.count({
+    where: { ...where, lastContactAt: { not: null } },
+  });
+  const replied = await prisma.unionUser.count({
+    where: { ...where, status: { in: ['in_conversation', 'converted', 'paused', 'silent'] } },
+  });
+  const converted = await prisma.unionUser.count({
+    where: { ...where, status: 'converted' },
+  });
+
+  const stages = [
+    { name: '待触达', count: total, rate: 1 },
+    { name: '已触达', count: contacted, rate: total > 0 ? contacted / total : 0 },
+    { name: '已回复', count: replied, rate: contacted > 0 ? replied / contacted : 0 },
+    { name: '已转化', count: converted, rate: replied > 0 ? converted / replied : 0 },
+  ];
+
+  return { stages };
+}
diff --git a/apps/minerva-server/src/services/union/batch-job-processor.ts b/apps/minerva-server/src/services/union/batch-job-processor.ts
new file mode 100644
