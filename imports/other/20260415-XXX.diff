+import { PageContainer, ProTable } from '@ant-design/pro-components';
+import type { ProColumns, ActionType } from '@ant-design/pro-components';
+import { useAccess } from '@umijs/max';
+import { useRequest } from 'ahooks';
+import { Button, Modal, Form, Input, Select, message, Tag, Collapse, Alert, Typography, Steps, Table as AntTable } from 'antd';
+import { PlusOutlined, QuestionCircleOutlined, ExperimentOutlined } from '@ant-design/icons';
+import { history } from '@umijs/max';
+import React, { useRef, useState } from 'react';
+import { listUnionPrompts, createUnionPrompt, updateUnionPrompt } from '@/api/union';
+
+type PromptItem = {
+  id: string;
+  layer: string;
+  phase: string;
+  scene: string;
+  version: number;
+  status: string;
+  content: string;
+};
+
+const statusEnum: Record<string, { text: string; color: string }> = {
+  draft: { text: '草稿', color: 'default' },
+  active: { text: '生效中', color: 'green' },
+  archived: { text: '已归档', color: 'default' },
+};
+
+const columns: ProColumns<PromptItem>[] = [
+  { title: 'Layer', dataIndex: 'layer', valueType: 'select',
+    valueEnum: { base_persona: { text: 'Base Persona' }, phase_strategy: { text: 'Phase Strategy' }, scene_script: { text: 'Scene Script' }, user_context: { text: 'User Context' } },
+  },
+  { title: '阶段', dataIndex: 'phase' },
+  { title: '场景', dataIndex: 'scene' },
+  { title: '版本', dataIndex: 'version', hideInSearch: true },
+  {
+    title: '状态', dataIndex: 'status',
+    render: (_, r) => <Tag color={statusEnum[r.status]?.color}>{statusEnum[r.status]?.text}</Tag>,
+  },
+  { title: '操作', valueType: 'option', render: () => [<a key="edit">编辑</a>] },
+];
+
+const { Text, Paragraph } = Typography;
+
+const layerGuideColumns = [
+  { title: '层级', dataIndex: 'layer', width: 160 },
+  { title: '作用', dataIndex: 'purpose' },
+  { title: '何时配置', dataIndex: 'when' },
+  { title: '示例', dataIndex: 'example' },
+];
+
+const layerGuideData = [
+  {
+    key: '1',
+    layer: '🧑 Base Persona（基础人设）',
+    purpose: '定义 AI 的角色身份和说话风格，所有对话共用',
+    when: '首次使用时配置一次，之后很少改动',
+    example: '"你是一位友善专业的工会客服，语气亲切，回复简洁"',
+  },
+  {
+    key: '2',
+    layer: '📋 Phase Strategy（阶段策略）',
+    purpose: '根据用户所处阶段调整 AI 的沟通目标',
+    when: '每新增一个运营阶段时配置',
+    example: '激活阶段："重点引导用户完成首次任务"',
+  },
+  {
+    key: '3',
+    layer: '🎬 Scene Script（场景话术）',
+    purpose: '具体场景下的对话模板，精细控制 AI 的回复方式',
+    when: '需要针对特定场景定制回复时配置',
+    example: '激活阶段 + 回复场景："回复时附带 App 下载链接"',
+  },
+];
+
+const ConfigGuide: React.FC = () => (
+  <Collapse
+    ghost
+    style={{ marginBottom: 16, background: '#fff', borderRadius: 8, border: '1px solid #f0f0f0' }}
+    items={[
+      {
+        key: 'guide',
+        label: (
+          <span style={{ fontSize: 15, fontWeight: 500 }}>
+            <QuestionCircleOutlined style={{ marginRight: 8, color: '#1677ff' }} />
+            配置说明 — 点击展开查看如何配置 Prompt
+          </span>
+        ),
+        children: (
+          <div style={{ padding: '0 8px' }}>
+            <Alert
+              type="info"
+              showIcon
+              style={{ marginBottom: 16 }}
+              message="什么是 Prompt？"
+              description="Prompt 是给 AI 的「工作指令」。通过配置不同层级的 Prompt，可以控制 AI 在不同阶段、不同场景下如何回复用户。配置好后可前往 Playground 实时测试效果。"
+            />
+
+            <Text strong style={{ fontSize: 14 }}>📐 Prompt 分层结构</Text>
+            <Paragraph type="secondary" style={{ marginBottom: 8 }}>
+              系统将多层 Prompt 自动组合，从上到下逐层叠加，越往下越具体：
+            </Paragraph>
+            <AntTable
+              columns={layerGuideColumns}
+              dataSource={layerGuideData}
+              pagination={false}
+              size="small"
+              bordered
+              style={{ marginBottom: 20 }}
+            />
+
+            <Text strong style={{ fontSize: 14 }}>🚀 快速上手</Text>
+            <Steps
+              direction="vertical"
+              size="small"
+              current={-1}
+              style={{ marginTop: 12, marginBottom: 20 }}
+              items={[
+                {
+                  title: '配置基础人设',
+                  description: '点击「新建 Prompt」→ Layer 选择 Base Persona → 填写 AI 的角色定位和说话风格',
+                },
+                {
+                  title: '配置阶段策略',
+                  description: '新建 Prompt → Layer 选择 Phase Strategy → 填写「阶段」（如 activation）→ 描述该阶段的沟通目标',
+                },
