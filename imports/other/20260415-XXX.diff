@@ -0,0 +1,290 @@
+-- ============================================================
+-- Union Ops — AI 工会运营系统
+-- 纯新增操作，不修改任何现有表
+-- ============================================================
+
+-- 1. 创建枚举类型
+CREATE TYPE "UnionUserStatus" AS ENUM ('pending_device', 'pending_contact', 'in_conversation', 'paused', 'silent', 'converted', 'opted_out', 'invalid_number', 'rejected', 'dead');
+CREATE TYPE "UnionUserSource" AS ENUM ('tiktok', 'facebook', 'manual', 'other');
+CREATE TYPE "UnionPhase" AS ENUM ('onboarding', 'retention', 'work_assist');
+CREATE TYPE "UnionMsgDirection" AS ENUM ('inbound', 'outbound');
+CREATE TYPE "UnionMsgStatus" AS ENUM ('pending', 'sent', 'delivered', 'failed');
+CREATE TYPE "UnionTemplateStatus" AS ENUM ('draft', 'reviewing', 'published', 'archived');
+CREATE TYPE "UnionTriggerType" AS ENUM ('user_reply', 'scheduled_followup', 'manual');
+CREATE TYPE "UnionDecisionAction" AS ENUM ('send_now', 'schedule_followup', 'mark_converted', 'mark_dead', 'escalate_to_human');
+CREATE TYPE "UnionDeviceStatus" AS ENUM ('online', 'offline', 'maintenance');
+CREATE TYPE "UnionAlertLevel" AS ENUM ('critical', 'warning', 'info');
+
+-- 2. 创建表
+
+-- UnionDevice（先建，因为 UnionUser 引用它）
+CREATE TABLE "union_devices" (
+    "id" TEXT NOT NULL,
+    "device_id" VARCHAR(100) NOT NULL,
+    "phone_number" VARCHAR(20) NOT NULL,
+    "status" "UnionDeviceStatus" NOT NULL DEFAULT 'offline',
+    "daily_limit" INTEGER NOT NULL DEFAULT 200,
+    "today_sent_count" INTEGER NOT NULL DEFAULT 0,
+    "assigned_users_count" INTEGER NOT NULL DEFAULT 0,
+    "last_heartbeat_at" TIMESTAMP(3),
+    "metadata" JSONB,
+    "created_at" TIMESTAMP(3) NOT NULL DEFAULT CURRENT_TIMESTAMP,
+    "updated_at" TIMESTAMP(3) NOT NULL,
+    CONSTRAINT "union_devices_pkey" PRIMARY KEY ("id")
+);
+CREATE UNIQUE INDEX "union_devices_device_id_key" ON "union_devices"("device_id");
+CREATE INDEX "union_devices_status_idx" ON "union_devices"("status");
+
+-- UnionUser
+CREATE TABLE "union_users" (
+    "id" TEXT NOT NULL,
+    "phone" VARCHAR(20) NOT NULL,
+    "source" "UnionUserSource" NOT NULL DEFAULT 'other',
+    "status" "UnionUserStatus" NOT NULL DEFAULT 'pending_device',
+    "phase" "UnionPhase" NOT NULL DEFAULT 'onboarding',
+    "device_id" TEXT,
+    "ab_group" VARCHAR(50),
+    "quality_score" DOUBLE PRECISION DEFAULT 0,
+    "is_test" BOOLEAN NOT NULL DEFAULT false,
+    "source_detail" JSONB,
+    "last_contact_at" TIMESTAMP(3),
+    "converted_at" TIMESTAMP(3),
+    "created_at" TIMESTAMP(3) NOT NULL DEFAULT CURRENT_TIMESTAMP,
+    "updated_at" TIMESTAMP(3) NOT NULL,
+    CONSTRAINT "union_users_pkey" PRIMARY KEY ("id")
+);
+CREATE UNIQUE INDEX "union_users_phone_key" ON "union_users"("phone");
+CREATE INDEX "union_users_status_idx" ON "union_users"("status");
+CREATE INDEX "union_users_phase_idx" ON "union_users"("phase");
+CREATE INDEX "union_users_device_id_idx" ON "union_users"("device_id");
