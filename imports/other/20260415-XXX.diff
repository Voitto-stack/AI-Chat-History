@@ -0,0 +1,204 @@
+import { PageContainer, ProTable } from '@ant-design/pro-components';
+import type { ProColumns, ActionType } from '@ant-design/pro-components';
+import { Button, Tag, Modal, message, Descriptions, Typography } from 'antd';
+import { StopOutlined } from '@ant-design/icons';
+import React, { useRef, useState } from 'react';
+import { listBatchJobs, getBatchJob, cancelBatchJob } from '@/api/union';
+
+const { Text } = Typography;
+
+const STATUS_MAP: Record<string, { color: string; text: string }> = {
+  pending: { color: 'default', text: '等待中' },
+  processing: { color: 'processing', text: '执行中' },
+  completed: { color: 'success', text: '已完成' },
+  failed: { color: 'error', text: '失败' },
+  cancelled: { color: 'warning', text: '已取消' },
+};
+
+const ACTION_MAP: Record<string, string> = {
+  start_conversation: '启动短信对话',
+  assign_device: '分配设备',
+  change_status: '变更状态',
+  add_tag: '添加标签',
+  remove_tag: '移除标签',
+};
+
+type BatchJobItem = {
+  id: string;
+  action: string;
+  status: string;
+  totalCount: number;
+  successCount: number;
+  failedCount: number;
+  userIds: string[];
+  results: Array<{ userId: string; success: boolean; error?: string }> | null;
+  scheduledAt: string | null;
+  startedAt: string | null;
+  completedAt: string | null;
+  createdAt: string;
+};
+
+const BatchJobsPage: React.FC = () => {
+  const actionRef = useRef<ActionType>(null);
+  const [detailOpen, setDetailOpen] = useState(false);
+  const [detail, setDetail] = useState<any>(null);
+
+  const handleCancel = async (id: string) => {
+    try {
+      await cancelBatchJob(id);
+      message.success('任务已取消');
+      actionRef.current?.reload();
+    } catch (err: any) {
+      message.error(err?.message || '取消失败');
+    }
+  };
+
+  const handleViewDetail = async (id: string) => {
+    try {
+      const job = await getBatchJob(id);
+      setDetail(job);
+      setDetailOpen(true);
+    } catch (err: any) {
+      message.error(err?.message || '获取详情失败');
+    }
+  };
+
+  const columns: ProColumns<BatchJobItem>[] = [
+    {
+      title: '操作类型',
+      dataIndex: 'action',
+      valueType: 'select',
+      valueEnum: Object.fromEntries(Object.entries(ACTION_MAP).map(([k, v]) => [k, { text: v }])),
+      render: (_, r) => ACTION_MAP[r.action] || r.action,
+    },
+    {
+      title: '状态',
+      dataIndex: 'status',
+      valueType: 'select',
+      valueEnum: Object.fromEntries(Object.entries(STATUS_MAP).map(([k, v]) => [k, { text: v.text }])),
+      render: (_, r) => {
+        const s = STATUS_MAP[r.status] || { color: 'default', text: r.status };
+        return <Tag color={s.color}>{s.text}</Tag>;
+      },
+    },
+    {
+      title: '进度',
+      dataIndex: 'totalCount',
+      hideInSearch: true,
+      render: (_, r) => (
+        <span>
+          <Text type="success">{r.successCount}</Text>
+          {r.failedCount > 0 && <> / <Text type="danger">{r.failedCount}</Text></>}
+          {' / '}
+          {r.totalCount}
+        </span>
+      ),
+    },
+    {
+      title: '定时执行',
+      dataIndex: 'scheduledAt',
+      valueType: 'dateTime',
+      hideInSearch: true,
+      render: (_, r) => r.scheduledAt ? new Date(r.scheduledAt).toLocaleString('zh-CN') : '-',
+    },
+    {
+      title: '创建时间',
+      dataIndex: 'createdAt',
+      valueType: 'dateTime',
+      hideInSearch: true,
+      sorter: true,
+    },
+    {
+      title: '完成时间',
+      dataIndex: 'completedAt',
+      valueType: 'dateTime',
+      hideInSearch: true,
+      render: (_, r) => r.completedAt ? new Date(r.completedAt).toLocaleString('zh-CN') : '-',
+    },
+    {
+      title: '操作',
+      valueType: 'option',
+      render: (_, record) => [
+        <a key="detail" onClick={() => handleViewDetail(record.id)}>详情</a>,
+        (record.status === 'pending' || record.status === 'processing') && (
+          <a key="cancel" style={{ color: '#ff4d4f' }} onClick={() => handleCancel(record.id)}>
+            <StopOutlined /> 取消
+          </a>
+        ),
+      ].filter(Boolean),
+    },
+  ];
+
+  return (
+    <PageContainer content="查看批量任务和定时任务的执行状态、进度和结果。">
+      <ProTable<BatchJobItem>
+        headerTitle="批量任务"
+        actionRef={actionRef}
+        rowKey="id"
+        columns={columns}
+        request={async (params: any) => {
+          const res = await listBatchJobs({
+            page: params.current,
+            pageSize: params.pageSize,
+            status: params.status,
+            action: params.action,
+          });
+          return { data: res.items, total: res.total, success: true };
+        }}
+        polling={5000}
+        pagination={{ defaultPageSize: 20, showSizeChanger: true }}
+        search={{ labelWidth: 'auto' }}
+      />
+
+      <Modal
+        title="任务详情"
+        open={detailOpen}
+        onCancel={() => { setDetailOpen(false); setDetail(null); }}
+        footer={null}
+        width={700}
+      >
+        {detail && (
+          <>
+            <Descriptions column={2} size="small" bordered style={{ marginBottom: 16 }}>
+              <Descriptions.Item label="任务ID">{detail.id}</Descriptions.Item>
+              <Descriptions.Item label="操作类型">{ACTION_MAP[detail.action] || detail.action}</Descriptions.Item>
+              <Descriptions.Item label="状态">
+                <Tag color={STATUS_MAP[detail.status]?.color}>{STATUS_MAP[detail.status]?.text || detail.status}</Tag>
+              </Descriptions.Item>
+              <Descriptions.Item label="进度">
+                {detail.successCount} 成功 / {detail.failedCount} 失败 / {detail.totalCount} 总计
+              </Descriptions.Item>
+              <Descriptions.Item label="定时执行">{detail.scheduledAt ? new Date(detail.scheduledAt).toLocaleString('zh-CN') : '-'}</Descriptions.Item>
+              <Descriptions.Item label="开始时间">{detail.startedAt ? new Date(detail.startedAt).toLocaleString('zh-CN') : '-'}</Descriptions.Item>
+              <Descriptions.Item label="完成时间">{detail.completedAt ? new Date(detail.completedAt).toLocaleString('zh-CN') : '-'}</Descriptions.Item>
+              <Descriptions.Item label="创建时间">{new Date(detail.createdAt).toLocaleString('zh-CN')}</Descriptions.Item>
+            </Descriptions>
+            {detail.results && detail.results.length > 0 && (
+              <ProTable
+                headerTitle="执行结果"
+                size="small"
+                rowKey="userId"
+                search={false}
+                pagination={false}
+                dataSource={detail.results}
+                columns={[
+                  { title: '用户ID', dataIndex: 'userId', ellipsis: true, copyable: true },
+                  { title: '手机号', dataIndex: 'phone', ellipsis: true, copyable: true },
+                  {
+                    title: '结果',
+                    dataIndex: 'success',
+                    render: (_: any, r: any) => r.success
+                      ? <Tag color="success">成功</Tag>
+                      : <Tag color="error">{r.error || '失败'}</Tag>,
+                  },
+                ]}
+              />
+            )}
+          </>
+        )}
+      </Modal>
+    </PageContainer>
+  );
+};
+
+export default BatchJobsPage;
