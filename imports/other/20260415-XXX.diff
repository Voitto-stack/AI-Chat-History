@@ -0,0 +1,193 @@
+import { PageContainer, ProTable } from '@ant-design/pro-components';
+import type { ProColumns, ActionType } from '@ant-design/pro-components';
+import { useAccess } from '@umijs/max';
+import { useRequest } from 'ahooks';
+import { Button, Modal, Form, Input, InputNumber, Select, Switch, message, Popconfirm, Table, Tag } from 'antd';
+import { PlusOutlined, CheckCircleOutlined, CloseCircleOutlined, ThunderboltOutlined, PercentageOutlined } from '@ant-design/icons';
+import React, { useRef, useState } from 'react';
+import {
+  listUnionModelConfigs,
+  createUnionModelConfig,
+  updateUnionModelConfig,
+  deleteUnionModelConfig,
+  getAiStats,
+} from '@/api/union';
+import { GradientStatRow } from '@/components/GradientStatCard';
+import type { StatCardItem } from '@/components/GradientStatCard';
+
+type ModelItem = {
+  id: string;
+  displayName: string;
+  modelName: string;
+  provider: string;
+  priority: number;
+  enabled: boolean;
+  endpoint: string;
+};
+
+const UnionModelConfig: React.FC = () => {
+  const access = useAccess();
+  const actionRef = useRef<ActionType>(null);
+  const [modalOpen, setModalOpen] = useState(false);
+  const [editingId, setEditingId] = useState<string | null>(null);
+  const [form] = Form.useForm();
+
+  const { data: list, loading, refresh } = useRequest(() => listUnionModelConfigs());
+  const { data: stats } = useRequest(() => getAiStats(), { pollingInterval: 30000 });
+
+  const { run: doSave, loading: saving } = useRequest(
+    async (values: any) => {
+      if (editingId) return updateUnionModelConfig(editingId, values);
+      return createUnionModelConfig(values);
+    },
+    {
+      manual: true,
+      onSuccess: () => {
+        message.success('保存成功');
+        setModalOpen(false);
+        form.resetFields();
+        setEditingId(null);
+        refresh();
+      },
+    },
+  );
+
+  const columns: ProColumns<ModelItem>[] = [
+    { title: '模型名称', dataIndex: 'displayName' },
+    { title: '模型标识', dataIndex: 'modelName' },
