+        confirmLoading={saving}
+      >
+        <Form form={form} layout="vertical">
+          <Form.Item name="displayName" label="模型名称" rules={[{ required: true }]}>
+            <Input placeholder="如：Claude Opus (供应商A)" />
+          </Form.Item>
+          <Form.Item name="modelName" label="模型标识" rules={[{ required: true }]}
+            tooltip="传给大模型 API 的 model 参数，如 claude-opus-4-6">
+            <Input placeholder="如：claude-opus-4-6" />
+          </Form.Item>
+          <Form.Item name="provider" label="提供商" rules={[{ required: true }]}>
+            <Select options={[
+              { label: 'OpenAI', value: 'openai' },
