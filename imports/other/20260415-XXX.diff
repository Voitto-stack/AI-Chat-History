@@ -0,0 +1,61 @@
+import Router from '@koa/router';
+import { prisma } from '../../utils/prisma.js';
+import { success } from '../../utils/response.js';
+import { AppError } from '../../utils/AppError.js';
+import { authMiddleware, requirePermission } from '../../middlewares/auth.js';
+import { createUnionExperimentRequestSchema } from '@sitin/minerva-schemas';
+
+export const experimentsRouter = new Router();
+experimentsRouter.use(authMiddleware);
+
+/** GET / — List experiments */
+experimentsRouter.get('/', requirePermission('union.template.read'), async (ctx) => {
+  const experiments = await prisma.unionExperiment.findMany({
+    orderBy: { createdAt: 'desc' },
+  });
+  success(ctx, experiments);
+});
+
+/** POST / — Create experiment */
+experimentsRouter.post('/', requirePermission('union.template.write'), async (ctx) => {
+  const body = createUnionExperimentRequestSchema.parse(ctx.request.body);
+  const experiment = await prisma.unionExperiment.create({
+    data: {
+      name: body.name,
+      phase: body.phase,
+      scene: body.scene,
+      variants: body.variants as any,
+      allocationRule: body.allocationRule as any,
+      status: 'draft',
+    },
+  });
+  success(ctx, experiment, 201);
+});
+
+/** PATCH /:id/start — Start experiment */
+experimentsRouter.patch('/:id/start', requirePermission('union.template.write'), async (ctx) => {
+  const { id } = ctx.params;
+  const exp = await prisma.unionExperiment.findUnique({ where: { id } });
+  if (!exp) throw AppError.notFound('Experiment not found');
+  if (exp.status !== 'draft') throw AppError.badRequest('Only draft experiments can be started');
+
+  const updated = await prisma.unionExperiment.update({
+    where: { id },
+    data: { status: 'running', startedAt: new Date() },
+  });
+  success(ctx, updated);
+});
+
+/** PATCH /:id/end — End experiment */
+experimentsRouter.patch('/:id/end', requirePermission('union.template.write'), async (ctx) => {
+  const { id } = ctx.params;
+  const exp = await prisma.unionExperiment.findUnique({ where: { id } });
+  if (!exp) throw AppError.notFound('Experiment not found');
+  if (exp.status !== 'running') throw AppError.badRequest('Only running experiments can be ended');
+
+  const updated = await prisma.unionExperiment.update({
+    where: { id },
+    data: { status: 'ended', endedAt: new Date() },
+  });
+  success(ctx, updated);
+});
diff --git a/apps/minerva-server/src/routes/union/gateway-device.ts b/apps/minerva-server/src/routes/union/gateway-device.ts
new file mode 100644
index 00000000..766c4594
--- /dev/null
+++ b/apps/minerva-server/src/routes/union/gateway-device.ts
@@ -0,0 +1,326 @@
+import Router from '@koa/router';
+import jwt from 'jsonwebtoken';
+import { prisma } from '../../utils/prisma.js';
+import { success } from '../../utils/response.js';
+import { AppError } from '../../utils/AppError.js';
+import { authMiddleware, requirePermission } from '../../middlewares/auth.js';
+import { isDeviceOnline, pushToDevice, disconnectDevice, getConnectionsDebug } from '../../services/union/device-ws.js';
+
+const JWT_SECRET = process.env.JWT_SECRET || 'dev-secret-change-me';
+
+export const gatewayDeviceRouter = new Router();
+
+// Apply auth middleware to all routes
+gatewayDeviceRouter.use(authMiddleware);
+
+/**
+ * GET /api/union/gateway-device/debug/connections
+ * Debug: show in-memory WS connections Map
+ */
+gatewayDeviceRouter.get(
+  '/debug/connections',
+  requirePermission('union.device.read'),
+  async (ctx) => {
+    success(ctx, getConnectionsDebug());
+  }
+);
+
+/**
+ * GET /api/union/gateway-device
+ * List devices with pagination, filter by status
+ */
+gatewayDeviceRouter.get(
+  '/',
+  requirePermission('union.device.read'),
+  async (ctx) => {
+    const {
+      page = '1',
+      pageSize = '20',
+      status,
+    } = ctx.query as {
+      page?: string;
+      pageSize?: string;
+      status?: string;
+    };
+
+    const skip = (Number(page) - 1) * Number(pageSize);
+    const take = Number(pageSize);
+
+    const where = status ? { status: status as any } : {};
+
+    const [devices, total] = await Promise.all([
+      prisma.unionDevice.findMany({
+        where,
+        skip,
+        take,
+        orderBy: { createdAt: 'desc' },
+      }),
+      prisma.unionDevice.count({ where }),
+    ]);
+
+    success(ctx, {
+      items: devices,
+      total,
+      page: Number(page),
+      pageSize: take,
+    });
+  }
+);
+
+/**
+ * POST /api/union/gateway-device/register
+ * Register a new device
+ */
+gatewayDeviceRouter.post(
+  '/register',
+  requirePermission('union.device.write'),
+  async (ctx) => {
+    const { deviceId, phoneNumber, dailyLimit } = ctx.request.body as {
+      deviceId: string;
+      phoneNumber: string;
+      dailyLimit?: number;
+    };
+
+    if (!deviceId || !phoneNumber) {
+      throw AppError.badRequest('deviceId and phoneNumber are required');
+    }
+
+    const existing = await prisma.unionDevice.findUnique({
+      where: { deviceId },
+    });
+
+    if (existing) {
+      throw AppError.conflict('Device already registered', 'DEVICE_EXISTS');
+    }
+
+    const device = await prisma.unionDevice.create({
+      data: {
+        deviceId,
+        phoneNumber,
+        dailyLimit: dailyLimit ?? 200,
+      },
+    });
+
+    success(ctx, device, 201);
+  }
+);
+
+/**
+ * PATCH /api/union/gateway-device/:id/control
+ * Control device status (enable/disable)
+ */
+gatewayDeviceRouter.patch(
+  '/:id/control',
+  requirePermission('union.device.write'),
+  async (ctx) => {
+    const { id } = ctx.params;
+    const { action } = ctx.request.body as {
+      action: 'enable' | 'disable';
+    };
+
+    if (!action || !['enable', 'disable'].includes(action)) {
+      throw AppError.badRequest(
+        'action must be one of: enable, disable'
+      );
+    }
+
+    const statusMap: Record<string, string> = {
+      enable: 'online',
+      disable: 'offline',
+    };
+
+    const device = await prisma.unionDevice.update({
+      where: { id },
+      data: { status: statusMap[action] as any },
+    });
+
+    // Close WS connection when disabling or setting maintenance
+    if (action !== 'enable') {
+      disconnectDevice(device.deviceId);
+    }
+
+    success(ctx, device);
+  }
+);
+
+/**
+ * POST /api/union/gateway-device/qr-token
+ * Generate a QR token for device scanning registration
+ */
+gatewayDeviceRouter.post(
+  '/qr-token',
+  requirePermission('union.device.write'),
+  async (ctx) => {
+    const expiresIn = 300; // 5 minutes
+    const token = jwt.sign({ purpose: 'device_register' }, JWT_SECRET, { expiresIn });
+
+    // Build wsUrl
+    // Priority: WS_PUBLIC_URL > derive from Origin header > derive from Host header
+    const wsPublicUrl = process.env.WS_PUBLIC_URL;
+    let wsUrl: string;
+    if (wsPublicUrl) {
+      wsUrl = wsPublicUrl;
+    } else {
+      const origin = ctx.request.header.origin || '';
+      const port = process.env.PORT || '29001';
+      if (origin) {
+        const url = new URL(origin);
+        const protocol = url.protocol === 'https:' ? 'wss' : 'ws';
+        // Use origin hostname + backend port (not frontend port)
+        wsUrl = `${protocol}://${url.hostname}:${port}/ws/device`;
+      } else {
+        // Fallback: use backend's own host
+        const host = ctx.request.header['x-forwarded-host']
+          || `${ctx.request.hostname}:${port}`;
+        const protocol = ctx.request.secure ? 'wss' : 'ws';
+        wsUrl = `${protocol}://${host}/ws/device`;
+      }
+    }
+
+    success(ctx, {
+      token,
+      wsUrl,
+      expiresAt: new Date(Date.now() + expiresIn * 1000).toISOString(),
+    });
+  }
+);
+
+/**
+ * POST /api/union/gateway-device/:id/heartbeat
+ * Device heartbeat — update lastHeartbeatAt and mark online
+ */
+gatewayDeviceRouter.post(
+  '/:id/heartbeat',
+  requirePermission('union.device.write'),
+  async (ctx) => {
+    const { id } = ctx.params;
+
+    const device = await prisma.unionDevice.update({
+      where: { id },
+      data: {
+        lastHeartbeatAt: new Date(),
+        status: 'online',
+      },
+    });
+
+    success(ctx, {
+      id: device.id,
+      deviceId: device.deviceId,
+      status: device.status,
+      lastHeartbeatAt: device.lastHeartbeatAt,
+    });
+  }
+);
+
+/**
+ * GET /api/union/gateway-device/:id
+ * Get device detail + realtime online status
+ */
+gatewayDeviceRouter.get(
+  '/:id',
+  requirePermission('union.device.read'),
+  async (ctx) => {
+    const { id } = ctx.params;
+
+    const device = await prisma.unionDevice.findUnique({ where: { id } });
+    if (!device) throw AppError.notFound('Device not found');
+
+    success(ctx, {
+      ...device,
+      online: isDeviceOnline(device.deviceId),
+    });
+  }
+);
+
+/**
+ * GET /api/union/gateway-device/:id/logs?page&pageSize
+ * Paginated device communication log
+ */
+gatewayDeviceRouter.get(
+  '/:id/logs',
+  requirePermission('union.device.read'),
+  async (ctx) => {
+    const { id } = ctx.params;
+    const { page = '1', pageSize = '20' } = ctx.query as { page?: string; pageSize?: string };
+
+    const device = await prisma.unionDevice.findUnique({ where: { id }, select: { deviceId: true } });
+    if (!device) throw AppError.notFound('Device not found');
+
+    const skip = (Number(page) - 1) * Number(pageSize);
+    const take = Number(pageSize);
+
+    const [items, total] = await Promise.all([
+      prisma.unionDeviceLog.findMany({
+        where: { deviceId: device.deviceId },
+        orderBy: { createdAt: 'desc' },
+        skip,
+        take,
+      }),
+      prisma.unionDeviceLog.count({ where: { deviceId: device.deviceId } }),
+    ]);
+
+    success(ctx, { items, total, page: Number(page), pageSize: take });
+  }
+);
+
+/**
+ * DELETE /api/union/gateway-device/:id?force=true
+ * Delete a device. force=true will unbind assigned users first.
+ */
+gatewayDeviceRouter.delete(
+  '/:id',
+  requirePermission('union.device.write'),
+  async (ctx) => {
+    const { id } = ctx.params;
+    const force = ctx.query.force === 'true';
+
+    const device = await prisma.unionDevice.findUnique({ where: { id } });
+    if (!device) throw AppError.notFound('Device not found');
+
+    // 解绑分配用户
+    if (device.assignedUsersCount > 0) {
+      if (!force) {
+        throw AppError.badRequest(
+          `该设备仍有 ${device.assignedUsersCount} 个分配用户，请先解绑后再删除`,
+        );
+      }
+      await prisma.unionUser.updateMany({
+        where: { deviceId: id },
+        data: { deviceId: null },
+      });
+    }
+
+    // 删除关联的通信日志
+    await prisma.unionDeviceLog.deleteMany({ where: { deviceId: device.deviceId } });
+    await prisma.unionDevice.delete({ where: { id } });
+
+    success(ctx, { message: 'Device deleted' });
+  },
+);
+
+/**
+ * POST /api/union/gateway-device/:id/send
+ * Send a WS frame to the device
+ */
+gatewayDeviceRouter.post(
+  '/:id/send',
+  requirePermission('union.device.write'),
+  async (ctx) => {
+    const { id } = ctx.params;
+    const { type, data } = ctx.request.body as { type: string; data: object };
+
+    if (!type) throw AppError.badRequest('type is required');
+
+    const device = await prisma.unionDevice.findUnique({ where: { id } });
+    if (!device) throw AppError.notFound('Device not found');
+
+    const pushed = pushToDevice(device.deviceId, { type, data: data ?? {}, ts: Date.now() });
+
+    if (!pushed) {
+      success(ctx, { pushed: false, reason: 'device_offline' });
+      return;
+    }
+
+    success(ctx, { pushed: true });
+  }
+);
diff --git a/apps/minerva-server/src/routes/union/gateway-queue.ts b/apps/minerva-server/src/routes/union/gateway-queue.ts
new file mode 100644
index 00000000..9bc36992
--- /dev/null
+++ b/apps/minerva-server/src/routes/union/gateway-queue.ts
@@ -0,0 +1,123 @@
+import Router from '@koa/router';
+import { prisma } from '../../utils/prisma.js';
+import { success } from '../../utils/response.js';
+import { AppError } from '../../utils/AppError.js';
+import { authMiddleware, requirePermission } from '../../middlewares/auth.js';
+
+export const gatewayQueueRouter = new Router();
+
+// Apply auth middleware to all routes
+gatewayQueueRouter.use(authMiddleware);
+
+/**
+ * GET /api/union/gateway-queue
+ * List message queue with pagination, filter by status and deviceId
+ */
+gatewayQueueRouter.get(
+  '/',
+  requirePermission('union.device.read'),
+  async (ctx) => {
+    const {
+      page = '1',
+      pageSize = '20',
+      status,
+      deviceId,
+    } = ctx.query as {
+      page?: string;
+      pageSize?: string;
+      status?: string;
+      deviceId?: string;
+    };
+
+    const skip = (Number(page) - 1) * Number(pageSize);
+    const take = Number(pageSize);
+
+    const where: any = {};
+    if (status) where.sendStatus = status;
+    if (deviceId) where.deviceId = deviceId;
+
+    const [messages, total] = await Promise.all([
+      prisma.unionMessage.findMany({
+        where,
+        skip,
+        take,
+        orderBy: { createdAt: 'desc' },
+        include: {
+          user: { select: { id: true, phone: true } },
+          device: { select: { id: true, deviceId: true } },
+        },
+      }),
+      prisma.unionMessage.count({ where }),
+    ]);
+
+    success(ctx, {
+      items: messages,
+      total,
+      page: Number(page),
+      pageSize: take,
+    });
+  }
+);
+
+/**
+ * GET /api/union/gateway-queue/stats
+ * Queue statistics — count by status
+ */
+gatewayQueueRouter.get(
+  '/stats',
+  requirePermission('union.device.read'),
+  async (ctx) => {
+    const stats = await prisma.unionMessage.groupBy({
+      by: ['sendStatus'],
+      _count: { id: true },
+    });
+
+    const result = stats.reduce(
+      (acc, item) => {
+        acc[item.sendStatus] = item._count.id;
+        return acc;
+      },
+      {} as Record<string, number>
+    );
+
+    success(ctx, result);
+  }
+);
+
+/**
+ * POST /api/union/gateway-queue/:id/retry
+ * Retry a failed message — reset retryCount, set status to pending
+ */
+gatewayQueueRouter.post(
+  '/:id/retry',
+  requirePermission('union.device.write'),
+  async (ctx) => {
+    const { id } = ctx.params;
+
+    const message = await prisma.unionMessage.findUnique({
+      where: { id },
+    });
+
+    if (!message) {
+      throw AppError.notFound('Message not found');
+    }
+
+    if (message.sendStatus !== 'failed') {
+      throw AppError.badRequest(
+        'Only failed messages can be retried',
+        'NOT_FAILED'
+      );
+    }
+
+    const updated = await prisma.unionMessage.update({
+      where: { id },
+      data: {
+        sendStatus: 'pending',
+        retryCount: 0,
+        failReason: null,
+      },
+    });
+
+    success(ctx, updated);
+  }
+);
diff --git a/apps/minerva-server/src/routes/union/gateway-trace.ts b/apps/minerva-server/src/routes/union/gateway-trace.ts
