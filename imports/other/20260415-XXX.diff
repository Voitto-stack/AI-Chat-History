index 00000000..9f1fdeec
--- /dev/null
+++ b/apps/minerva-server/src/services/union/ai-client.ts
@@ -0,0 +1,222 @@
+/**
+ * AI Client — 多模型统一调用客户端
+ *
+ * 支持 Claude / Gemini / GPT-4o，按优先级降级
+ */
+import { prisma } from '../../utils/prisma.js';
+import { aiStats } from './ai-stats.js';
+
+export interface InferenceInput {
+  prompt: string;
+  modelConfigId?: string;
+  maxTokens?: number;
+  temperature?: number;
+}
+
+export interface InferenceOutput {
+  text: string;
+  modelUsed: string;
+  tokenUsage: { input: number; output: number };
+  latencyMs: number;
+}
+
+class AIClient {
+  /**
+   * Run inference with automatic model fallback
+   */
+  async inference(input: InferenceInput): Promise<InferenceOutput> {
+    const models = await this.getModelChain(input.modelConfigId);
+
+    if (models.length === 0) {
+      throw new Error('No AI models configured or enabled');
+    }
+
+    let lastError: Error | null = null;
+
+    for (const model of models) {
+      const startTime = Date.now();
+      try {
+        const result = await this.callModel(model, input);
+        const latency = Date.now() - startTime;
+        aiStats.track('ai-client', model.modelName, true, latency);
+        return {
+          ...result,
+          modelUsed: model.modelName,
+          latencyMs: latency,
+        };
+      } catch (err) {
+        aiStats.track('ai-client', model.modelName, false, Date.now() - startTime);
+        lastError = err as Error;
+        console.warn(
+          `[AIClient] Model ${model.modelName} failed: ${(err as Error).message}, trying next...`
+        );
+        continue;
+      }
+    }
+
+    throw new Error(
+      `All AI models failed. Last error: ${lastError?.message}`
+    );
+  }
+
+  private async getModelChain(preferredModelId?: string) {
+    const models = await prisma.unionModelConfig.findMany({
+      where: { enabled: true },
+      orderBy: { priority: 'asc' },
+    });
+
+    if (preferredModelId) {
+      const preferred = models.find((m) => m.id === preferredModelId);
+      if (preferred) {
+        return [preferred, ...models.filter((m) => m.id !== preferred.id)];
+      }
+    }
+
+    return models;
+  }
+
+  private async callModel(
+    model: { modelName: string; provider: string; apiKey: string; endpoint: string | null; params: any },
+    input: InferenceInput
+  ): Promise<Omit<InferenceOutput, 'latencyMs'>> {
+    const timeout = (model.params as any)?.timeoutMs ?? 10000;
+    const maxTokens = input.maxTokens ?? (model.params as any)?.maxTokens ?? 4096;
+    const temperature = input.temperature ?? (model.params as any)?.temperature ?? 0.7;
+
+    const controller = new AbortController();
+    const timer = setTimeout(() => controller.abort(), timeout);
+
+    try {
+      switch (model.provider) {
+        case 'anthropic':
+          return await this.callAnthropic(model, input.prompt, maxTokens, temperature, controller.signal);
+        case 'openai':
+          return await this.callOpenAI(model, input.prompt, maxTokens, temperature, controller.signal);
+        case 'google':
+          return await this.callGoogle(model, input.prompt, maxTokens, temperature, controller.signal);
+        default:
+          // Generic OpenAI-compatible endpoint
+          return await this.callOpenAI(model, input.prompt, maxTokens, temperature, controller.signal);
+      }
+    } finally {
+      clearTimeout(timer);
+    }
+  }
+
+  private async callAnthropic(
+    model: { apiKey: string; endpoint: string | null; modelName: string },
+    prompt: string,
+    maxTokens: number,
+    temperature: number,
+    signal: AbortSignal
+  ): Promise<Omit<InferenceOutput, 'latencyMs'>> {
+    const endpoint = model.endpoint || 'https://api.anthropic.com';
+    const resp = await fetch(`${endpoint}/v1/messages`, {
+      method: 'POST',
+      headers: {
+        'Content-Type': 'application/json',
+        'x-api-key': model.apiKey,
+        'anthropic-version': '2023-06-01',
+      },
+      body: JSON.stringify({
+        model: model.modelName,
+        max_tokens: maxTokens,
+        temperature,
+        messages: [{ role: 'user', content: prompt }],
+      }),
+      signal,
+    });
+
+    if (!resp.ok) {
+      throw new Error(`Anthropic API error: ${resp.status} ${await resp.text()}`);
+    }
+
+    const data = await resp.json() as any;
+    return {
+      text: data.content?.[0]?.text || '',
+      modelUsed: model.modelName,
+      tokenUsage: {
+        input: data.usage?.input_tokens || 0,
+        output: data.usage?.output_tokens || 0,
+      },
+    };
+  }
+
+  private async callOpenAI(
+    model: { apiKey: string; endpoint: string | null; modelName: string },
+    prompt: string,
+    maxTokens: number,
+    temperature: number,
+    signal: AbortSignal
+  ): Promise<Omit<InferenceOutput, 'latencyMs'>> {
+    const endpoint = model.endpoint || 'https://api.openai.com';
+    const resp = await fetch(`${endpoint}/v1/chat/completions`, {
+      method: 'POST',
+      headers: {
+        'Content-Type': 'application/json',
+        Authorization: `Bearer ${model.apiKey}`,
+      },
+      body: JSON.stringify({
+        model: model.modelName,
+        max_tokens: maxTokens,
+        temperature,
+        messages: [{ role: 'user', content: prompt }],
+      }),
+      signal,
+    });
+
+    if (!resp.ok) {
+      throw new Error(`OpenAI API error: ${resp.status} ${await resp.text()}`);
+    }
+
+    const data = await resp.json() as any;
+    return {
+      text: data.choices?.[0]?.message?.content || '',
+      modelUsed: model.modelName,
+      tokenUsage: {
+        input: data.usage?.prompt_tokens || 0,
+        output: data.usage?.completion_tokens || 0,
+      },
+    };
+  }
+
+  private async callGoogle(
+    model: { apiKey: string; endpoint: string | null; modelName: string },
+    prompt: string,
+    maxTokens: number,
+    temperature: number,
+    signal: AbortSignal
+  ): Promise<Omit<InferenceOutput, 'latencyMs'>> {
+    const endpoint =
+      model.endpoint ||
+      `https://generativelanguage.googleapis.com/v1beta/models/${model.modelName}:generateContent`;
+    const url = `${endpoint}?key=${model.apiKey}`;
+
+    const resp = await fetch(url, {
+      method: 'POST',
+      headers: { 'Content-Type': 'application/json' },
+      body: JSON.stringify({
+        contents: [{ parts: [{ text: prompt }] }],
+        generationConfig: { maxOutputTokens: maxTokens, temperature },
+      }),
+      signal,
+    });
+
+    if (!resp.ok) {
+      throw new Error(`Google AI error: ${resp.status} ${await resp.text()}`);
+    }
+
+    const data = await resp.json() as any;
+    const text = data.candidates?.[0]?.content?.parts?.[0]?.text || '';
+    return {
+      text,
+      modelUsed: model.modelName,
+      tokenUsage: {
+        input: data.usageMetadata?.promptTokenCount || 0,
+        output: data.usageMetadata?.candidatesTokenCount || 0,
+      },
+    };
+  }
+}
+
+export const aiClient = new AIClient();
diff --git a/apps/minerva-server/src/services/union/ai-stats.ts b/apps/minerva-server/src/services/union/ai-stats.ts
